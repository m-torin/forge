# Camoufox - Stealth Browser Automation Service
# Railway will automatically set PORT, but you can override locally
PORT=3000

# Node Environment
NODE_ENV=production

# Browser Configuration
HEADLESS=true
MAX_CONCURRENT_SESSIONS=5
SESSION_TIMEOUT=300000
BROWSER_TIMEOUT=30000

# Stealth Configuration
ENABLE_CANVAS_FINGERPRINTING=true
ENABLE_WEBGL_FINGERPRINTING=true
ENABLE_AUDIO_FINGERPRINTING=true
RANDOMIZE_USER_AGENT=true

# Performance Settings
RUST_ENGINE_ENABLED=true
RUST_OPTIMIZATION_LEVEL=3
MEMORY_LIMIT=2048
CPU_LIMIT=2

# Fingerprinting Resistance
CANVAS_NOISE_LEVEL=5
WEBGL_VENDOR_OVERRIDE=true
WEBGL_RENDERER_OVERRIDE=true
FONT_FINGERPRINT_PROTECTION=true

# Proxy Configuration (optional)
# PROXY_URL=http://proxy:8080
# PROXY_USERNAME=username
# PROXY_PASSWORD=password

# Anti-Detection
BOT_DETECTION_EVASION=true
TIMING_RANDOMIZATION=true
MOUSE_MOVEMENT_SIMULATION=true
KEYBOARD_SIMULATION=true

# Resource Management
CLEANUP_INTERVAL=60000
MAX_PAGE_LOAD_TIME=30000
ENABLE_REQUEST_INTERCEPTION=true

# Logging
LOG_LEVEL=info
ENABLE_PERFORMANCE_LOGGING=true
ENABLE_STEALTH_LOGGING=false

# Health Check
HEALTH_CHECK_INTERVAL=30000

# Optional: Advanced settings
ENABLE_DEVTOOLS=false
SCREENSHOT_QUALITY=80
PDF_GENERATION=true