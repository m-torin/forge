{
  "name": "@repo/trycomp",
  "version": "0.1.0",
  "type": "module",
  "description": "TryComp.ai integration service for AI-powered code comparison and analysis",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./client": "./src/client.ts",
    "./server": "./src/server.ts",
    "./types": "./src/types.ts",
    "./compare": "./src/compare.ts",
    "./analysis": "./src/analysis.ts"
  },
  "scripts": {
    "test": "vitest",
    "typecheck": "tsc --noEmit",
    "compare": "tsx scripts/trycomp-cli.ts compare",
    "analyze": "tsx scripts/trycomp-cli.ts analyze",
    "diff": "tsx scripts/trycomp-cli.ts diff"
  },
  "bin": {
    "trycomp": "./scripts/trycomp-cli.ts"
  },
  "dependencies": {
    "zod": "catalog:",
    "commander": "catalog:",
    "diff": "^6.0.0",
    "openai": "^4.75.1",
    "@anthropic-ai/sdk": "^0.54.0"
  },
  "devDependencies": {
    "@repo/eslint-config": "workspace:*",
    "@repo/config": "workspace:*",
    "@repo/testing": "workspace:*",
    "@types/diff": "^6.0.0",
    "typescript": "catalog:",
    "vitest": "catalog:",
    "tsx": "catalog:"
  },
  "peerDependencies": {
    "typescript": ">=5.0.0"
  }
}
