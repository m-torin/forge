# OpenGrep - Static Code Analysis Service
# Railway will automatically set PORT, but you can override locally
PORT=3000

# Node Environment
NODE_ENV=production

# Semgrep Configuration
SEMGREP_TIMEOUT=300
SEMGREP_MAX_MEMORY=2048
SEMGREP_RULES_PATH=/app/src/rules

# Optional: Custom Semgrep settings
SEMGREP_VERBOSE=false
SEMGREP_AUTOFIX=false
SEMGREP_METRICS=false

# Optional: API Keys for enhanced rules (if using Semgrep Pro)
# SEMGREP_APP_TOKEN=your_semgrep_token_here

# Logging
LOG_LEVEL=info

# Health Check
HEALTH_CHECK_INTERVAL=30000