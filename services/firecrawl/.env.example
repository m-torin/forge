# Firecrawl - Web Scraping Service
# Railway will automatically set PORT, but you can override locally
PORT=3002

# Node Environment
NODE_ENV=production

# Core Service Configuration
NUM_WORKERS_PER_QUEUE=8
PLAYWRIGHT_MICROSERVICE_URL=http://localhost:3000
FIRE_ENGINE_BETA_URL=http://localhost:3000

# Redis Configuration (required)
REDIS_URL=redis://localhost:6379
REDIS_RATE_LIMIT_URL=redis://localhost:6379

# Supabase Configuration (optional - for managed deployment)
# SUPABASE_URL=your_supabase_url
# SUPABASE_ANON_KEY=your_supabase_anon_key
# SUPABASE_SERVICE_TOKEN=your_supabase_service_token

# API Configuration
USE_DB_AUTHENTICATION=false
FIRECRAWL_API_KEY=your_firecrawl_api_key_here

# Rate Limiting
RATE_LIMIT_TEST_MODE=false
SCRAPE_RATE_LIMIT_TEST_MODE=false

# AI Configuration (optional)
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Scraping Configuration
MAX_CRAWL_PAGES=1000
DEFAULT_CRAWL_LIMIT=100
CRAWL_TIMEOUT=300000
PAGE_TIMEOUT=30000

# Content Processing
ENABLE_AI_EXTRACTION=true
ENABLE_MARKDOWN_CONVERSION=true
ENABLE_HTML_CLEANING=true
ENABLE_PDF_PROCESSING=true

# Performance Settings
CONCURRENT_CRAWLERS=5
REQUEST_TIMEOUT=30000
RETRY_ATTEMPTS=3
RETRY_DELAY=2000

# Storage Configuration
STORAGE_TYPE=local
# AWS_ACCESS_KEY_ID=your_aws_key
# AWS_SECRET_ACCESS_KEY=your_aws_secret
# AWS_REGION=us-east-1
# S3_BUCKET=your_bucket_name

# Logging
LOG_LEVEL=info
ENABLE_VERBOSE_LOGGING=false
ENABLE_DEBUG_MODE=false

# Health Check
HEALTH_CHECK_INTERVAL=30000

# Security
ENABLE_CORS=true
ALLOWED_ORIGINS=*
MAX_REQUEST_SIZE=50mb

# Optional: Webhook configuration
# WEBHOOK_URL=https://your-webhook-endpoint.com
# WEBHOOK_SECRET=your_webhook_secret