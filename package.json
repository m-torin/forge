{
  "name": "forge",
  "version": "4.2.10",
  "bin": {
    "forge": "dist/index.js"
  },
  "files": [
    "dist/index.js"
  ],
  "scripts": {
    "prebuild": "pnpm --filter=@repo/database build",
    "predev": "pnpm --filter=@repo/database build",
    "dev": "turbo dev",
    "build": "doppler run --project monorepo --config dev -- turbo build --parallel",
    "build:local": "turbo build:local --parallel",
    "doppler": "pnpm exec turbo run doppler || npx turbo run doppler",
    "doppler:setup": "doppler setup",
    "doppler:login": "doppler login",
    "doppler:logout": "doppler logout",
    "doppler:whoami": "doppler whoami",
    "doppler:secrets": "turbo run doppler:secrets",
    "doppler:secrets:upload": "turbo run doppler:secrets:upload",
    "doppler:secrets:download": "turbo run doppler:secrets:download",
    "doppler:pull": "turbo run doppler:pull",
    "doppler:sync": "for dir in apps/*; do if [ -f \"$dir/.env.local\" ]; then echo \"Uploading $dir\" && (cd \"$dir\" && doppler secrets upload .env.local); fi; done",
    "doppler:sync:dry": "for dir in apps/*; do if [ -f \"$dir/.env.local\" ]; then echo \"Would upload: $dir/.env.local\"; fi; done",
    "doppler:open": "turbo run doppler:open",
    "lint": "pnpm prettier && turbo lint --parallel",
    "lint:packages": "turbo typecheck --filter=\"./packages/*\" --parallel",
    "prettier": "prettier --log-level=error \"**/*.{ts,tsx,js,jsx,json,md,mdx,css,scss,yaml,yml,graphql,gql}\" --write",
    "bump-deps": "node scripts/update-workspace.mjs",
    "test": "turbo test --parallel --concurrency=10",
    "test:coverage": "turbo test:coverage --parallel --concurrency=10 && node scripts/aggregate-coverage.js",
    "test:doppler": "doppler run -- turbo test --parallel --concurrency=10",
    "test:e2e": "turbo test:e2e --parallel",
    "test:e2e:ui": "turbo test:e2e:ui",
    "test:e2e:headed": "turbo test:e2e:headed",
    "typecheck": "turbo typecheck",
    "check": "pnpm typecheck && pnpm lint && pnpm test",
    "analyze": "turbo analyze",
    "translate": "turbo translate",
    "boundaries": "turbo boundaries",
    "bump-ui": "npx shadcn@latest add --all --overwrite -c packages/design-system",
    "migrate": "doppler run -- pnpm --filter @repo/database migrate",
    "migrate:offline": "pnpm --filter @repo/database migrate",
    "clean": "./scripts/clean-everything.sh",
    "mac-setup": "./scripts/mac-setup.sh",
    "knip": "knip --config @repo/config/knip/monorepo.json",
    "knip:production": "knip --config @repo/config/knip/monorepo.json --production",
    "knip:workspace": "knip --config @repo/config/knip/monorepo.json --workspace",
    "knip:fix": "knip --config @repo/config/knip/monorepo.json --fix",
    "knip:reporter": "knip --config @repo/config/knip/monorepo.json --reporter json",
    "knip:apps": "knip --config @repo/config/knip/monorepo.json --workspace 'apps/*'",
    "knip:packages": "knip --config @repo/config/knip/monorepo.json --workspace 'packages/*'",
    "knip:labs": "knip --config @repo/config/knip/monorepo.json --workspace 'labs/*'",
    "circular": "madge --circular --extensions ts,tsx,js,jsx ."
  },
  "devDependencies": {
    "@auto-it/first-time-contributor": "^11.3.0",
    "@next/eslint-plugin-next": "catalog:",
    "@repo/config": "workspace:*",
    "@turbo/gen": "^2.5.4",
    "@types/node": "catalog:",
    "eslint": "catalog:",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "glob": "^11.0.2",
    "js-yaml": "^4.1.0",
    "knip": "^5.60.2",
    "madge": "^8.0.0",
    "prettier": "^3.5.3",
    "prettier-plugin-organize-imports": "^4.1.0",
    "prettier-plugin-tailwindcss": "^0.6.12",
    "tsup": "^8.5.0",
    "turbo": "^2.5.4",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "engines": {
    "node": ">=22",
    "pnpm": ">=10.0.0"
  },
  "packageManager": "pnpm@10.12.1",
  "dependencies": {
    "@clack/prompts": "^0.11.0",
    "@eslint/markdown": "^6.5.0",
    "commander": "^14.0.0",
    "server-only": "catalog:"
  },
  "type": "module"
}
