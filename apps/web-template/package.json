    "react-dom": "catalog:",
    "react-hooks-global-state": "^2.1.0",
    "react-instantsearch": "^7.15.8",
    "react-instantsearch-nextjs": "^0.4.9",
    "react-swipeable": "^7.0.1",
    "schema-dts": "^1.1.5",
    "tailwind-preset-mantine": "catalog:",
