{
  "name": "web-template",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --port 3250",
    "build": "next build",
    "build:local": "next build",
    "start": "next start --port 3250",
    "lint": "eslint . --fix",
    "typecheck": "tsc --noEmit --emitDeclarationOnly false",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:basic": "playwright test e2e/app.spec.ts e2e/navigation.spec.ts",
    "dev:e2e": "concurrently --kill-others --success first \"npm:dev\" \"npm:dev:e2e:wait\"",
    "dev:e2e:wait": "wait-on http://localhost:3250 && npm run test:e2e"
  },
  "dependencies": {
    "@algolia/autocomplete-core": "^1.19.2",
    "@algolia/autocomplete-js": "^1.19.2",
