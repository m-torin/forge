    "@algolia/client-search": "^5.27.0",
    "@heroicons/react": "^2.2.0",
    "@mantine/carousel": "catalog:",
    "@mantine/core": "catalog:",
    "@mantine/form": "catalog:",
    "@mantine/hooks": "catalog:",
    "@mantine/notifications": "catalog:",
    "@repo/analytics": "workspace:*",
    "@repo/config": "workspace:*",
    "@repo/internationalization": "workspace:*",
    "@repo/security": "workspace:*",
    "@repo/seo": "workspace:*",
    "@t3-oss/env-nextjs": "catalog:",
    "@tabler/icons-react": "catalog:",
    "@vercel/edge-config": "^1.2.0",
    "@vercel/toolbar": "catalog:",
    "algoliasearch": "^5.27.0",
    "clsx": "catalog:",
    "embla-carousel-autoplay": "^8.0.0",
    "framer-motion": "catalog:",
