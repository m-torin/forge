# Database
DATABASE_URL="postgresql://user:password@localhost:5432/forge"
DIRECT_DATABASE_URL="postgresql://user:password@localhost:5432/forge"

# Better Auth
BETTER_AUTH_SECRET="your-secret-here-min-32-chars-long"
BETTER_AUTH_URL="http://localhost:3900"
BETTER_AUTH_TRUSTED_ORIGINS="http://localhost:3900"

# Public
NEXT_PUBLIC_APP_URL="http://localhost:3900"

# PostHog & Feature Flags (Optional - for Vercel Toolbar integration)
NEXT_PUBLIC_POSTHOG_HOST="https://app.posthog.com"
NEXT_PUBLIC_POSTHOG_KEY="phc_test_key"
POSTHOG_HOST="https://app.posthog.com"  
POSTHOG_KEY="phc_test_key"
POSTHOG_PERSONAL_API_KEY="phx_personal_api_key"
POSTHOG_PROJECT_ID="12345"

# Feature Flags (optional)
LOCAL_FLAGS=""

# Demo Mode - Set to "true" to use hardcoded data instead of database
# This is useful for running the app without a database connection
DEMO_MODE="false"

# Observability (optional)
# Sentry
NEXT_PUBLIC_SENTRY_DSN=""
SENTRY_DSN=""
SENTRY_ORG=""
SENTRY_PROJECT=""
SENTRY_AUTH_TOKEN=""
NEXT_PUBLIC_ENV="development"

# Logtail
LOGTAIL_SOURCE_TOKEN=""