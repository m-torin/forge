# QStash Configuration (for local development)
QSTASH_URL=http://localhost:8080
QSTASH_TOKEN=your-qstash-token-here
QSTASH_CURRENT_SIGNING_KEY=your-current-signing-key
QSTASH_NEXT_SIGNING_KEY=your-next-signing-key

# Redis Configuration (optional - uses in-memory store if not provided)
# REDIS_URL=redis://localhost:6379

# WebSocket Configuration
WS_PORT=3101
NEXT_PUBLIC_WS_URL=ws://localhost:3101

# Development Configuration
NODE_ENV=development
LOG_LEVEL=debug
NEXT_PUBLIC_APP_NAME=Workflows

# Performance Configuration
MAX_CONCURRENT_WORKFLOWS=10
WORKFLOW_TIMEOUT=300000
METRICS_RETENTION_DAYS=7