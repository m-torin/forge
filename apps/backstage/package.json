{
  "name": "backstage",
  "private": true,
  "scripts": {
    "predev": "pnpm --filter=@repo/database build",
    "dev": "next dev -p 3300",
    "prebuild": "pnpm --filter=@repo/database build",
    "build": "doppler run -- next build",
    "build:local": "next build",
    "start": "node dist/index.js",
    "start:local": "next start",
    "analyze": "doppler run -- ANALYZE=true pnpm build",
    "analyze:local": "ANALYZE=true pnpm build:local",
    "test": "vitest run",
    "test:doppler": "doppler run -- NODE_ENV=test vitest run",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "stripe": "stripe listen --forward-to localhost:3300/webhooks/stripe",
    "typecheck": "tsc --noEmit --emitDeclarationOnly false",
    "lint": "eslint . --ext .ts,.tsx",
    "knip": "knip",
    "doppler:secrets": "doppler secrets",
    "doppler:secrets:upload": "doppler secrets upload .env.local",
    "doppler:secrets:download": "doppler secrets download --no-file --format env",
    "doppler:pull": "doppler secrets download --no-file --format env > .env.local",
    "doppler:open": "doppler open"
  },
  "dependencies": {
    "@hello-pangea/dnd": "^18.0.1",
    "@mantine/core": "^8.1.1",
    "@mantine/dates": "^8.1.1",
    "@mantine/dropzone": "^8.1.1",
    "@mantine/form": "^8.1.1",
    "@mantine/hooks": "^8.1.1",
    "@mantine/modals": "^8.1.1",
    "@mantine/notifications": "^8.1.1",
    "@mantine/spotlight": "^8.1.1",
    "@repo/ai": "workspace:*",
    "@repo/auth": "workspace:*",
    "@repo/config": "workspace:*",
    "@repo/database": "workspace:*",
    "@repo/feature-flags": "workspace:*",
    "@repo/observability": "workspace:*",
    "@repo/orchestration": "workspace:*",
    "@repo/payments": "workspace:*",
    "@repo/security": "workspace:*",
    "@repo/testing": "workspace:*",
    "@sentry/nextjs": "^9.30.0",
    "@t3-oss/env-nextjs": "^0.13.8",
    "@tabler/icons-react": "^3.34.0",
    "@upstash/workflow": "^0.2.14",
    "@vercel/toolbar": "^0.1.37",
    "clsx": "2.1.1",
    "date-fns": "^4.1.0",
    "dayjs": "^1.11.13",
    "mantine-react-table": "2.0.0-beta.9",
    "nanoid": "^5.1.5",
    "next": "^15.3.4",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-hook-form": "^7.58.1",
    "svix": "^1.67.0",
    "zod": "^3.25.67"
  },
  "devDependencies": {
    "@repo/config": "workspace:*",
    "@repo/eslint-config": "workspace:*",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@types/eslint": "^9.6.1",
    "@types/node": "^24.0.3",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.1.2",
    "eslint": "^9.29.0",
    "jsdom": "^26.1.0",
    "nodemon": "^3.1.10",
    "postcss-preset-mantine": "^1.17.0",
    "postcss-simple-vars": "^7.0.1",
    "tsx": "^4.20.3",
    "typescript": "5.8.3"
  }
}
