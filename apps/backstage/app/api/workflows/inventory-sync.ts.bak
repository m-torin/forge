/**
 * Inventory Sync Workflow
 * Real-time inventory tracking across all affiliate networks
 */

import { z } from 'zod';

import {
  compose,
  createStep,
  createStepWithValidation,
  StepTemplates,
  withStepCircuitBreaker,
  withStepMonitoring,
  withStepRetry,
  withStepTimeout,
} from '@repo/orchestration';

// Input schemas
const InventorySyncInput = z.object({
  mode: z.enum(['realtime', 'batch', 'webhook', 'reconciliation']).default('batch'),
  networks: z.array(
    z.object({
      id: z.string(),
      name: z.string(),
      apiEndpoint: z.string(),
      rateLimit: z.object({
        requests: z.number(),
        window: z.number(), // seconds
      }),
      webhookSupported: z.boolean(),
    }),
  ),
  products: z
    .array(
      z.object({
        currentInventory: z
          .object({
            lastChecked: z.string().datetime(),
            quantity: z.number(),
            status: z.enum(['in_stock', 'out_of_stock', 'limited', 'discontinued']),
          })
          .optional(),
        networkMappings: z.record(z.string()), // networkId -> networkProductId
        productId: z.string(),
        sku: z.string(),
      }),
    )
    .optional(),
  syncConfig: z.object({
    alertThresholds: z.object({
      rapidDepletion: z.number().default(0.8), // 80% depletion rate
      backInStock: z.boolean().default(true),
      lowStock: z.number().default(10),
      outOfStock: z.boolean().default(true),
    }),
    batchSize: z.number().default(100),
    checkInterval: z.number().default(300), // 5 minutes
    enablePredictions: z.boolean().default(true),
    webhookConfig: z
      .object({
        endpoint: z.string().url().optional(),
        events: z.array(z.enum(['out_of_stock', 'back_in_stock', 'low_stock'])).default(['all']),
        secret: z.string().optional(),
      })
      .optional(),
  }),
});

// Inventory update schema
const InventoryUpdate = z.object({
  changes: z.object({
    changeRate: z.number(), // units per hour
    previousQuantity: z.number(),
    quantityChange: z.number(),
    trend: z.enum(['increasing', 'decreasing', 'stable']),
  }),
  inventory: z.object({
    availability: z
      .object({
        online: z.boolean(),
        stores: z
          .array(
            z.object({
              quantity: z.number(),
              storeId: z.string(),
              zipCode: z.string(),
            }),
          )
          .optional(),
      })
      .optional(),
    nextRestockDate: z.string().datetime().optional(),
    quantity: z.number(),
    reservedQuantity: z.number().optional(),
    status: z.enum(['in_stock', 'out_of_stock', 'limited', 'discontinued']),
  }),
  networkId: z.string(),
  productId: z.string(),
  timestamp: z.string(),
});

// Step 1: Initialize sync session
export const initializeSyncSessionStep = compose(
  createStepWithValidation(
    'initialize-sync',
    async (input: z.infer<typeof InventorySyncInput>) => {
      const { mode, networks, products, syncConfig } = input;

      // Create sync session
      const sessionId = `inv_sync_${Date.now()}`;

      // Determine products to sync
      let productsToSync = products || [];
      if (!products) {
        // Fetch all active products
        productsToSync = await fetchActiveProducts();
      }

      // Setup webhook listeners if supported
      const webhookSubscriptions = [];
      if (mode === 'webhook' || mode === 'realtime') {
        for (const network of networks) {
          if (network.webhookSupported) {
            const subscription = await setupWebhookListener(network, syncConfig.webhookConfig);
            webhookSubscriptions.push(subscription);
          }
        }
      }

      return {
        ...input,
        products: productsToSync,
        sessionId,
        syncStarted: new Date().toISOString(),
        totalProducts: productsToSync.length,
        webhookSubscriptions,
      };
    },
    (input) => input.networks.length > 0,
    (output) => output.products.length > 0,
  ),
  (step) => withStepTimeout(step, { execution: 30000 }),
  (step) =>
    withStepMonitoring(step, {
, 'networkCount'],
      enableDetailedLogging: true,
    }),
);

// Mock function to fetch active products
async function fetchActiveProducts(): Promise<any[]> {
  return Array.from({ length: 200 }, (_, i) => ({
    currentInventory: {
      lastChecked: new Date(Date.now() - Math.random() * 3600000).toISOString(),
      quantity: Math.floor(Math.random() * 100),
      status: Math.random() > 0.1 ? 'in_stock' : 'out_of_stock',
    },
    networkMappings: {
      network_1: `AMZN_${i}`,
      network_2: `WMT_${i}`,
      network_3: `TGT_${i}`,
    },
    productId: `prod_${i}`,
    sku: `SKU-${i.toString().padStart(6, '0')}`,
  }));
}

// Mock webhook setup
async function setupWebhookListener(network: any, config: any): Promise<any> {
  return {
    createdAt: new Date().toISOString(),
    endpoint: config?.endpoint || `https://api.example.com/webhooks/inventory/${network.id}`,
    events: config?.events || ['all'],
    networkId: network.id,
    status: 'active',
    subscriptionId: `webhook_${network.id}_${Date.now()}`,
  };
}

// Step 2: Fetch current inventory levels
export const fetchInventoryLevelsStep = compose(
  createStep('fetch-inventory', async (data: any) => {
    const { networks, products, syncConfig } = data;
    const inventoryUpdates = [];
    const failedChecks = [];

    // Process in batches to respect rate limits
    for (const network of networks) {
      const networkProducts = products.filter((p: any) => p.networkMappings[network.id]);
      const batchSize = Math.min(syncConfig.batchSize, network.rateLimit.requests);

      for (let i = 0; i < networkProducts.length; i += batchSize) {
        const batch = networkProducts.slice(i, i + batchSize);

        try {
          // Respect rate limit window
          if (i > 0) {
            await new Promise((resolve) =>
              setTimeout(resolve, (network.rateLimit.window * 1000) / network.rateLimit.requests),
            );
          }

          // Fetch inventory for batch
          const batchUpdates = await fetchNetworkInventory(network, batch);
          inventoryUpdates.push(...batchUpdates);
        } catch (error) {
          console.error(`Failed to fetch inventory from ${network.name}:`, error);
          failedChecks.push({
            (error as Error): (error as Error).message,
            networkId: network.id,
            products: batch.map((p: any) => p.productId),
            timestamp: new Date().toISOString(),
          });
        }
      }
    }

    return {
      ...data,
      failedChecks,
      fetchStats: {
        failed: failedChecks.length,
        successRate: inventoryUpdates.length / (inventoryUpdates.length + failedChecks.length),
        totalChecked: inventoryUpdates.length,
      },
      inventoryUpdates,
    };
  }),
  (step) =>
    withStepRetry(step, {
      backoff: 'exponential',
      maxAttempts: 3,
,
    }),
  (step) =>
    withStepCircuitBreaker(step, {
      threshold: 0.5,
,
      resetTimeout: 300000,
      timeout: 60000,
    }),
);

// Mock inventory fetching
async function fetchNetworkInventory(network: any, products: any[]): Promise<any[]> {
  await new Promise((resolve) => setTimeout(resolve, 100)); // Simulate API call

  return products.map((product) => {
    const previousQuantity = product.currentInventory?.quantity || 0;
    const quantityChange = Math.floor((Math.random() - 0.5) * 20);
    const newQuantity = Math.max(0, previousQuantity + quantityChange);

    return {
      changes: {
        changeRate: quantityChange / 1, // per hour
        previousQuantity,
        quantityChange,
        trend: quantityChange > 0 ? 'increasing' : quantityChange < 0 ? 'decreasing' : 'stable',
      },
      inventory: {
        availability: {
          online: newQuantity > 0,
          stores: Math.random() > 0.7 ? generateStoreAvailability() : undefined,
        },
        nextRestockDate:
          newQuantity === 0
            ? new Date(Date.now() + 7 * 24 * 60 * 60 * 1000).toISOString()
            : undefined,
        quantity: newQuantity,
        reservedQuantity: Math.floor(newQuantity * 0.1),
        status: newQuantity > 0 ? (newQuantity < 10 ? 'limited' : 'in_stock') : 'out_of_stock',
      },
      networkId: network.id,
      productId: product.productId,
      timestamp: new Date().toISOString(),
    };
  });
}

function generateStoreAvailability(): any[] {
  return Array.from({ length: 3 }, (_, i) => ({
    quantity: Math.floor(Math.random() * 10),
    storeId: `store_${i}`,
    zipCode: `${10000 + i * 1000}`,
  }));
}

// Step 3: Analyze inventory changes
export const analyzeInventoryChangesStep = createStep('analyze-changes', async (data: any) => {
  const { inventoryUpdates, syncConfig } = data;
  const { alertThresholds } = syncConfig;

  const alerts = {
    rapidDepletion: [],
    backInStock: [],
    lowStock: [],
    outOfStock: [],
  };

  const trends = {
    byNetwork: new Map(),
    byProduct: new Map(),
    overall: {
      averageQuantity: 0,
      totalInStock: 0,
      totalLimited: 0,
      totalOutOfStock: 0,
    },
  };

  // Analyze each update
  inventoryUpdates.forEach((update: any) => {
    const { changes, inventory, networkId, productId } = update;

    // Check for alerts
    if (inventory.status === 'out_of_stock' && changes.previousQuantity > 0) {
      alerts.outOfStock.push({
        networkId,
        previousQuantity: changes.previousQuantity,
        productId,
        timestamp: update.timestamp,
      });
    }

    if (inventory.status === 'in_stock' && changes.previousQuantity === 0) {
      alerts.backInStock.push({
        networkId,
        newQuantity: inventory.quantity,
        productId,
        restocked: true,
        timestamp: update.timestamp,
      });
    }

    if (inventory.quantity > 0 && inventory.quantity <= alertThresholds.lowStock) {
      alerts.lowStock.push({
        networkId,
        productId,
        quantity: inventory.quantity,
        threshold: alertThresholds.lowStock,
        timestamp: update.timestamp,
      });
    }

    if (changes.changeRate < -alertThresholds.rapidDepletion * changes.previousQuantity) {
      alerts.rapidDepletion.push({
        depletionRate: Math.abs(changes.changeRate),
        hoursUntilEmpty: inventory.quantity / Math.abs(changes.changeRate),
        networkId,
        productId,
        timestamp: update.timestamp,
      });
    }

    // Update trends
    if (!trends.byProduct.has(productId)) {
      trends.byProduct.set(productId, {
        averageChange: 0,
        quantities: [],
        trend: 'stable',
      });
    }
    trends.byProduct.get(productId).quantities.push({
      networkId,
      quantity: inventory.quantity,
      timestamp: update.timestamp,
    });

    // Network trends
    if (!trends.byNetwork.has(networkId)) {
      trends.byNetwork.set(networkId, {
        inStock: 0,
        limited: 0,
        outOfStock: 0,
        totalQuantity: 0,
      });
    }
    const networkTrend = trends.byNetwork.get(networkId);
    if (inventory.status === 'in_stock') networkTrend.inStock++;
    else if (inventory.status === 'out_of_stock') networkTrend.outOfStock++;
    else if (inventory.status === 'limited') networkTrend.limited++;
    networkTrend.totalQuantity += inventory.quantity;

    // Overall trends
    if (inventory.status === 'in_stock') trends.overall.totalInStock++;
    else if (inventory.status === 'out_of_stock') trends.overall.totalOutOfStock++;
    else if (inventory.status === 'limited') trends.overall.totalLimited++;
    trends.overall.averageQuantity += inventory.quantity;
  });

  trends.overall.averageQuantity /= inventoryUpdates.length || 1;

  return {
    ...data,
    alerts,
    analysisComplete: true,
    trends: {
      byNetwork: Array.from(trends.byNetwork.entries()).map(([networkId, data]) => ({
        networkId,
        ...data,
        stockRate: data.inStock / (data.inStock + data.outOfStock + data.limited),
      })),
      byProduct: Array.from(trends.byProduct.entries()).map(([productId, data]) => ({
        productId,
        ...data,
      })),
      overall: trends.overall,
    },
  };
});

// Step 4: Predict stock levels
export const predictStockLevelsStep = createStep('predict-stock', async (data: any) => {
  const { inventoryUpdates, syncConfig, trends } = data;

  if (!syncConfig.enablePredictions) {
    return {
      ...data,
      predictionsSkipped: true,
    };
  }

  const predictions = [];

  // Group updates by product
  const productUpdates = new Map();
  inventoryUpdates.forEach((update: any) => {
    if (!productUpdates.has(update.productId)) {
      productUpdates.set(update.productId, []);
    }
    productUpdates.get(update.productId).push(update);
  });

  // Generate predictions for each product
  for (const [productId, updates] of productUpdates.entries()) {
    const prediction = predictProductStock(productId, updates);
    predictions.push(prediction);
  }

  // Identify products at risk
  const atRiskProducts = predictions.filter((p) => p.predictedStockout && p.daysUntilStockout <= 3);

  return {
    ...data,
    atRiskProducts,
    predictions,
    predictionStats: {
      averageDaysUntilStockout:
        predictions
          .filter((p) => p.predictedStockout)
          .reduce((sum, p) => sum + p.daysUntilStockout, 0) /
          predictions.filter((p) => p.predictedStockout).length || 0,
      productsAtRisk: atRiskProducts.length,
      totalPredictions: predictions.length,
    },
  };
});

function predictProductStock(productId: string, updates: any[]): any {
  // Simple linear regression for demo
  const sortedUpdates = updates.sort(
    (a, b) => new Date(a.timestamp).getTime() - new Date(b.timestamp).getTime(),
  );

  if (sortedUpdates.length < 2) {
    return {
      confidence: 0.1,
      predictedStockout: false,
      productId,
    };
  }

  // Calculate average change rate
  const totalChange = sortedUpdates.reduce((sum, update) => sum + update.changes.quantityChange, 0);
  const timeSpan =
    (new Date(sortedUpdates[sortedUpdates.length - 1].timestamp).getTime() -
      new Date(sortedUpdates[0].timestamp).getTime()) /
    (1000 * 60 * 60); // hours

  const changeRate = totalChange / timeSpan;
  const currentQuantity = sortedUpdates[sortedUpdates.length - 1].inventory.quantity;

  let daysUntilStockout = null;
  let predictedStockout = false;

  if (changeRate < 0 && currentQuantity > 0) {
    const hoursUntilEmpty = currentQuantity / Math.abs(changeRate);
    daysUntilStockout = hoursUntilEmpty / 24;
    predictedStockout = true;
  }

  return {
    confidence: Math.min(0.9, 0.3 + sortedUpdates.length * 0.1),
    changeRate,
    currentQuantity,
    daysUntilStockout,
    predictedStockout,
    productId,
    recommendation: daysUntilStockout && daysUntilStockout < 7 ? 'restock_urgent' : 'monitor',
  };
}

// Step 5: Update consolidated inventory
export const updateConsolidatedInventoryStep = compose(
  createStep('update-consolidated', async (data: any) => {
    const { inventoryUpdates, products } = data;

    // Consolidate inventory across all networks
    const consolidatedInventory = new Map();

    products.forEach((product: any) => {
      const productInventory = {
        consolidatedStatus: 'out_of_stock',
        bestAvailability: null,
        lastUpdated: new Date().toISOString(),
        networkInventory: {},
        productId: product.productId,
        sku: product.sku,
        totalQuantity: 0,
      };

      // Aggregate from all networks
      const productUpdates = inventoryUpdates.filter((u: any) => u.productId === product.productId);

      productUpdates.forEach((update: any) => {
        productInventory.networkInventory[(update.networkId as any)] = {
          lastChecked: update.timestamp,
          quantity: update.inventory.quantity,
          status: update.inventory.status,
        };

        productInventory.totalQuantity += update.inventory.quantity;

        // Update best availability
        if (update.inventory.status === 'in_stock' && !productInventory.bestAvailability) {
          productInventory.bestAvailability = update.networkId;
        }
      });

      // Set consolidated status
      if (productInventory.totalQuantity > 10) {
        productInventory.consolidatedStatus = 'in_stock';
      } else if (productInventory.totalQuantity > 0) {
        productInventory.consolidatedStatus = 'limited';
      }

      consolidatedInventory.set(product.productId, productInventory);
    });

    return {
      ...data,
      consolidatedInventory: Array.from(consolidatedInventory.values()),
      consolidationComplete: true,
    };
  }),
  (step) => withStepRetry(step, { maxAttempts: 3 }),
);

// Step 6: Send notifications
export const sendInventoryNotificationsStep = createStep(
  'send-notifications',
  async (data: any) => {
    const { alerts, atRiskProducts, syncConfig } = data;
    const notifications = [];

    // Out of stock notifications
    if (alerts.outOfStock.length > 0 && syncConfig.alertThresholds.outOfStock) {
      notifications.push({
        type: 'out_of_stock',
        count: alerts.outOfStock.length,
        message: `${alerts.outOfStock.length} products went out of stock`,
        priority: 'high',
        products: alerts.outOfStock.slice(0, 10), // Top 10
        timestamp: new Date().toISOString(),
      });
    }

    // Back in stock notifications
    if (alerts.backInStock.length > 0 && syncConfig.alertThresholds.backInStock) {
      notifications.push({
        type: 'back_in_stock',
        count: alerts.backInStock.length,
        message: `${alerts.backInStock.length} products are back in stock`,
        priority: 'medium',
        products: alerts.backInStock.slice(0, 10),
        timestamp: new Date().toISOString(),
      });
    }

    // Low stock warnings
    if (alerts.lowStock.length > 0) {
      notifications.push({
        type: 'low_stock',
        count: alerts.lowStock.length,
        message: `${alerts.lowStock.length} products have low stock`,
        priority: 'medium',
        products: alerts.lowStock.slice(0, 10),
        timestamp: new Date().toISOString(),
      });
    }

    // Rapid depletion alerts
    if (alerts.rapidDepletion.length > 0) {
      notifications.push({
        type: 'rapid_depletion',
        count: alerts.rapidDepletion.length,
        message: `${alerts.rapidDepletion.length} products depleting rapidly`,
        priority: 'high',
        products: alerts.rapidDepletion.slice(0, 5),
        timestamp: new Date().toISOString(),
      });
    }

    // At-risk products
    if (atRiskProducts && atRiskProducts.length > 0) {
      notifications.push({
        type: 'stockout_prediction',
        count: atRiskProducts.length,
        message: `${atRiskProducts.length} products predicted to stock out within 3 days`,
        priority: 'high',
        products: atRiskProducts.slice(0, 10),
        timestamp: new Date().toISOString(),
      });
    }

    // Send notifications (mock)
    for (const notification of notifications) {
      await sendNotification(notification, syncConfig.webhookConfig);
    }

    return {
      ...data,
      notifications,
      notificationsSent: notifications.length,
    };
  },
);

async function sendNotification(notification: any, webhookConfig: any): Promise<void> {
  // Mock notification sending
  console.log(`Sending ${notification.type} notification:`, notification.message);

  if (webhookConfig?.endpoint) {
    // Simulate webhook call
    await new Promise((resolve) => setTimeout(resolve, 100));
  }
}

// Step 7: Update cache and database
export const updateInventoryCacheStep = compose(
  StepTemplates.database('update-inventory-cache', 'Update inventory cache and database'),
  (step) => withStepRetry(step, { maxAttempts: 3 }),
);

// Step 8: Generate sync report
export const generateSyncReportStep = createStep('generate-report', async (data: any) => {
  const { alerts, fetchStats, inventoryUpdates, notifications, predictions, sessionId, trends } =
    data;

  const report = {
    alerts: {
      critical: [...alerts.outOfStock, ...alerts.rapidDepletion].slice(0, 20),
      summary: Object.entries(alerts).map(([type, items]) => ({
        type,
        count: items.length,
      })),
    },
    inventory: {
      criticalStockProducts: getCriticalStock(data.consolidatedInventory, 10),
      overall: trends.overall,
      topAvailableProducts: getTopAvailable(data.consolidatedInventory, 10),
    },
    performance: {
      averageResponseTime:
        (Date.now() - new Date(data.syncStarted).getTime()) / inventoryUpdates.length,
      successRate: fetchStats.successRate,
      syncDuration: Date.now() - new Date(data.syncStarted).getTime(),
    },
    predictions: predictions
      ? {
          atRiskCount: data.atRiskProducts?.length || 0,
          averageDaysToStockout: data.predictionStats?.averageDaysUntilStockout || 0,
          urgentRestockNeeded:
            data.atRiskProducts?.filter((p: any) => p.daysUntilStockout < 1).length || 0,
        }
      : null,
    recommendations: generateSyncRecommendations(data),
    sessionId,
    summary: {
      failedChecks: data.failedChecks?.length || 0,
      networksQueried: data.networks.length,
      notificationsSent: notifications.length,
      productsChecked: data.totalProducts,
      successfulChecks: inventoryUpdates.length,
      totalAlerts: Object.values(alerts).reduce((sum: number, arr: any[]) => sum + arr.length, 0),
    },
    timestamp: new Date().toISOString(),
  };

  return {
    ...data,
    report,
    syncComplete: true,
  };
});

function getTopAvailable(inventory: any[], limit: number): any[] {
  return inventory
    .sort((a, b) => b.totalQuantity - a.totalQuantity)
    .slice(0, limit)
    .map((item) => ({
      productId: item.productId,
      sku: item.sku,
      status: item.consolidatedStatus,
      totalQuantity: item.totalQuantity,
    }));
}

function getCriticalStock(inventory: any[], limit: number): any[] {
  return inventory
    .filter(
      (item) => item.consolidatedStatus === 'limited' || item.consolidatedStatus === 'out_of_stock',
    )
    .sort((a, b) => a.totalQuantity - b.totalQuantity)
    .slice(0, limit)
    .map((item) => ({
      networks: Object.entries(item.networkInventory)
        .filter(([_, inv]: [string, any]) => inv.quantity === 0)
        .map(([networkId]) => networkId),
      productId: item.productId,
      sku: item.sku,
      status: item.consolidatedStatus,
      totalQuantity: item.totalQuantity,
    }));
}

function generateSyncRecommendations(data: any): any[] {
  const recommendations = [];

  // High failure rate
  if (data.fetchStats?.successRate < 0.9) {
    recommendations.push({
      type: 'reliability',
      action: 'review_failed_networks',
      message: `Sync success rate is ${(data.fetchStats.successRate * 100).toFixed(1)}%. Check API connections.`,
      priority: 'high',
    });
  }

  // Many out of stock items
  const outOfStockRate = data.trends?.overall?.totalOutOfStock / data.totalProducts;
  if (outOfStockRate > 0.2) {
    recommendations.push({
      type: 'inventory',
      action: 'review_supplier_relationships',
      message: `${(outOfStockRate * 100).toFixed(1)}% of products are out of stock`,
      priority: 'high',
    });
  }

  // Rapid depletion
  if (data.alerts?.rapidDepletion?.length > 10) {
    recommendations.push({
      type: 'depletion',
      action: 'increase_restock_frequency',
      message: `${data.alerts.rapidDepletion.length} products depleting rapidly`,
      priority: 'medium',
    });
  }

  // Enable predictions
  if (!data.syncConfig.enablePredictions) {
    recommendations.push({
      type: 'feature',
      action: 'enable_predictions',
      message: 'Stock predictions are disabled. Enable for better inventory planning.',
      priority: 'low',
    });
  }

  return recommendations;
}

// Main workflow definition
export const inventorySyncWorkflow = {
  id: 'inventory-sync',
  name: 'Inventory Sync',
  config: {
    concurrency: {
      max: 10, // Allow multiple sync sessions
    },
    maxDuration: 3600000, // 1 hour
    schedule: {
      cron: '*/15 * * * *', // Every 15 minutes
      timezone: 'UTC',
    },
  },
  description: 'Real-time inventory tracking across all affiliate networks',
  features: {
    alertSystem: true,
    multiNetworkSync: true,
    realtimeTracking: true,
    stockPredictions: true,
    webhookSupport: true,
  },
  steps: [
    initializeSyncSessionStep,
    fetchInventoryLevelsStep,
    analyzeInventoryChangesStep,
    predictStockLevelsStep,
    updateConsolidatedInventoryStep,
    sendInventoryNotificationsStep,
    updateInventoryCacheStep,
    generateSyncReportStep,
  ],
  version: '1.0.0',
};
