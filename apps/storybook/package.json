{
  "name": "storybook",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "storybook build",
    "chromatic": "chromatic --exit-zero-on-changes",
    "clean": "git clean -xdf .cache .turbo dist node_modules",
    "dev": "storybook dev -p 6006",
    "lint": "eslint . --fix",
    "typecheck": "tsc --noEmit --emitDeclarationOnly false",
    "pixeleye": "concurrently \"pnpm run dev\" \"wait-on tcp:6006 && pixeleye storybook http://localhost:6006\"",
    "test": "vitest",
    "test:watch": "vitest watch",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "cy:open": "cypress open",
    "cy:run": "cypress run",
    "test:e2e": "start-server-and-test dev http://localhost:6006 cy:run"
  },
  "dependencies": {
    "@repo/design-system": "workspace:*",
    "@storybook/addon-actions": "^8.6.12",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "input-otp": "^1.4.2",
    "lucide-react": "^0.487.0",
    "next": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "react-hook-form": "^7.55.0",
    "recharts": "^2.15.2",
    "sonner": "^2.0.3",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^3.2.6",
    "@cypress/react": "^9.0.1",
    "@cypress/webpack-dev-server": "^4.0.2",
    "@repo/eslint-config": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "@storybook/addon-a11y": "^8.6.12",
    "@storybook/addon-essentials": "^8.6.12",
    "@storybook/addon-interactions": "^8.6.12",
    "@storybook/addon-links": "^8.6.12",
    "@storybook/addon-measure": "^8.6.12",
    "@storybook/addon-onboarding": "^8.6.12",
    "@storybook/addon-outline": "^8.6.12",
    "@storybook/addon-themes": "^8.6.12",
    "@storybook/blocks": "^8.6.12",
    "@storybook/nextjs": "^8.6.12",
    "@storybook/react": "^8.6.12",
    "@storybook/test": "^8.6.12",
    "@storybook/testing-react": "^2.0.1",
    "@testing-library/cypress": "^10.0.3",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/cypress": "^1.1.6",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@types/testing-library__cypress": "^5.0.13",
    "@vitest/coverage-istanbul": "^3.1.1",
    "@vitest/ui": "^3.1.1",
    "chromatic": "^11.28.0",
    "concurrently": "^9.1.2",
    "cypress": "^14.2.1",
    "jsdom": "catalog:",
    "pixeleye": "^0.8.8",
    "postcss": "catalog:",
    "start-server-and-test": "^2.0.11",
    "storybook": "^8.6.12",
    "tailwindcss": "catalog:",
    "typescript": "catalog:",
    "vitest": "^3.1.1",
    "wait-on": "^8.0.3"
  }
}