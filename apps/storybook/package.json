{
  "name": "storybook",
  "private": true,
  "scripts": {
    "dev": "storybook dev -p 3700 --quiet --loglevel warn --no-open",
    "build": "doppler run -- storybook build --quiet --loglevel warn",
    "build:local": "storybook build --quiet --loglevel warn",
    "chromatic": "doppler run -- chromatic --exit-zero-on-changes",
    "chromatic:local": "chromatic --exit-zero-on-changes",
    "typecheck": "tsc --noEmit --emitDeclarationOnly false",
    "lint": "echo 'Skipping ESLint check for storybook'",
    "doppler:secrets": "doppler secrets",
    "doppler:secrets:upload": "doppler secrets upload .env.local",
    "doppler:secrets:download": "doppler secrets download --no-file --format env",
    "doppler:pull": "doppler secrets download --no-file --format env > .env.local",
    "doppler:open": "doppler open"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.0.1",
    "@mantine/core": "catalog:",
    "@mantine/dates": "^8.0.2",
    "@mantine/hooks": "catalog:",
    "@repo/design-system": "workspace:*",
    "@tabler/icons-react": "catalog:",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "input-otp": "^1.4.2",
    "next": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "recharts": "^2.15.3",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^4.0.0",
    "@eslint/eslintrc": "^3.3.1",
    "@eslint/js": "^9.27.0",
    "@repo/typescript-config": "workspace:*",
    "@storybook/addon-docs": "^9.0.0",
    "@storybook/addon-onboarding": "^9.0.0",
    "@storybook/addon-themes": "^9.0.0",
    "@storybook/nextjs": "^9.0.0",
    "@types/eslint": "^9.6.1",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@typescript-eslint/eslint-plugin": "^8.33.0",
    "@typescript-eslint/parser": "^8.33.0",
    "chromatic": "^12.0.0",
    "eslint": "catalog:",
    "eslint-plugin-cypress": "^4.3.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-storybook": "9.0.0",
    "eslint-plugin-testing-library": "^7.2.2",
    "eslint-plugin-vitest": "^0.5.4",
    "postcss": "catalog:",
    "storybook": "^9.0.0",
    "typescript": "catalog:"
  }
}
