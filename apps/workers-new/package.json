{
  "name": "workers-new",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "dev": "concurrently \"pnpm:next\" \"pnpm:qstash:local\"",
    "dev:local": "WORKFLOW_MODE=local concurrently \"pnpm:next\" \"pnpm:qstash:local\"",
    "dev:cloud": "WORKFLOW_MODE=cloud pnpm next",
    "next": "next dev -p 3001",
    "qstash:local": "QSTASH_EVENT_METADATA=full npx @upstash/qstash-cli dev -port=8080",
    "qstash:only": "QSTASH_EVENT_METADATA=full npx @upstash/qstash-cli dev -port=8080",
    "build": "next build",
    "build:local": "next build",
    "start": "next start -p 3001",
    "typecheck": "tsc --noEmit --emitDeclarationOnly false",
    "lint": "eslint . --fix"
  },
  "dependencies": {
    "@ai-sdk/openai": "^1.0.8",
    "@mantine/core": "catalog:",
    "@mantine/hooks": "catalog:",
    "@mantine/notifications": "catalog:",
    "@repo/orchestration": "workspace:*",
    "@tabler/icons-react": "catalog:",
    "ai": "^4.0.16",
    "clsx": "catalog:",
    "next": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "tailwind-merge": "^2.5.2",
    "tailwind-preset-mantine": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "catalog:",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "autoprefixer": "catalog:",
    "concurrently": "^9.1.2",
    "eslint": "catalog:",
    "eslint-config-next": "14.2.9",
    "postcss": "catalog:",
    "prettier": "^3.3.3",
    "prettier-plugin-tailwindcss": "^0.6.6",
    "typescript": "catalog:"
  }
}
