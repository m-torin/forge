# Environment Mode Control
# Set to "local" for QStash CLI or "cloud" for Upstash cloud services
WORKFLOW_MODE="local"

# === LOCAL DEVELOPMENT CONFIGURATION ===
# Used when WORKFLOW_MODE="local"
LOCAL_QSTASH_URL="http://localhost:8080"
LOCAL_QSTASH_TOKEN="eyJVc2VySUQiOiJkZWZhdWx0VXNlciIsIlBhc3N3b3JkIjoiZGVmYXVsdFBhc3N3b3JkIn0="
LOCAL_WORKFLOW_URL="http://localhost:3001"

# === CLOUD CONFIGURATION ===
# Used when WORKFLOW_MODE="cloud"
# Get these from https://console.upstash.com/qstash
CLOUD_QSTASH_URL="https://qstash.upstash.io"
CLOUD_QSTASH_TOKEN="your_qstash_token_here"
CLOUD_QSTASH_CURRENT_SIGNING_KEY="your_current_signing_key_here"
CLOUD_QSTASH_NEXT_SIGNING_KEY="your_next_signing_key_here"
# For cloud, this should be your public domain (e.g., https://yourapp.vercel.app)
CLOUD_WORKFLOW_URL="https://yourapp.vercel.app"

# === SHARED CONFIGURATION ===
QSTASH_EVENT_METADATA="full"
NODE_ENV="development"
UPSTASH_DISABLE_TELEMETRY="true"