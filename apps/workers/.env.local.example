# Example environment variables for local development
# Copy this to .env.local and update with your values

# Required for local development
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3400

# QStash Local Development (from QStash CLI output)
QSTASH_URL=http://localhost:8080
QSTASH_TOKEN=eyJVc2VySUQiOiJkZWZhdWx0VXNlciIsIlBhc3N3b3JkIjoiZGVmYXVsdFBhc3N3b3JkIn0=
QSTASH_CURRENT_SIGNING_KEY=sig_7kYjw48mhY7kAjqNGcy6cr29RJ6r
QSTASH_NEXT_SIGNING_KEY=sig_5ZB6DVzB1wjE8S6rZ7eenA8Pdnhs
QSTASH_EVENT_METADATA=full
UPSTASH_WORKFLOW_URL=http://localhost:3400

# Workflow Development Settings
WORKFLOW_DEV_MODE=true
SKIP_WORKFLOW_DEDUPLICATION=true

# Database (required - get from Doppler or use local PostgreSQL)
DATABASE_URL=postgresql://user:password@localhost:5432/workers_dev

# Auth (required - generate with: openssl rand -base64 44)
BETTER_AUTH_SECRET=your-secret-here
FLAGS_SECRET=your-flags-secret-here

# Optional services (can leave empty for local dev)
ARCJET_KEY=""
BETTERSTACK_API_KEY=""
BETTERSTACK_URL=""
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""

# Email (optional for local dev)
RESEND_FROM=noreply@localhost
RESEND_TOKEN=""

# Analytics (optional for local dev)
NEXT_PUBLIC_POSTHOG_HOST=""
NEXT_PUBLIC_POSTHOG_KEY=""

# Redis (optional - for rate limiting)
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# Service API Key (for internal API calls)
SERVICE_API_KEY=your-secure-api-key-here-for-workers-app