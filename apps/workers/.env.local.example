# QStash Configuration for Local Development
# These are the required settings for local development with QStash CLI
QSTASH_URL=http://localhost:8080
QSTASH_TOKEN=local_qstash_token

# Tell Upstash Workflow SDK to use your local Next.js app
# This should match your Next.js dev server URL
UPSTASH_WORKFLOW_URL=http://localhost:3800

# Optional: Redis for State Management
# Get these from https://console.upstash.com/redis
# UPSTASH_REDIS_REST_URL=https://xxx.upstash.io
# UPSTASH_REDIS_REST_TOKEN=AXXXASQgxxxxx

# Production Configuration (when deploying)
# Remove QSTASH_URL and UPSTASH_WORKFLOW_URL in production
# Set these in your deployment platform (Vercel, etc.):
# QSTASH_TOKEN=qstash_xxxxxx
# QSTASH_CURRENT_SIGNING_KEY=sig_xxxxxx
# QSTASH_NEXT_SIGNING_KEY=sig_xxxxxx

BETTER_AUTH_SECRET=your-secret-here
DATABASE_URL=postgresql://user:password@localhost:5432/dbname