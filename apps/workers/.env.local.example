# Workers App Environment Variables Example

# Service API Key for service-to-service authentication
# Generate a secure key: openssl rand -base64 32
SERVICE_API_KEY=your-32-character-minimum-service-api-key-here

# QStash Configuration
QSTASH_TOKEN=your-qstash-token
QSTASH_URL=https://qstash.upstash.io
QSTASH_CURRENT_SIGNING_KEY=your-signing-key
QSTASH_NEXT_SIGNING_KEY=your-next-signing-key

# Upstash Redis
UPSTASH_REDIS_REST_URL=https://your-redis-url.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-redis-token

# Optional: Workflow URL
UPSTASH_WORKFLOW_URL=https://your-workflow-url

# Optional: Development flags
SKIP_WORKFLOW_DEDUPLICATION=false
WORKFLOW_DEV_MODE=false

# Copy shared .env.local from root if using shared auth/database
# Or set individual values as needed