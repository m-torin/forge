# QStash Configuration
QSTASH_URL=http://localhost:8080
QSTASH_TOKEN=your_qstash_token_here
QSTASH_CURRENT_SIGNING_KEY=your_signing_key_here
QSTASH_NEXT_SIGNING_KEY=your_next_signing_key_here

# Optional: Skip deduplication in development for easier testing
# SKIP_WORKFLOW_DEDUPLICATION=true

# Optional: Workflow failure webhook URL
# ORDER_FAILURE_WEBHOOK_URL=https://your-webhook-url.com/failures

# Stripe (for payment simulation in event workflow)
# STRIPE_KEY=sk_test_your_stripe_key