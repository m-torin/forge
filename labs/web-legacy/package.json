{
  "name": "web-legacy",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --port 3200",
    "build": "next build",
    "build:local": "next build",
    "predev": "pnpm --filter=@repo/database build",
    "prebuild": "pnpm --filter=@repo/database build",
    "start": "next start --port 3200",
    "lint": "eslint . --fix",
    "lint:check": "eslint .",
    "typecheck": "tsc --noEmit --emitDeclarationOnly false",
    "knip": "knip",
    "test": "vitest --run",
    "test:watch": "vitest",
    "test:coverage": "vitest --coverage --run",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:basic": "playwright test e2e/app.spec.ts e2e/navigation.spec.ts",
    "dev:e2e": "concurrently --kill-others --success first \"npm:dev\" \"npm:dev:e2e:wait\"",
    "dev:e2e:wait": "wait-on http://localhost:3200 && npm run test:e2e"
  },
  "dependencies": {
    "@algolia/autocomplete-core": "^1.19.2",
    "@algolia/autocomplete-js": "^1.19.2",
    "@algolia/autocomplete-theme-classic": "^1.19.2",
    "@algolia/cache-in-memory": "^4.25.0",
    "@algolia/client-search": "^5.29.0",
    "@heroicons/react": "^2.2.0",
    "@mantine/carousel": "^8.1.1",
    "@mantine/core": "^8.1.1",
    "@mantine/dates": "^8.1.1",
    "@mantine/form": "^8.1.1",
    "@mantine/hooks": "^8.1.1",
    "@mantine/notifications": "^8.1.1",
    "@repo/analytics": "workspace:*",
    "@repo/auth": "workspace:*",
    "@repo/config": "workspace:*",
    "@repo/database": "workspace:*",
    "@repo/internationalization": "workspace:*",
    "@repo/security": "workspace:*",
    "@repo/seo": "workspace:*",
    "@repo/storage": "workspace:*",
    "@segment/analytics-core": "^1.8.1",
    "@t3-oss/env-nextjs": "^0.13.8",
    "@tabler/icons-react": "^3.34.0",
    "@vercel/edge-config": "^1.4.0",
    "@vercel/toolbar": "^0.1.37",
    "algoliasearch": "^5.29.0",
    "clsx": "2.1.1",
    "date-fns": "^4.1.0",
    "embla-carousel-autoplay": "^8.6.0",
    "framer-motion": "^12.18.1",
    "mantine-form-zod-resolver": "^1.3.0",
    "next": "15.4.0-canary.88",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-hooks-global-state": "^2.1.0",
    "react-instantsearch": "^7.16.0",
    "react-instantsearch-nextjs": "^0.5.0",
    "react-swipeable": "^7.0.2",
    "schema-dts": "^1.1.5",
    "tailwind-preset-mantine": "^2.1.0",
    "zod": "^3.25.67"
  },
  "devDependencies": {
    "@playwright/test": "^1.53.1",
    "@repo/eslint-config": "workspace:*",
    "@repo/testing": "workspace:*",
    "@tailwindcss/postcss": "^4.1.10",
    "@types/node": "^24.0.3",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "concurrently": "^9.1.2",
    "eslint": "^9.29.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.1.10",
    "typescript": "5.8.3",
    "wait-on": "^8.0.3"
  }
}
