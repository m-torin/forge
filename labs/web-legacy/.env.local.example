# Security Configuration (Optional)
# Get your Arcjet key from https://app.arcjet.com
ARCJET_KEY=ajkey_your_key_here

# Vercel Edge Config
# Get this from your Vercel dashboard after creating an Edge Config
# https://vercel.com/docs/storage/edge-config
EDGE_CONFIG=

# Example Edge Config content:
# {
#   "isInMaintenanceMode": false
# }

# Upstash Redis for Rate Limiting (Optional)
# Get your credentials from https://console.upstash.com
UPSTASH_REDIS_REST_URL=https://your-redis-url.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_redis_token_here

# Analytics Configuration (Optional)
# By default, analytics logs to console in development
# Add these for production analytics providers:

# Segment Analytics
# Get your write key from https://app.segment.com
# NEXT_PUBLIC_SEGMENT_WRITE_KEY=your_segment_write_key_here

# PostHog Analytics
# Get your API key from https://app.posthog.com
# NEXT_PUBLIC_POSTHOG_API_KEY=phc_your_posthog_key_here
# NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# Vercel Analytics (auto-configured when deployed to Vercel)
# No configuration needed

# Note: The analytics package works without these environment variables.
# When not configured:
# - Console logging is used in development
# - Page tracking still works and logs to console
# This allows for easy development without external services.