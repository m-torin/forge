    "@types/negotiator": "^0.6.3",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@vitejs/plugin-react": "^4.5.0",
    "@vitest/coverage-v8": "catalog:",
