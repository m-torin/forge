{
  "extends": "@repo/typescript-config/base.json",
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "bundler",
    "target": "ES2022",
    "lib": ["ES2022"],
    "outDir": "dist",
    "skipLibCheck": true,
    "allowImportingTsExtensions": false
  },
  "include": ["**/*.ts", "**/*.tsx", "**/*.mts", "**/*.d.ts", "*.d.ts", "README.md", "index.d.ts"],
  "exclude": ["node_modules", "dist"]
}
