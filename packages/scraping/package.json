{
  "name": "@repo/scraping",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./puppeteer": {
      "types": "./src/puppeteer/index.ts",
      "default": "./src/puppeteer/index.ts"
    },
    "./playwright": {
      "types": "./src/playwright/index.ts",
      "default": "./src/playwright/index.ts"
    }
  },
  "scripts": {
    "lint": "eslint . --fix",
    "typecheck": "tsc --noEmit --emitDeclarationOnly false",
    "test": "vitest --run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage --run"
  },
  "dependencies": {
    "zod": "catalog:"
  },
  "devDependencies": {
    "@repo/eslint-config": "workspace:*",
    "@repo/testing": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "@types/node": "catalog:",
    "eslint": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "peerDependencies": {
    "playwright": "^1.40.0",
    "puppeteer": "^21.0.0"
  },
  "peerDependenciesMeta": {
    "playwright": {
      "optional": true
    },
    "puppeteer": {
      "optional": true
    }
  }
}
