{
  "extends": "@repo/typescript-config/nextjs.json",
  "compilerOptions": {
    "baseUrl": ".",
    "allowImportingTsExtensions": true,
    "skipLibCheck": true,
    "noImplicitAny": false,
    "typeRoots": ["./node_modules/@types", "./types"],
    "paths": {
      "eslint": ["./types/eslint.d.ts"],
      "eslint-plugin-node": ["./types/eslint-plugin-node.d.ts"]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    "**/*.js",
    "**/*.jsx",
    "vitest.d.ts",
    "cypress.d.ts"
  ],
  "exclude": ["node_modules"]
}
