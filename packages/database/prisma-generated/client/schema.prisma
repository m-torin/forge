// guestActions.prisma - Guest and User Action Models (Favorites, Reviews, Votes)

//==============================================================================
// GUEST ACTIONS MODELS
//==============================================================================

model Review {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Soft delete
  deletedAt   DateTime?
  deletedById String?
  deletedBy   User?     @relation("DeletedReviews", fields: [deletedById], references: [id], onDelete: SetNull)

  // Review content
  title   String?
  content String  @db.Text
  rating  Int // Rating (typically 1-5)

  // Metadata
  status   ContentStatus @default(PUBLISHED)
  verified Boolean       @default(false)
  type     ReviewType    @default(DEDICATED)

  // Source information for imported reviews
  sourceId String? // ID from the original source
  source   String? // Name of the source (e.g., "Amazon", "Google")

  // Helpfulness tracking
  helpfulCount Int @default(0)
  totalVotes   Int @default(0)

  // Relationships
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  productId String?
  product   Product? @relation("ProductReviews", fields: [productId], references: [id], onDelete: SetNull)

  // Media attachments
  media Media[] @relation("ReviewMedia")

  // Votes
  votes ReviewVoteJoin[]

  @@index([userId])
  @@index([productId])
  @@index([rating])
  @@index([status])
  @@index([verified])
  @@index([type])
  @@index([source])
  @@index([helpfulCount])
  @@index([totalVotes])
  @@index([deletedAt])
  @@index([deletedById])
}

//==============================================================================
// JUNCTION MODELS
//==============================================================================

model FavoriteJoin {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // User relationship
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Item relationships (only one should be set)
  productId String?
  product   Product? @relation("ProductFavorites", fields: [productId], references: [id], onDelete: SetNull)

  collectionId String?
  collection   Collection? @relation(fields: [collectionId], references: [id], onDelete: SetNull)

  @@unique([userId, productId, collectionId])
  @@index([userId])
  @@index([productId])
  @@index([collectionId])
}

model ReviewVoteJoin {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Vote information
  voteType VoteType // Whether the user found the review helpful or not

  // Relationships
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  reviewId String
  review   Review @relation(fields: [reviewId], references: [id], onDelete: Cascade)

  @@unique([userId, reviewId])
  @@index([userId])
  @@index([reviewId])
  @@index([voteType])
}

// orders.prisma - Order Management, Cart, and Inventory Models

//==============================================================================
// ADDRESS MODELS
//==============================================================================

model Address {
  id     String  @id @default(cuid())
  userId String?
  user   User?   @relation(fields: [userId], references: [id], onDelete: Cascade)

  type      AddressType @default(SHIPPING)
  isDefault Boolean     @default(false)

  firstName String
  lastName  String
  company   String?
  phone     String?

  street1    String
  street2    String?
  city       String
  state      String
  postalCode String
  country    String  @default("US")

  // Validation flags
  isValidated Boolean   @default(false)
  validatedAt DateTime?

  // Relations
  orderShippingAddresses Order[] @relation("ShippingAddress")
  orderBillingAddresses  Order[] @relation("BillingAddress")

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([userId])
  @@index([type])
}

//==============================================================================
// CART MODELS
//==============================================================================

model Cart {
  id        String  @id @default(cuid())
  userId    String?
  user      User?   @relation(fields: [userId], references: [id], onDelete: Cascade)
  sessionId String? // For guest carts

  status    CartStatus @default(ACTIVE)
  expiresAt DateTime? // For abandoned cart cleanup

  // Cart metadata
  currency String  @default("USD")
  notes    String?
  metadata Json?

  // Relations
  items CartItem[]

  // Analytics
  abandonedAt DateTime?
  recoveredAt DateTime?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@unique([userId])
  @@index([sessionId])
  @@index([status])
  @@index([expiresAt])
}

model CartItem {
  id     String @id @default(cuid())
  cartId String
  cart   Cart   @relation(fields: [cartId], references: [id], onDelete: Cascade)

  productId String?
  product   Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
  variantId String?
  variant   Product? @relation("CartItemVariant", fields: [variantId], references: [id], onDelete: SetNull)

  quantity Int
  price    Decimal @db.Decimal(10, 2)

  // Gift/Registry info
  isGift      Boolean   @default(false)
  giftMessage String?
  registryId  String?
  registry    Registry? @relation(fields: [registryId], references: [id])

  // Saved for later
  savedForLater Boolean @default(false)

  metadata Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([cartId, productId, variantId])
  @@index([productId])
  @@index([variantId])
}

//==============================================================================
// ORDER MODELS
//==============================================================================

model Order {
  id          String  @id @default(cuid())
  orderNumber String  @unique
  userId      String?
  user        User?   @relation(fields: [userId], references: [id])

  // Guest order info
  guestEmail String?
  guestName  String?

  status OrderStatus @default(PENDING)

  // Addresses
  shippingAddressId String?
  shippingAddress   Address? @relation("ShippingAddress", fields: [shippingAddressId], references: [id])
  billingAddressId  String?
  billingAddress    Address? @relation("BillingAddress", fields: [billingAddressId], references: [id])

  // Pricing
  currency       String  @default("USD")
  subtotal       Decimal @db.Decimal(10, 2)
  taxAmount      Decimal @db.Decimal(10, 2)
  shippingAmount Decimal @db.Decimal(10, 2)
  discountAmount Decimal @default(0) @db.Decimal(10, 2)
  total          Decimal @db.Decimal(10, 2)

  // Shipping
  shippingMethod String?
  trackingNumber String?
  shippedAt      DateTime?
  deliveredAt    DateTime?

  // Payment
  paymentStatus PaymentStatus @default(PENDING)
  paymentMethod String?

  // Relations
  items        OrderItem[]
  transactions Transaction[]

  // Customer info
  customerNotes String?
  internalNotes String?

  metadata Json?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([userId])
  @@index([orderNumber])
  @@index([status])
  @@index([paymentStatus])
  @@index([createdAt])
}

model OrderItem {
  id      String @id @default(cuid())
  orderId String
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  productId String?
  product   Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
  variantId String?
  variant   Product? @relation("OrderItemVariant", fields: [variantId], references: [id], onDelete: SetNull)

  // Snapshot data at time of order
  productName String
  variantName String?
  sku         String?

  quantity Int
  price    Decimal @db.Decimal(10, 2)
  total    Decimal @db.Decimal(10, 2)

  // Gift/Registry info
  isGift      Boolean   @default(false)
  giftMessage String?
  registryId  String?
  registry    Registry? @relation(fields: [registryId], references: [id])

  // Fulfillment
  status      OrderItemStatus @default(PENDING)
  fulfilledAt DateTime?

  metadata Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([productId])
  @@index([variantId])
  @@index([status])
}

//==============================================================================
// TRANSACTION MODELS
//==============================================================================

model Transaction {
  id      String @id @default(cuid())
  orderId String
  order   Order  @relation(fields: [orderId], references: [id])

  type   TransactionType
  status TransactionStatus @default(PENDING)

  amount   Decimal @db.Decimal(10, 2)
  currency String  @default("USD")

  // Payment gateway info
  gateway         String // stripe, paypal, etc
  gatewayId       String? // External transaction ID
  gatewayResponse Json?

  // Card info (last 4 digits only)
  paymentMethod String?
  last4         String?

  // For refunds
  parentTransactionId String?
  parentTransaction   Transaction?  @relation("RefundTransaction", fields: [parentTransactionId], references: [id])
  refunds             Transaction[] @relation("RefundTransaction")

  metadata Json?

  processedAt   DateTime?
  failedAt      DateTime?
  failureReason String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([orderId])
  @@index([gateway])
  @@index([gatewayId])
  @@index([status])
}

//==============================================================================
// INVENTORY MODELS
//==============================================================================

model Inventory {
  id        String   @id @default(cuid())
  productId String?
  product   Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
  variantId String?
  variant   Product? @relation("InventoryVariant", fields: [variantId], references: [id], onDelete: SetNull)

  // Stock levels
  quantity  Int @default(0)
  reserved  Int @default(0) // Reserved for pending orders
  available Int @default(0) // quantity - reserved

  // Thresholds
  lowStockThreshold Int?

  // Location (for multi-warehouse)
  locationId   String?
  locationName String?

  // Tracking
  lastRestockedAt DateTime?

  // Relations
  transactions InventoryTransaction[]

  metadata Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([productId, variantId, locationId])
  @@index([available])
  @@index([locationId])
}

model InventoryTransaction {
  id          String    @id @default(cuid())
  inventoryId String
  inventory   Inventory @relation(fields: [inventoryId], references: [id])

  type     InventoryTransactionType
  quantity Int // Positive for additions, negative for removals

  // Reference to order/return/adjustment
  referenceType String?
  referenceId   String?

  notes String?

  createdAt DateTime @default(now())
  createdBy String?

  @@index([inventoryId])
  @@index([referenceType, referenceId])
}

// registry.prisma - Registry and Wishlist Models

//==============================================================================
// REGISTRY MODELS
//==============================================================================

model Registry {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Soft delete
  deletedAt   DateTime?
  deletedById String?
  deletedBy   User?     @relation("DeletedRegistries", fields: [deletedById], references: [id], onDelete: SetNull)

  // Basic information
  title       String
  description String?
  type        RegistryType @default(WISHLIST)
  isPublic    Boolean      @default(false)

  // Event information (for gift registries)
  eventDate DateTime?

  // Creator tracking (optional)
  createdByUserId String?
  createdByUser   User?   @relation("CreatedRegistries", fields: [createdByUserId], references: [id], onDelete: SetNull)

  // Items in the registry
  items RegistryItem[]

  // User access
  users RegistryUserJoin[]

  // Cart and Order relations
  cartItems  CartItem[]
  orderItems OrderItem[]

  @@index([createdByUserId])
  @@index([type])
  @@index([isPublic])
  @@index([eventDate])
  @@index([deletedAt])
  @@index([deletedById])
}

model RegistryItem {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Soft delete
  deletedAt   DateTime?
  deletedById String?
  deletedBy   User?     @relation("DeletedRegistryItems", fields: [deletedById], references: [id], onDelete: SetNull)

  // Item metadata
  quantity  Int     @default(1)
  priority  Int     @default(0)
  notes     String?
  purchased Boolean @default(false)

  // Registry relationship
  registryId String
  registry   Registry @relation(fields: [registryId], references: [id], onDelete: Cascade)

  // Item relationships (only one should be set)
  productId String?
  product   Product? @relation("RegistryProduct", fields: [productId], references: [id], onDelete: SetNull)

  collectionId String?
  collection   Collection? @relation(fields: [collectionId], references: [id], onDelete: SetNull)

  // Purchases
  purchases RegistryPurchaseJoin[]

  @@unique([registryId, productId, collectionId])
  @@index([registryId])
  @@index([productId])
  @@index([collectionId])
  @@index([purchased])
  @@index([priority])
  @@index([deletedAt])
  @@index([deletedById])
}

model RegistryPurchaseJoin {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Purchase metadata
  purchaseDate DateTime       @default(now())
  quantity     Int            @default(1)
  status       PurchaseStatus @default(PENDING)

  // Transaction information
  transactionId String? // External transaction ID
  orderNumber   String? // Order number for reference
  price         Float? // Price at time of purchase
  currency      String? // Currency code (e.g., USD, EUR)

  // Shipping information
  trackingNumber    String?
  trackingUrl       String?
  estimatedDelivery DateTime?
  actualDelivery    DateTime?

  // Gift information
  isGift      Boolean @default(false)
  giftMessage String? @db.Text
  giftWrapped Boolean @default(false)

  // Thank you tracking
  thankYouSent    Boolean   @default(false)
  thankYouSentAt  DateTime?
  thankYouMessage String?   @db.Text

  // Notes
  notes String?

  // Purchaser relationship
  purchaserId String
  purchaser   User   @relation("UserPurchases", fields: [purchaserId], references: [id], onDelete: Cascade)

  // Registry item relationship
  registryItemId String
  registryItem   RegistryItem @relation(fields: [registryItemId], references: [id], onDelete: Cascade)

  // Notification status
  notifiedOwner Boolean   @default(false)
  notifiedDate  DateTime?

  @@index([purchaserId])
  @@index([registryItemId])
  @@index([status])
  @@index([purchaseDate])
  @@index([transactionId])
  @@index([orderNumber])
  @@index([isGift])
  @@index([notifiedOwner])
  @@index([thankYouSent])
}

model RegistryUserJoin {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Role information
  role RegistryUserRole @default(VIEWER)

  // Relationships
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  registryId String
  registry   Registry @relation(fields: [registryId], references: [id], onDelete: Cascade)

  @@unique([userId, registryId])
  @@index([userId])
  @@index([registryId])
  @@index([role])
}

// workflows.prisma - Workflow Management Models

//==============================================================================
// WORKFLOW MANAGEMENT MODELS
//==============================================================================

model WorkflowConfig {
  id             String  @id @default(cuid())
  workflowSlug   String // References the dynamically registered workflow
  organizationId String? // If set, applies to entire organization
  userId         String? // If set, applies to specific user

  // Enable/disable workflow
  isEnabled Boolean @default(true)

  // Optional overrides
  displayName String?
  description String?
  category    String?
  tags        String[]

  // Notification settings
  notifyOnStart     Boolean @default(false)
  notifyOnComplete  Boolean @default(false)
  notifyOnFailure   Boolean @default(true)
  notifyOnApproval  Boolean @default(false)
  notificationEmail String?

  // Execution limits
  maxRetries       Int?
  timeoutSeconds   Int?
  rateLimitPerHour Int?

  // Resource limits
  maxConcurrent Int?
  priority      Int? @default(5) @db.SmallInt

  // Custom configuration
  customPayload Json?
  metadata      Json?

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  createdBy String?

  // Relations
  schedules WorkflowSchedule[]

  @@unique([workflowSlug, organizationId])
  @@unique([workflowSlug, userId])
  @@index([workflowSlug])
  @@index([organizationId])
  @@index([userId])
  @@index([isEnabled])
  @@map("workflow_config")
}

model WorkflowExecution {
  id             String  @id @default(cuid())
  workflowRunId  String  @unique
  workflowSlug   String
  userId         String?
  organizationId String?

  // Execution details
  status      String // pending, running, completed, failed, cancelled
  startedAt   DateTime  @default(now())
  completedAt DateTime?
  duration    Int? // milliseconds

  // Payload and results
  inputPayloadHash String?
  hasOutput        Boolean @default(false)
  error            String? @db.Text
  errorType        String?

  // Metrics
  stepCount      Int @default(0)
  completedSteps Int @default(0)
  retryCount     Int @default(0)

  // Trigger information
  triggeredBy       String // api, schedule, webhook, manual, chained
  triggerSource     String?
  parentExecutionId String?

  // Cost tracking
  creditsUsed  Int @default(0)
  apiCallCount Int @default(0)

  // Metadata
  tags      String[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([workflowSlug])
  @@index([workflowSlug, status, startedAt])
  @@index([userId])
  @@index([organizationId])
  @@index([organizationId, status, startedAt])
  @@index([status])
  @@index([startedAt])
  @@index([triggeredBy])
  @@map("workflow_execution")
}

model WorkflowSchedule {
  id       String @id @default(cuid())
  configId String

  // Schedule configuration
  name           String
  description    String?
  cronExpression String
  timezone       String  @default("UTC")
  isActive       Boolean @default(true)

  // Execution settings
  payload Json

  // Schedule metadata
  nextRunAt      DateTime?
  lastRunAt      DateTime?
  lastRunStatus  String?
  totalRuns      Int       @default(0)
  successfulRuns Int       @default(0)
  failedRuns     Int       @default(0)

  // Validity period
  validFrom  DateTime  @default(now())
  validUntil DateTime?

  // Metadata
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  createdBy String?

  // Relations
  config WorkflowConfig @relation(fields: [configId], references: [id], onDelete: Cascade)

  @@index([configId])
  @@index([isActive])
  @@index([nextRunAt])
  @@map("workflow_schedule")
}
