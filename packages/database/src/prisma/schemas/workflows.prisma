// workflows.prisma - Workflow Management Models

//==============================================================================
// WORKFLOW MANAGEMENT MODELS
//==============================================================================

model WorkflowConfig {
  id             String  @id @default(cuid())
  workflowSlug   String // References the dynamically registered workflow
  organizationId String? // If set, applies to entire organization
  userId         String? // If set, applies to specific user

  // Enable/disable workflow
  isEnabled Boolean @default(true)

  // Optional overrides
  displayName String?
  description String?
  category    String?
  tags        String[]

  // Notification settings
  notifyOnStart     Boolean @default(false)
  notifyOnComplete  Boolean @default(false)
  notifyOnFailure   Boolean @default(true)
  notifyOnApproval  Boolean @default(false)
  notificationEmail String?

  // Execution limits
  maxRetries       Int?
  timeoutSeconds   Int?
  rateLimitPerHour Int?

  // Resource limits
  maxConcurrent Int?
  priority      Int? @default(5) @db.SmallInt

  // Custom configuration
  customPayload Json? @db.JsonB
  metadata      Json? @db.JsonB

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  createdBy String?

  // Relations
  schedules WorkflowSchedule[]

  @@unique([workflowSlug, organizationId])
  @@unique([workflowSlug, userId])
  @@index([workflowSlug])
  @@index([organizationId])
  @@index([userId])
  @@map("workflow_config")
}

model WorkflowExecution {
  id             String  @id @default(cuid())
  workflowRunId  String  @unique
  workflowSlug   String
  userId         String?
  organizationId String?

  // Execution details
  status      String // pending, running, completed, failed, cancelled, retrying, scheduled
  startedAt   DateTime  @default(now())
  completedAt DateTime?
  duration    Int? // milliseconds

  // Payload and results
  inputPayload     Json? @db.JsonB
  inputPayloadHash String?
  outputPayload    Json? @db.JsonB
  hasOutput        Boolean @default(false)
  error            String? @db.Text
  errorType        String?
  errorStack       String? @db.Text

  // V3 Enhanced Metrics
  stepCount      Int @default(0)
  completedSteps Int @default(0)
  failedSteps    Int @default(0)
  retryCount     Int @default(0)
  maxRetries     Int @default(3)

  // V3 Progress Tracking
  currentStep     String?
  progressPercent Int     @default(0)
  progressMessage String?

  // V3 Quality and Cost Tracking
  qualityScore   Float?
  totalCostCents Int    @default(0)
  creditsUsed    Int    @default(0)
  apiCallCount   Int    @default(0)

  // V3 Service Usage Tracking
  emailsSent      Int    @default(0)
  imagesProcessed Int    @default(0)
  aiTokensUsed    Int    @default(0)
  storageBytes    BigInt @default(0)

  // Trigger information
  triggeredBy        String // api, schedule, webhook, manual, chained, retry
  triggerSource      String?
  parentExecutionId  String?
  retryOfExecutionId String?

  // V3 Scheduling
  scheduledFor  DateTime?
  actualStartAt DateTime?

  // Metadata
  tags      String[]
  metadata  Json? @db.JsonB
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  checkpoints       WorkflowCheckpoint[]
  metrics           WorkflowMetrics?
  serviceUsage      WorkflowServiceUsage[]
  alerts            WorkflowAlert[]
  retries           WorkflowExecution[]    @relation("WorkflowRetries")
  originalExecution WorkflowExecution?     @relation("WorkflowRetries", fields: [retryOfExecutionId], references: [id])

  @@index([workflowSlug])
  @@index([userId])
  @@index([organizationId])
  @@index([organizationId, status, startedAt])
  @@index([startedAt])
  @@index([retryOfExecutionId])
  @@index([scheduledFor])
  @@index([userId, status]) // For user's workflow executions by status
  @@index([workflowSlug, status, startedAt], map: "idx_workflow_execution_monitoring") // For workflow monitoring
  @@map("workflow_execution")
}

model WorkflowSchedule {
  id       String @id @default(cuid())
  configId String

  // Schedule configuration
  name           String
  description    String?
  cronExpression String
  timezone       String  @default("UTC")
  isActive       Boolean @default(true)

  // Execution settings
  payload Json @db.JsonB

  // Schedule metadata
  nextRunAt      DateTime?
  lastRunAt      DateTime?
  lastRunStatus  String?
  totalRuns      Int       @default(0)
  successfulRuns Int       @default(0)
  failedRuns     Int       @default(0)

  // Validity period
  validFrom  DateTime  @default(now())
  validUntil DateTime?

  // Metadata
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  createdBy String?

  // Relations
  config WorkflowConfig @relation(fields: [configId], references: [id], onDelete: Cascade)

  @@index([configId])
  @@index([nextRunAt])
  @@map("workflow_schedule")
}

//==============================================================================
// V3 WORKFLOW ENHANCEMENTS
//==============================================================================

model WorkflowCheckpoint {
  id           String @id @default(cuid())
  executionId  String
  workflowSlug String

  // Checkpoint identification
  checkpointName String
  stepId         String
  stepName       String?

  // State data
  state    Json @db.JsonB
  progress Json? @db.JsonB
  metadata Json? @db.JsonB

  // Checkpoint details
  createdAt  DateTime  @default(now())
  isRestored Boolean   @default(false)
  restoredAt DateTime?

  // Size tracking
  stateSizeBytes Int?

  // Relations
  execution WorkflowExecution @relation(fields: [executionId], references: [id], onDelete: Cascade)

  @@unique([executionId, checkpointName])
  @@index([executionId])
  @@index([workflowSlug])
  @@index([stepId])
  @@map("workflow_checkpoint")
}

model WorkflowMetrics {
  id           String @id @default(cuid())
  executionId  String @unique
  workflowSlug String

  // Performance metrics
  totalDuration     Int // milliseconds
  setupDuration     Int @default(0)
  executionDuration Int @default(0)
  cleanupDuration   Int @default(0)

  // Step metrics
  stepsPlanned   Int @default(0)
  stepsExecuted  Int @default(0)
  stepsSucceeded Int @default(0)
  stepsFailed    Int @default(0)
  stepsSkipped   Int @default(0)
  stepsRetried   Int @default(0)

  // Resource usage
  memoryUsageMB        Int?
  cpuUsagePercent      Float?
  networkBytesSent     BigInt @default(0)
  networkBytesReceived BigInt @default(0)

  // External service calls
  databaseQueries  Int @default(0)
  apiCallsExternal Int @default(0)
  fileOperations   Int @default(0)
  aiTokensUsed     Int @default(0)

  // Quality metrics
  dataQualityScore    Float?
  performanceScore    Float?
  reliabilityScore    Float?
  overallQualityScore Float?

  // Cost breakdown (in cents)
  computeCostCents     Int @default(0)
  storageCostCents     Int @default(0)
  networkCostCents     Int @default(0)
  externalApiCostCents Int @default(0)
  totalCostCents       Int @default(0)

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  execution WorkflowExecution @relation(fields: [executionId], references: [id], onDelete: Cascade)

  @@index([workflowSlug])
  @@map("workflow_metrics")
}

model WorkflowServiceUsage {
  id           String @id @default(cuid())
  executionId  String
  workflowSlug String

  // Service identification
  serviceName String // email, storage, ai, database, external_api
  serviceType String // resend, cloudflare_r2, lmstudio, postgres, jolly_roger
  operation   String // send_email, upload_file, generate_text, query, scrape

  // Usage metrics
  operationCount Int     @default(1)
  bytesProcessed BigInt?
  tokensUsed     Int?
  durationMs     Int?

  // Cost tracking (in cents)
  costCents Int @default(0)

  // Request/Response details
  requestData  Json? @db.JsonB
  responseData Json? @db.JsonB
  errorMessage String?

  // Timestamps
  startedAt   DateTime  @default(now())
  completedAt DateTime?

  // Relations
  execution WorkflowExecution @relation(fields: [executionId], references: [id], onDelete: Cascade)

  @@index([executionId])
  @@index([workflowSlug])
  @@index([startedAt])
  @@map("workflow_service_usage")
}

model WorkflowAlert {
  id           String  @id @default(cuid())
  workflowSlug String
  executionId  String?

  // Alert details
  alertType   String // failure, timeout, cost_exceeded, quality_low, retry_exhausted
  severity    String // info, warning, error, critical
  title       String
  description String @db.Text

  // Alert conditions
  threshold   Json? @db.JsonB
  actualValue Json? @db.JsonB

  // Alert status
  status         String    @default("active") // active, acknowledged, resolved
  acknowledgedAt DateTime?
  acknowledgedBy String?
  resolvedAt     DateTime?
  resolvedBy     String?

  // Notification tracking
  notificationsSent Int       @default(0)
  lastNotifiedAt    DateTime?

  // Metadata
  tags      String[]
  metadata  Json? @db.JsonB
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  execution WorkflowExecution? @relation(fields: [executionId], references: [id], onDelete: Cascade)

  @@index([workflowSlug])
  @@index([executionId])
  @@map("workflow_alert")
}
