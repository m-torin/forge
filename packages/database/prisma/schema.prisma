// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider        = "prisma-client-js"
  output          = "../generated/client"
}

datasource db {
  provider     = "postgresql"
  url          = env("DATABASE_URL")
}

// This is a stub model.
// Delete it and add your own Prisma models.

model Page {
  id   Int    @id @default(autoincrement())
  name String
}

// Product Information Management (PIM) Models
model Product {
  id            String   @id @default(cuid())
  name          String
  sku           String   @unique
  description   String?
  category      String
  status        ProductStatus @default(DRAFT)

  // Product details
  brand         String?
  price         Float?
  currency      String?  @default("USD")

  // Barcode information
  barcodes      ProductBarcode[]

  // Product attributes (flexible JSON storage)
  attributes    Json     @default("{}")

  // Metadata
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  createdBy     String?
  organizationId String?

  // AI-generated flag
  aiGenerated   Boolean  @default(false)
  aiConfidence  Float?
  aiSources     String[] @default([])

  // Relations
  digitalAssets ProductAsset[]
  scanHistory   ScanHistory[]

  @@index([sku])
  @@index([category])
  @@index([status])
  @@index([organizationId])
  @@index([aiGenerated])
  @@index([brand])
  @@map("product")
}

model ProductBarcode {
  id        String @id @default(cuid())
  productId String
  barcode   String
  type      BarcodeType
  isPrimary Boolean @default(false)

  createdAt DateTime @default(now())

  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([barcode])
  @@index([productId])
  @@index([barcode])
  @@map("product_barcode")
}

model ProductAsset {
  id          String    @id @default(cuid())
  productId   String
  type        AssetType
  url         String
  filename    String
  mimeType    String?
  size        Int?
  alt         String?
  description String?
  sortOrder   Int       @default(0)

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  product     Product   @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([type])
  @@map("product_asset")
}

model ScanHistory {
  id          String    @id @default(cuid())
  barcode     String
  type        String
  productId   String?
  userId      String?
  sessionId   String?   // Session identifier for grouping scans

  // Scan metadata
  platform    String?   // ios, android, web
  userAgent   String?
  ipAddress   String?

  // Scan results
  success     Boolean   @default(true)  // Whether scan was successful
  scannedAt   DateTime  @default(now()) // When the scan occurred

  // Additional data from scan
  rawData     String
  note        String?

  createdAt   DateTime  @default(now())

  // Relations
  product     Product?  @relation(fields: [productId], references: [id], onDelete: SetNull)
  user        User?     @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([barcode])
  @@index([productId])
  @@index([userId])
  @@index([sessionId])
  @@index([createdAt])
  @@index([scannedAt])
  @@index([success])
  @@map("scan_history")
}

// Enums
enum ProductStatus {
  DRAFT
  ACTIVE
  ARCHIVED
  DISCONTINUED
}

enum BarcodeType {
  UPC_A
  UPC_E
  EAN_13
  EAN_8
  CODE_128
  CODE_39
  QR_CODE
  PDF417
  AZTEC
  DATA_MATRIX
  ITF14
  CODABAR
  OTHER
}

enum AssetType {
  IMAGE
  VIDEO
  DOCUMENT
  MANUAL
  SPECIFICATION
  CERTIFICATE
  OTHER
}

model User {
  id            String    @id
  name          String
  email         String
  emailVerified Boolean
  image         String?
  phoneNumber   String?
  createdAt     DateTime
  updatedAt     DateTime
  role          String   @default("user")
  banned        Boolean  @default(false)
  banReason     String?
  banExpires    DateTime?
  sessions      Session[]
  accounts      Account[]
  members       Member[]
  apiKeys       ApiKey[]
  twoFactor     TwoFactor?
  passkeys      Passkey[]
  scanHistory   ScanHistory[]

  @@unique([email])
  @@index([email]) // Performance index
  @@index([role]) // Index for admin queries
  @@index([banned]) // Index for ban status queries
  @@map("user")
}

model Session {
  id                   String   @id
  expiresAt            DateTime
  token                String
  createdAt            DateTime
  updatedAt            DateTime
  ipAddress            String?
  userAgent            String?
  userId               String
  activeOrganizationId String?
  impersonatedBy       String?  // ID of the admin impersonating this session
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([token])
  @@index([userId]) // Performance index
  @@index([token]) // Performance index
  @@index([impersonatedBy]) // Index for impersonation queries
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime
  updatedAt             DateTime

  @@index([userId]) // Performance index
  @@map("account")
}

model Verification {
  id         String    @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime?
  updatedAt  DateTime?

  @@index([identifier]) // Performance index
  @@map("verification")
}

// Organization plugin tables
model Organization {
  id          String       @id
  name        String
  slug        String       @unique
  logo        String?
  metadata    Json?
  createdAt   DateTime
  updatedAt   DateTime?
  members     Member[]
  teams       Team[]
  invitations Invitation[]

  @@index([slug]) // Performance index
  @@map("organization")
}

model Member {
  id             String       @id
  userId         String
  organizationId String
  role           String
  teamId         String?
  createdAt      DateTime
  updatedAt      DateTime?
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  team           Team?        @relation(fields: [teamId], references: [id], onDelete: SetNull)

  @@unique([userId, organizationId])
  @@index([userId])
  @@index([organizationId])
  @@index([teamId])
  @@map("member")
}

model Invitation {
  id             String       @id
  email          String
  inviterId      String
  organizationId String
  role           String
  teamId         String?
  status         String
  expiresAt      DateTime
  createdAt      DateTime
  updatedAt      DateTime?
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  team           Team?        @relation(fields: [teamId], references: [id], onDelete: SetNull)

  @@index([email])
  @@index([organizationId])
  @@index([teamId])
  @@map("invitation")
}

model Team {
  id             String       @id
  name           String
  organizationId String
  createdAt      DateTime
  updatedAt      DateTime?
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  members        Member[]
  invitations    Invitation[]

  @@index([organizationId])
  @@map("team")
}

// API Key plugin tables
model ApiKey {
  id                  String    @id
  name                String    @db.VarChar(100)
  start               String?   @db.VarChar(16)
  prefix              String?   @db.VarChar(12)
  key                 String    @unique
  userId              String
  refillInterval      Int?
  refillAmount        Int?
  lastRefillAt        DateTime?
  enabled             Boolean   @default(true)
  rateLimitEnabled    Boolean   @default(true)
  rateLimitTimeWindow Int?
  rateLimitMax        Int?
  requestCount        Int       @default(0)
  remaining           Int?
  lastRequest         DateTime?
  expiresAt           DateTime?
  createdAt           DateTime
  updatedAt           DateTime
  permissions         String?   @db.Text
  metadata            Json?
  user                User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([enabled])
  @@index([expiresAt])
  @@map("apikey")
}

// Two-Factor Authentication plugin tables
model TwoFactor {
  id         String   @id
  userId     String   @unique
  secret     String
  enabled    Boolean  @default(false)
  verified   Boolean  @default(false)
  createdAt  DateTime
  updatedAt  DateTime
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  backupCodes BackupCode[]

  @@index([userId])
  @@map("twofactor")
}

model BackupCode {
  id         String    @id
  code       String
  userId     String
  twoFactorId String
  used       Boolean   @default(false)
  usedAt     DateTime?
  createdAt  DateTime
  twoFactor  TwoFactor @relation(fields: [twoFactorId], references: [id], onDelete: Cascade)

  @@unique([code, userId])
  @@index([userId])
  @@index([twoFactorId])
  @@map("backupcode")
}

// Passkey plugin tables
model Passkey {
  id                String   @id
  name              String?
  userId            String
  credentialId      String   @unique
  publicKey         String   @db.Text
  counter           BigInt
  deviceType        String
  backedUp          Boolean
  transports        String[] @default([])
  createdAt         DateTime
  updatedAt         DateTime
  lastUsedAt        DateTime?
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([credentialId])
  @@map("passkey")
}

// Workflow Management Models
// NOTE: Workflows are dynamically registered. Database records are only created
// when a workflow is explicitly enabled/configured by a user or organization.
// No database record = workflow uses default settings from code.

model WorkflowConfig {
  id              String   @id @default(cuid())
  workflowSlug    String   // References the dynamically registered workflow
  organizationId  String?  // If set, applies to entire organization
  userId          String?  // If set, applies to specific user

  // Enable/disable workflow (if record exists, it's enabled)
  isEnabled       Boolean  @default(true)

  // Optional overrides (null = use defaults from code)
  displayName     String?  // Custom display name
  description     String?  // Custom description
  category        String?  // Override category
  tags            String[] // Additional tags

  // Notification settings (all default to false if not specified)
  notifyOnStart   Boolean  @default(false)
  notifyOnComplete Boolean @default(false)
  notifyOnFailure Boolean  @default(true)  // Only failure notifications by default
  notifyOnApproval Boolean @default(false)
  notificationEmail String? // Override notification recipient

  // Execution limits (null = use system defaults)
  maxRetries      Int?     // Override retry count
  timeoutSeconds  Int?     // Override timeout
  rateLimitPerHour Int?    // Max executions per hour

  // Resource limits
  maxConcurrent   Int?     // Max concurrent executions
  priority        Int?     // 1-10, higher = more priority

  // Custom configuration
  customPayload   Json?    // Default payload overrides
  metadata        Json?    // Additional metadata

  // Timestamps
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  createdBy       String?

  // Relations
  schedules       WorkflowSchedule[]

  @@unique([workflowSlug, organizationId])
  @@unique([workflowSlug, userId])
  @@index([workflowSlug])
  @@index([organizationId])
  @@index([userId])
  @@index([isEnabled])
  @@map("workflow_config")
}


model WorkflowExecution {
  id                  String   @id @default(cuid())
  workflowRunId       String   @unique // QStash workflow run ID
  workflowSlug        String   // References the dynamically registered workflow
  userId              String?
  organizationId      String?

  // Execution details
  status              String   // pending, running, completed, failed, cancelled
  startedAt           DateTime @default(now())
  completedAt         DateTime?
  duration            Int?     // milliseconds

  // Payload and results (stored in Firestore for details, this is summary)
  inputPayloadHash    String?  // Hash of input for deduplication
  hasOutput           Boolean  @default(false)
  error               String?  @db.Text
  errorType           String?  // timeout, validation, api_error, etc.

  // Metrics
  stepCount           Int      @default(0)
  completedSteps      Int      @default(0)
  retryCount          Int      @default(0)

  // Trigger information
  triggeredBy         String   // api, schedule, webhook, manual, chained
  triggerSource       String?  // IP address, webhook URL, etc.
  parentExecutionId   String?  // For chained workflows

  // Cost tracking
  creditsUsed         Int      @default(0)
  apiCallCount        Int      @default(0)

  // Metadata
  tags                String[]
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([workflowSlug])
  @@index([userId])
  @@index([organizationId])
  @@index([status])
  @@index([startedAt])
  @@index([triggeredBy])
  @@map("workflow_execution")
}

model WorkflowSchedule {
  id                  String   @id @default(cuid())
  configId            String   // References WorkflowConfig

  // Schedule configuration
  name                String
  description         String?
  cronExpression      String   // e.g., "0 9 * * *" for daily at 9am
  timezone            String   @default("UTC")
  isActive            Boolean  @default(true)

  // Execution settings
  payload             Json     // Payload to use for scheduled runs

  // Schedule metadata
  nextRunAt           DateTime?
  lastRunAt           DateTime?
  lastRunStatus       String?  // completed, failed, skipped
  totalRuns           Int      @default(0)
  successfulRuns      Int      @default(0)
  failedRuns          Int      @default(0)

  // Validity period
  validFrom           DateTime @default(now())
  validUntil          DateTime?

  // Metadata
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  createdBy           String?

  // Relations
  config              WorkflowConfig @relation(fields: [configId], references: [id], onDelete: Cascade)

  @@index([configId])
  @@index([isActive])
  @@index([nextRunAt])
  @@map("workflow_schedule")
}
