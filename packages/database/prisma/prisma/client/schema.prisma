// auth.prisma - Authentication and User Management Models

//==============================================================================
// USER & AUTHENTICATION MODELS
//==============================================================================

model User {
  id            String    @id
  name          String
  email         String
  emailVerified Boolean
  image         String?
  phoneNumber   String?
  createdAt     DateTime
  updatedAt     DateTime
  role          String    @default("user")
  banned        Boolean   @default(false)
  banReason     String?
  banExpires    DateTime?

  // Soft delete support
  deletedAt DateTime?

  // Author information from e-commerce schema
  bio              String?   @db.Text // Author biography text
  expertise        String[] // Areas of expertise
  isVerifiedAuthor Boolean   @default(false) // Whether this is a verified expert/author
  authorSince      DateTime? // When the user became an author

  // User preferences and settings
  preferences Json? // Flexible storage for user preferences

  // Account status
  isSuspended       Boolean @default(false) // Whether the user is currently suspended
  suspensionDetails Json? // Details about the suspension (reason, duration, etc.)

  // Authentication relationships
  sessions  Session[]
  accounts  Account[]
  members   Member[]
  apiKeys   ApiKey[]
  twoFactor TwoFactor?
  passkeys  Passkey[]

  // PIM relationships
  scanHistory ScanHistory[]

  // E-commerce relationships
  articles          Article[]
  collections       Collection[]
  media             Media[]
  favorites         FavoriteJoin[]
  reviews           Review[]
  createdRegistries Registry[]             @relation("CreatedRegistries")
  registries        RegistryUserJoin[]
  purchases         RegistryPurchaseJoin[] @relation("UserPurchases")
  reviewVotes       ReviewVoteJoin[]

  // Invitation relationships
  invitationsSent Invitation[] @relation("InvitedBy")
  teamMemberships TeamMember[] @relation("TeamMemberships")

  // Deletion relationships
  deletedArticles          Article[]         @relation("DeletedArticles")
  deletedBrands            Brand[]           @relation("DeletedBrands")
  deletedCollections       Collection[]      @relation("DeletedCollections")
  deletedProducts          Product[]         @relation("DeletedProducts")
  deletedTaxonomies        Taxonomy[]        @relation("DeletedTaxonomies")
  deletedReviews           Review[]          @relation("DeletedReviews")
  deletedRegistries        Registry[]        @relation("DeletedRegistries")
  deletedRegistryItems     RegistryItem[]    @relation("DeletedRegistryItems")
  deletedMedia             Media[]           @relation("DeletedMedia")
  deletedProductCategories ProductCategory[] @relation("DeletedProductCategories")

  @@unique([email])
  @@index([email])
  @@index([role])
  @@index([banned])
  @@index([deletedAt])
  @@index([isVerifiedAuthor])
  @@index([isSuspended])
  @@map("user")
}

model Session {
  id                   String   @id
  expiresAt            DateTime
  token                String
  createdAt            DateTime
  updatedAt            DateTime
  ipAddress            String?
  userAgent            String?
  userId               String
  activeOrganizationId String?
  impersonatedBy       String? // ID of the admin impersonating this session
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([token])
  @@index([userId])
  @@index([token])
  @@index([expiresAt])
  @@index([userId, activeOrganizationId])
  @@index([impersonatedBy])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?   @db.Text
  refreshToken          String?   @db.Text
  idToken               String?   @db.Text
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime
  updatedAt             DateTime

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String    @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime?
  updatedAt  DateTime?

  @@index([identifier])
  @@map("verification")
}

//==============================================================================
// ORGANIZATION & TEAM MODELS
//==============================================================================

model Organization {
  id          String       @id
  name        String
  slug        String       @unique
  logo        String?
  description String?
  metadata    Json?
  createdAt   DateTime
  updatedAt   DateTime?
  members     Member[]
  teams       Team[]
  invitations Invitation[]

  @@index([slug])
  @@map("organization")
}

model Member {
  id             String       @id
  userId         String
  organizationId String
  role           String
  createdAt      DateTime
  updatedAt      DateTime?
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([userId, organizationId])
  @@index([userId])
  @@index([organizationId])
  @@map("member")
}

model Team {
  id             String       @id
  name           String
  description    String?
  organizationId String
  createdAt      DateTime
  updatedAt      DateTime?
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  invitations    Invitation[]
  teamMembers    TeamMember[]

  @@index([organizationId])
  @@map("team")
}

model TeamMember {
  id        String   @id @default(cuid())
  userId    String
  teamId    String
  role      String   @default("member")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation("TeamMemberships", fields: [userId], references: [id], onDelete: Cascade)
  team      Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([userId, teamId])
  @@index([userId])
  @@index([teamId])
  @@map("team_member")
}

model Invitation {
  id             String       @id
  email          String
  invitedById    String
  organizationId String
  role           String
  teamId         String?
  status         String
  expiresAt      DateTime
  createdAt      DateTime
  updatedAt      DateTime?
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  team           Team?        @relation(fields: [teamId], references: [id], onDelete: SetNull)
  invitedBy      User         @relation("InvitedBy", fields: [invitedById], references: [id], onDelete: SetNull)

  @@index([email])
  @@index([organizationId])
  @@index([teamId])
  @@index([invitedById])
  @@map("invitation")
}

//==============================================================================
// SECURITY & API MODELS
//==============================================================================

model ApiKey {
  id                  String    @id
  name                String    @db.VarChar(100)
  start               String?   @db.VarChar(16)
  prefix              String?   @db.VarChar(12)
  key                 String    @unique
  keyHash             String? // Hash of the key for security
  userId              String
  organizationId      String?
  refillInterval      Int?
  refillAmount        Int?
  lastRefillAt        DateTime?
  lastUsedAt          DateTime?
  enabled             Boolean   @default(true)
  rateLimitEnabled    Boolean   @default(true)
  rateLimitTimeWindow Int?
  rateLimitMax        Int?
  requestCount        Int       @default(0)
  remaining           Int?
  lastRequest         DateTime?
  expiresAt           DateTime?
  createdAt           DateTime
  updatedAt           DateTime
  permissions         String?   @db.Text
  metadata            Json?
  user                User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([organizationId])
  @@index([key])
  @@index([keyHash])
  @@index([enabled])
  @@index([expiresAt])
  @@index([lastUsedAt])
  @@map("apikey")
}

model TwoFactor {
  id          String       @id
  userId      String       @unique
  secret      String       @db.Text // Consider encryption at application level
  secretHash  String? // Hash for verification without exposing secret
  enabled     Boolean      @default(false)
  verified    Boolean      @default(false)
  createdAt   DateTime
  updatedAt   DateTime
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  backupCodes BackupCode[]

  @@index([userId])
  @@map("twofactor")
}

model BackupCode {
  id          String    @id
  code        String    @db.Text // Consider encryption
  codeHash    String // Hash for verification
  userId      String
  twoFactorId String
  used        Boolean   @default(false)
  usedAt      DateTime?
  createdAt   DateTime
  twoFactor   TwoFactor @relation(fields: [twoFactorId], references: [id], onDelete: Cascade)

  @@unique([codeHash, userId])
  @@index([userId])
  @@index([twoFactorId])
  @@map("backupcode")
}

model Passkey {
  id           String    @id
  name         String?
  userId       String
  credentialId String    @unique
  publicKey    String    @db.Text
  counter      Int // Changed from BigInt for JS compatibility
  deviceType   String
  backedUp     Boolean
  transports   String[]  @default([])
  createdAt    DateTime
  updatedAt    DateTime
  lastUsedAt   DateTime?
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([credentialId])
  @@map("passkey")
}

// ecommerce.prisma - E-commerce Content Models

//==============================================================================
// E-COMMERCE CONTENT MODELS
//==============================================================================

model ProductCategory {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Soft delete
  deletedAt   DateTime?
  deletedById String?
  deletedBy   User?     @relation("DeletedProductCategories", fields: [deletedById], references: [id], onDelete: SetNull)

  // Basic information
  name   String
  slug   String        @unique
  status ContentStatus @default(PUBLISHED)

  // Content and metadata
  description String? @db.Text
  copy        Json? // Flexible storage for category copy/content

  // SEO metadata
  metaTitle       String?
  metaDescription String?
  metaKeywords    String?

  // Hierarchical relationship
  parentId String?
  parent   ProductCategory?  @relation("ProductCategoryHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children ProductCategory[] @relation("ProductCategoryHierarchy")

  // Display order within parent category
  displayOrder Int @default(0)

  // Relationships
  products    Product[]
  collections Collection[] @relation("CollectionToCategory")
  media       Media[]

  @@index([slug])
  @@index([parentId])
  @@index([status])
  @@index([displayOrder])
  @@index([deletedAt])
  @@index([deletedById])
}

model Article {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Soft delete
  deletedAt   DateTime?
  deletedById String?
  deletedBy   User?     @relation("DeletedArticles", fields: [deletedById], references: [id], onDelete: SetNull)

  // Basic information
  title   String
  slug    String        @unique
  content Json // Flexible storage for article content
  status  ContentStatus @default(DRAFT)

  // Ownership (optional)
  userId String?
  user   User?   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Relationships
  media Media[]

  @@index([slug])
  @@index([userId])
  @@index([status])
  @@index([deletedAt])
  @@index([deletedById])
}

model Brand {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Soft delete
  deletedAt   DateTime?
  deletedById String?
  deletedBy   User?     @relation("DeletedBrands", fields: [deletedById], references: [id], onDelete: SetNull)

  // Basic information
  name   String
  slug   String        @unique
  type   BrandType     @default(OTHER)
  status ContentStatus @default(DRAFT)

  // Content and metadata
  copy    Json // Flexible storage for brand copy/content
  baseUrl String? // Base URL for the brand's website

  // Hierarchical relationship
  parentId String?
  parent   Brand?  @relation("BrandHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children Brand[] @relation("BrandHierarchy")

  // Display order within parent brand
  displayOrder Int @default(0)

  // Relationships
  products    PdpJoin[]
  collections Collection[] @relation("BrandToCollection")
  media       Media[]

  @@index([slug])
  @@index([type])
  @@index([status])
  @@index([parentId])
  @@index([displayOrder])
  @@index([deletedAt])
  @@index([deletedById])
}

model Collection {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Soft delete
  deletedAt   DateTime?
  deletedById String?
  deletedBy   User?     @relation("DeletedCollections", fields: [deletedById], references: [id], onDelete: SetNull)

  // Basic information
  name   String
  slug   String         @unique
  type   CollectionType @default(OTHER)
  status ContentStatus  @default(DRAFT)

  // Content and metadata
  copy Json // Flexible storage for collection copy/content

  // Ownership (optional)
  userId String?
  user   User?   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Hierarchical structure
  parentId String?
  parent   Collection?  @relation("CollectionHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children Collection[] @relation("CollectionHierarchy")

  // Relationships
  products   Product[]         @relation("ProductToCollection")
  brands     Brand[]           @relation("BrandToCollection")
  taxonomies Taxonomy[]        @relation("CollectionToTaxonomy")
  categories ProductCategory[] @relation("CollectionToCategory")
  media      Media[]
  favorites  FavoriteJoin[]
  registries RegistryItem[]

  @@index([slug])
  @@index([type])
  @@index([userId])
  @@index([status])
  @@index([parentId])
  @@index([deletedAt])
  @@index([deletedById])
}

model Taxonomy {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Soft delete
  deletedAt   DateTime?
  deletedById String?
  deletedBy   User?     @relation("DeletedTaxonomies", fields: [deletedById], references: [id], onDelete: SetNull)

  // Basic information
  name   String
  slug   String        @unique
  type   TaxonomyType  @default(CATEGORY)
  status ContentStatus @default(DRAFT)

  // Content and metadata
  copy Json // Flexible storage for taxonomy copy/content

  // Relationships
  products    Product[]    @relation("ProductToTaxonomy")
  collections Collection[] @relation("CollectionToTaxonomy")
  media       Media[]

  @@index([slug])
  @@index([type])
  @@index([status])
  @@index([deletedAt])
  @@index([deletedById])
}

model Review {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Soft delete
  deletedAt   DateTime?
  deletedById String?
  deletedBy   User?     @relation("DeletedReviews", fields: [deletedById], references: [id], onDelete: SetNull)

  // Review content
  title   String?
  content String  @db.Text
  rating  Int // Rating (typically 1-5)

  // Metadata
  status   ContentStatus @default(PUBLISHED)
  verified Boolean       @default(false)
  type     ReviewType    @default(DEDICATED)

  // Source information for imported reviews
  sourceId String? // ID from the original source
  source   String? // Name of the source (e.g., "Amazon", "Google")

  // Helpfulness tracking
  helpfulCount Int @default(0)
  totalVotes   Int @default(0)

  // Relationships
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  productId String?
  product   Product? @relation(fields: [productId], references: [id], onDelete: SetNull)

  // Media attachments
  media Media[]

  // Votes
  votes ReviewVoteJoin[]

  @@index([userId])
  @@index([productId])
  @@index([rating])
  @@index([status])
  @@index([verified])
  @@index([type])
  @@index([source])
  @@index([helpfulCount])
  @@index([totalVotes])
  @@index([deletedAt])
  @@index([deletedById])
}

model Registry {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Soft delete
  deletedAt   DateTime?
  deletedById String?
  deletedBy   User?     @relation("DeletedRegistries", fields: [deletedById], references: [id], onDelete: SetNull)

  // Basic information
  title       String
  description String?
  type        RegistryType @default(WISHLIST)
  isPublic    Boolean      @default(false)

  // Event information (for gift registries)
  eventDate DateTime?

  // Creator tracking (optional)
  createdByUserId String?
  createdByUser   User?   @relation("CreatedRegistries", fields: [createdByUserId], references: [id], onDelete: SetNull)

  // Items in the registry
  items RegistryItem[]

  // User access
  users RegistryUserJoin[]

  @@index([createdByUserId])
  @@index([type])
  @@index([isPublic])
  @@index([eventDate])
  @@index([deletedAt])
  @@index([deletedById])
}

model RegistryItem {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Soft delete
  deletedAt   DateTime?
  deletedById String?
  deletedBy   User?     @relation("DeletedRegistryItems", fields: [deletedById], references: [id], onDelete: SetNull)

  // Item metadata
  quantity  Int     @default(1)
  priority  Int     @default(0)
  notes     String?
  purchased Boolean @default(false)

  // Registry relationship
  registryId String
  registry   Registry @relation(fields: [registryId], references: [id], onDelete: Cascade)

  // Item relationships (only one should be set)
  productId String?
  product   Product? @relation(fields: [productId], references: [id], onDelete: Cascade)

  collectionId String?
  collection   Collection? @relation(fields: [collectionId], references: [id], onDelete: Cascade)

  // Purchases
  purchases RegistryPurchaseJoin[]

  @@unique([registryId, productId, collectionId])
  @@index([registryId])
  @@index([productId])
  @@index([collectionId])
  @@index([purchased])
  @@index([priority])
  @@index([deletedAt])
  @@index([deletedById])
}

model RegistryPurchaseJoin {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Purchase metadata
  purchaseDate DateTime       @default(now())
  quantity     Int            @default(1)
  status       PurchaseStatus @default(PENDING)

  // Transaction information
  transactionId String? // External transaction ID
  orderNumber   String? // Order number for reference
  price         Float? // Price at time of purchase
  currency      String? // Currency code (e.g., USD, EUR)

  // Shipping information
  trackingNumber    String?
  trackingUrl       String?
  estimatedDelivery DateTime?
  actualDelivery    DateTime?

  // Gift information
  isGift      Boolean @default(false)
  giftMessage String? @db.Text
  giftWrapped Boolean @default(false)

  // Thank you tracking
  thankYouSent    Boolean   @default(false)
  thankYouSentAt  DateTime?
  thankYouMessage String?   @db.Text

  // Notes
  notes String?

  // Purchaser relationship
  purchaserId String
  purchaser   User   @relation("UserPurchases", fields: [purchaserId], references: [id], onDelete: Cascade)

  // Registry item relationship
  registryItemId String
  registryItem   RegistryItem @relation(fields: [registryItemId], references: [id], onDelete: Cascade)

  // Notification status
  notifiedOwner Boolean   @default(false)
  notifiedDate  DateTime?

  @@index([purchaserId])
  @@index([registryItemId])
  @@index([status])
  @@index([purchaseDate])
  @@index([transactionId])
  @@index([orderNumber])
  @@index([isGift])
  @@index([notifiedOwner])
  @@index([thankYouSent])
}

model Media {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Soft delete
  deletedAt   DateTime?
  deletedById String?
  deletedBy   User?     @relation("DeletedMedia", fields: [deletedById], references: [id], onDelete: SetNull)

  // Basic information
  url     String
  altText String?
  type    MediaType @default(IMAGE)

  // Technical details
  width    Int?
  height   Int?
  size     Int? // File size in bytes
  mimeType String?

  // Ownership
  userId String?
  user   User?   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Entity relationships (only one should be set)
  articleId String?
  article   Article? @relation(fields: [articleId], references: [id], onDelete: Cascade)

  brandId String?
  brand   Brand?  @relation(fields: [brandId], references: [id], onDelete: SetNull)

  collectionId String?
  collection   Collection? @relation(fields: [collectionId], references: [id], onDelete: SetNull)

  productId String?
  product   Product? @relation(fields: [productId], references: [id], onDelete: Cascade)

  taxonomyId String?
  taxonomy   Taxonomy? @relation(fields: [taxonomyId], references: [id], onDelete: SetNull)

  reviewId String?
  review   Review? @relation(fields: [reviewId], references: [id], onDelete: Cascade)

  categoryId String?
  category   ProductCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([articleId])
  @@index([brandId])
  @@index([collectionId])
  @@index([productId])
  @@index([taxonomyId])
  @@index([reviewId])
  @@index([categoryId])
  @@index([type])
  @@index([deletedAt])
  @@index([deletedById])
}

//==============================================================================
// JUNCTION MODELS
//==============================================================================

model PdpJoin {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relationships
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  brandId String
  brand   Brand  @relation(fields: [brandId], references: [id], onDelete: Cascade)

  @@unique([productId, brandId])
  @@index([productId])
  @@index([brandId])
}

model FavoriteJoin {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // User relationship
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Item relationships (only one should be set)
  productId String?
  product   Product? @relation(fields: [productId], references: [id], onDelete: Cascade)

  collectionId String?
  collection   Collection? @relation(fields: [collectionId], references: [id], onDelete: Cascade)

  @@unique([userId, productId, collectionId])
  @@index([userId])
  @@index([productId])
  @@index([collectionId])
}

model ReviewVoteJoin {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Vote information
  voteType VoteType // Whether the user found the review helpful or not

  // Relationships
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  reviewId String
  review   Review @relation(fields: [reviewId], references: [id], onDelete: Cascade)

  @@unique([userId, reviewId])
  @@index([userId])
  @@index([reviewId])
  @@index([voteType])
}

model RegistryUserJoin {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Role information
  role RegistryUserRole @default(VIEWER)

  // Relationships
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  registryId String
  registry   Registry @relation(fields: [registryId], references: [id], onDelete: Cascade)

  @@unique([userId, registryId])
  @@index([userId])
  @@index([registryId])
  @@index([role])
}

// enums.prisma - All enums used across the schema

//==============================================================================
// E-COMMERCE ENUMS
//==============================================================================

enum ContentStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum BrandType {
  MANUFACTURER
  RETAILER
  MARKETPLACE
  SERVICE
  OTHER
}

enum CollectionType {
  SEASONAL
  THEMATIC
  PRODUCT_LINE
  BRAND_LINE
  PROMOTIONAL
  CURATED
  TRENDING
  FEATURED
  NEW_ARRIVALS
  BEST_SELLERS
  CLEARANCE
  LIMITED_EDITION
  COLLABORATION
  EXCLUSIVE
  BUNDLE
  SET
  OTHER
}

enum TaxonomyType {
  CATEGORY
  TAG
  ATTRIBUTE
  DEPARTMENT
  COLLECTION
  OTHER
}

enum MediaType {
  IMAGE
  VIDEO
  DOCUMENT
  AUDIO
}

enum ReviewType {
  IMPORTED // Reviews imported from external sources
  DEDICATED // Reviews created directly on the platform
}

enum RegistryType {
  WISHLIST
  GIFT
  WEDDING
  BABY
  BIRTHDAY
  HOLIDAY
  OTHER
}

enum PurchaseStatus {
  PENDING
  CONFIRMED
  SHIPPED
  DELIVERED
  CANCELLED
  RETURNED
}

enum VoteType {
  HELPFUL
  NOT_HELPFUL
}

enum RegistryUserRole {
  OWNER // Can edit all aspects of the registry and delete it
  EDITOR // Can add/remove items and edit details
  VIEWER // Can only view the registry
}

//==============================================================================
// PIM ENUMS
//==============================================================================

enum ProductStatus {
  DRAFT
  ACTIVE
  ARCHIVED
  DISCONTINUED
}

enum ProductType {
  PHYSICAL
  DIGITAL
  SERVICE
  SUBSCRIPTION
  BUNDLE
  VARIANT
  OTHER
}

enum BarcodeType {
  UPC_A
  UPC_E
  EAN_13
  EAN_8
  CODE_128
  CODE_39
  QR_CODE
  PDF417
  AZTEC
  DATA_MATRIX
  ITF14
  CODABAR
  OTHER
}

enum AssetType {
  IMAGE
  VIDEO
  DOCUMENT
  MANUAL
  SPECIFICATION
  CERTIFICATE
  OTHER
}

// pim.prisma - Product Information Management Models

//==============================================================================
// PRODUCT INFORMATION MANAGEMENT (PIM) MODELS
//==============================================================================

model Product {
  id          String        @id @default(cuid())
  name        String
  sku         String        @unique
  description String?
  category    String
  status      ProductStatus @default(DRAFT)

  // Product details
  brand    String?
  price    Float?
  currency String? @default("USD")

  // Type from e-commerce schema
  type ProductType @default(PHYSICAL)

  // Content and metadata from e-commerce
  copy         Json? // Flexible storage for product copy/content
  canonicalUrl String? // Canonical URL for the product detail page

  // Hierarchical relationship from e-commerce
  parentId String?
  parent   Product?  @relation("ProductHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children Product[] @relation("ProductHierarchy")

  // Barcode information
  barcodes ProductBarcode[]

  // Product attributes (flexible JSON storage)
  attributes Json @default("{}")

  // Metadata
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  createdBy      String?
  organizationId String?

  // Soft delete
  deletedAt   DateTime?
  deletedById String?
  deletedBy   User?     @relation("DeletedProducts", fields: [deletedById], references: [id], onDelete: SetNull)

  // AI-generated flag
  aiGenerated  Boolean  @default(false)
  aiConfidence Float?
  aiSources    String[] @default([])

  // Relations from PIM
  digitalAssets ProductAsset[]
  scanHistory   ScanHistory[]

  // Relations from e-commerce
  soldBy      PdpJoin[]
  collections Collection[]      @relation("ProductToCollection")
  taxonomies  Taxonomy[]        @relation("ProductToTaxonomy")
  categories  ProductCategory[]
  media       Media[]
  favorites   FavoriteJoin[]
  reviews     Review[]
  registries  RegistryItem[]

  @@index([sku])
  @@index([category])
  @@index([status])
  @@index([organizationId])
  @@index([aiGenerated])
  @@index([brand])
  @@index([type])
  @@index([parentId])
  @@index([deletedAt])
  @@map("product")
}

model ProductBarcode {
  id        String      @id @default(cuid())
  productId String
  barcode   String
  type      BarcodeType
  isPrimary Boolean     @default(false)
  createdAt DateTime    @default(now())
  product   Product     @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([barcode])
  @@index([productId])
  @@index([barcode])
  @@map("product_barcode")
}

model ProductAsset {
  id          String    @id @default(cuid())
  productId   String
  type        AssetType
  url         String
  filename    String
  mimeType    String?
  size        Int?
  alt         String?
  description String?
  sortOrder   Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  product     Product   @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([type])
  @@map("product_asset")
}

model ScanHistory {
  id        String  @id @default(cuid())
  barcode   String
  type      String
  productId String?
  userId    String?
  sessionId String? // Session identifier for grouping scans

  // Scan metadata
  platform  String? // ios, android, web
  userAgent String?
  ipAddress String?

  // Scan results
  success   Boolean  @default(true)
  scannedAt DateTime @default(now())

  // Additional data from scan
  rawData String
  note    String?

  createdAt DateTime @default(now())

  // Relations
  product Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
  user    User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([barcode])
  @@index([barcode, scannedAt])
  @@index([productId])
  @@index([userId])
  @@index([sessionId])
  @@index([createdAt])
  @@index([scannedAt])
  @@index([success])
  @@map("scan_history")
}

// schema.prisma - Main configuration file
// This file contains the generator and datasource configuration
// Model definitions are split across multiple files in this directory

generator client {
  provider      = "prisma-client-js"
  output        = "../generated/client"
  binaryTargets = ["native", "darwin-arm64"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// workflows.prisma - Workflow Management Models

//==============================================================================
// WORKFLOW MANAGEMENT MODELS
//==============================================================================

model WorkflowConfig {
  id             String  @id @default(cuid())
  workflowSlug   String // References the dynamically registered workflow
  organizationId String? // If set, applies to entire organization
  userId         String? // If set, applies to specific user

  // Enable/disable workflow
  isEnabled Boolean @default(true)

  // Optional overrides
  displayName String?
  description String?
  category    String?
  tags        String[]

  // Notification settings
  notifyOnStart     Boolean @default(false)
  notifyOnComplete  Boolean @default(false)
  notifyOnFailure   Boolean @default(true)
  notifyOnApproval  Boolean @default(false)
  notificationEmail String?

  // Execution limits
  maxRetries       Int?
  timeoutSeconds   Int?
  rateLimitPerHour Int?

  // Resource limits
  maxConcurrent Int?
  priority      Int? @default(5) @db.SmallInt

  // Custom configuration
  customPayload Json?
  metadata      Json?

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  createdBy String?

  // Relations
  schedules WorkflowSchedule[]

  @@unique([workflowSlug, organizationId])
  @@unique([workflowSlug, userId])
  @@index([workflowSlug])
  @@index([organizationId])
  @@index([userId])
  @@index([isEnabled])
  @@map("workflow_config")
}

model WorkflowExecution {
  id             String  @id @default(cuid())
  workflowRunId  String  @unique
  workflowSlug   String
  userId         String?
  organizationId String?

  // Execution details
  status      String // pending, running, completed, failed, cancelled
  startedAt   DateTime  @default(now())
  completedAt DateTime?
  duration    Int? // milliseconds

  // Payload and results
  inputPayloadHash String?
  hasOutput        Boolean @default(false)
  error            String? @db.Text
  errorType        String?

  // Metrics
  stepCount      Int @default(0)
  completedSteps Int @default(0)
  retryCount     Int @default(0)

  // Trigger information
  triggeredBy       String // api, schedule, webhook, manual, chained
  triggerSource     String?
  parentExecutionId String?

  // Cost tracking
  creditsUsed  Int @default(0)
  apiCallCount Int @default(0)

  // Metadata
  tags      String[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([workflowSlug])
  @@index([workflowSlug, status, startedAt])
  @@index([userId])
  @@index([organizationId])
  @@index([organizationId, status, startedAt])
  @@index([status])
  @@index([startedAt])
  @@index([triggeredBy])
  @@map("workflow_execution")
}

model WorkflowSchedule {
  id       String @id @default(cuid())
  configId String

  // Schedule configuration
  name           String
  description    String?
  cronExpression String
  timezone       String  @default("UTC")
  isActive       Boolean @default(true)

  // Execution settings
  payload Json

  // Schedule metadata
  nextRunAt      DateTime?
  lastRunAt      DateTime?
  lastRunStatus  String?
  totalRuns      Int       @default(0)
  successfulRuns Int       @default(0)
  failedRuns     Int       @default(0)

  // Validity period
  validFrom  DateTime  @default(now())
  validUntil DateTime?

  // Metadata
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  createdBy String?

  // Relations
  config WorkflowConfig @relation(fields: [configId], references: [id], onDelete: Cascade)

  @@index([configId])
  @@index([isActive])
  @@index([nextRunAt])
  @@map("workflow_schedule")
}
