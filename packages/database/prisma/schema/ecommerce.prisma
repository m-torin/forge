// ecommerce.prisma - E-commerce and Product Information Management Models

//==============================================================================
// PRODUCT INFORMATION MANAGEMENT (PIM) MODELS
//==============================================================================

model Product {
  id            String   @id @default(cuid())
  name          String
  sku           String   @unique
  description   String?
  category      String
  status        ProductStatus @default(DRAFT)

  // Product details
  brand         String?
  price         Float?
  currency      String?  @default("USD")

  // Type from e-commerce schema
  type          ProductType   @default(PHYSICAL)

  // Content and metadata from e-commerce
  copy          Json?    // Flexible storage for product copy/content
  canonicalUrl  String?  // Canonical URL for the product detail page

  // Hierarchical relationship from e-commerce
  parentId      String?
  parent        Product? @relation("ProductHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children      Product[] @relation("ProductHierarchy")

  // Barcode information
  barcodes      ProductBarcode[]

  // Product attributes (flexible JSON storage)
  attributes    Json     @default("{}")

  // Metadata
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  createdBy     String?
  organizationId String?

  // Soft delete
  deletedAt     DateTime?
  deletedById   String?
  deletedBy     User?    @relation("DeletedProducts", fields: [deletedById], references: [id], onDelete: SetNull)

  // AI-generated flag
  aiGenerated   Boolean  @default(false)
  aiConfidence  Float?
  aiSources     String[] @default([])

  // Relations from PIM
  digitalAssets ProductAsset[]
  scanHistory   ScanHistory[]

  // Relations from e-commerce
  soldBy        PdpJoin[]
  collections   Collection[]  @relation("ProductToCollection")
  taxonomies    Taxonomy[]    @relation("ProductToTaxonomy")
  categories    ProductCategory[]
  media         Media[]
  favorites     FavoriteJoin[]
  reviews       Review[]
  registries    RegistryItem[]

  @@index([sku])
  @@index([category])
  @@index([status])
  @@index([organizationId])
  @@index([aiGenerated])
  @@index([brand])
  @@index([type])
  @@index([parentId])
  @@index([deletedAt])
  @@map("product")
}

model ProductBarcode {
  id        String @id @default(cuid())
  productId String
  barcode   String
  type      BarcodeType
  isPrimary Boolean @default(false)
  createdAt DateTime @default(now())
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([barcode])
  @@index([productId])
  @@index([barcode])
  @@map("product_barcode")
}

model ProductAsset {
  id          String    @id @default(cuid())
  productId   String
  type        AssetType
  url         String
  filename    String
  mimeType    String?
  size        Int?
  alt         String?
  description String?
  sortOrder   Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  product     Product   @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([type])
  @@map("product_asset")
}

model ScanHistory {
  id          String    @id @default(cuid())
  barcode     String
  type        String
  productId   String?
  userId      String?
  sessionId   String?   // Session identifier for grouping scans

  // Scan metadata
  platform    String?   // ios, android, web
  userAgent   String?
  ipAddress   String?

  // Scan results
  success     Boolean   @default(true)
  scannedAt   DateTime  @default(now())

  // Additional data from scan
  rawData     String
  note        String?

  createdAt   DateTime  @default(now())

  // Relations
  product     Product?  @relation(fields: [productId], references: [id], onDelete: SetNull)
  user        User?     @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([barcode])
  @@index([barcode, scannedAt])
  @@index([productId])
  @@index([userId])
  @@index([sessionId])
  @@index([createdAt])
  @@index([scannedAt])
  @@index([success])
  @@map("scan_history")
}

//==============================================================================
// E-COMMERCE CONTENT MODELS
//==============================================================================

model ProductCategory {
  id        String        @id @default(cuid())
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  // Soft delete
  deletedAt DateTime?
  deletedById String?
  deletedBy   User?       @relation("DeletedProductCategories", fields: [deletedById], references: [id], onDelete: SetNull)

  // Basic information
  name      String
  slug      String        @unique
  status    ContentStatus @default(PUBLISHED)

  // Content and metadata
  description String?     @db.Text
  copy        Json?       // Flexible storage for category copy/content

  // SEO metadata
  metaTitle       String?
  metaDescription String?
  metaKeywords    String?

  // Hierarchical relationship
  parentId  String?
  parent    ProductCategory?  @relation("ProductCategoryHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children  ProductCategory[] @relation("ProductCategoryHierarchy")

  // Display order within parent category
  displayOrder Int @default(0)

  // Relationships
  products   Product[]
  collections Collection[] @relation("CollectionToCategory")
  media      Media[]

  @@index([slug])
  @@index([parentId])
  @@index([status])
  @@index([displayOrder])
  @@index([deletedAt])
  @@index([deletedById])
}


model Brand {
  id        String        @id @default(cuid())
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  // Soft delete
  deletedAt DateTime?
  deletedById String?
  deletedBy   User?       @relation("DeletedBrands", fields: [deletedById], references: [id], onDelete: SetNull)

  // Basic information
  name      String
  slug      String        @unique
  type      BrandType     @default(OTHER)
  status    ContentStatus @default(DRAFT)

  // Content and metadata
  copy      Json          // Flexible storage for brand copy/content
  baseUrl   String?       // Base URL for the brand's website

  // Hierarchical relationship
  parentId  String?
  parent    Brand?        @relation("BrandHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children  Brand[]       @relation("BrandHierarchy")

  // Display order within parent brand
  displayOrder Int @default(0)

  // Relationships
  products     PdpJoin[]
  collections  Collection[] @relation("BrandToCollection")
  media        Media[]

  @@index([slug])
  @@index([type])
  @@index([status])
  @@index([parentId])
  @@index([displayOrder])
  @@index([deletedAt])
  @@index([deletedById])
}

model Collection {
  id        String         @id @default(cuid())
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  // Soft delete
  deletedAt DateTime?
  deletedById String?
  deletedBy   User?        @relation("DeletedCollections", fields: [deletedById], references: [id], onDelete: SetNull)

  // Basic information
  name      String
  slug      String         @unique
  type      CollectionType @default(OTHER)
  status    ContentStatus  @default(DRAFT)

  // Content and metadata
  copy      Json           // Flexible storage for collection copy/content

  // Ownership (optional)
  userId    String?
  user      User?          @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Hierarchical structure
  parentId  String?
  parent    Collection?    @relation("CollectionHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children  Collection[]   @relation("CollectionHierarchy")

  // Relationships
  products    Product[]    @relation("ProductToCollection")
  brands      Brand[]      @relation("BrandToCollection")
  taxonomies  Taxonomy[]   @relation("CollectionToTaxonomy")
  categories  ProductCategory[] @relation("CollectionToCategory")
  media       Media[]
  favorites   FavoriteJoin[]
  registries  RegistryItem[]

  @@index([slug])
  @@index([type])
  @@index([userId])
  @@index([status])
  @@index([parentId])
  @@index([deletedAt])
  @@index([deletedById])
}

model Taxonomy {
  id        String        @id @default(cuid())
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  // Soft delete
  deletedAt DateTime?
  deletedById String?
  deletedBy   User?       @relation("DeletedTaxonomies", fields: [deletedById], references: [id], onDelete: SetNull)

  // Basic information
  name      String
  slug      String        @unique
  type      TaxonomyType  @default(CATEGORY)
  status    ContentStatus @default(DRAFT)

  // Content and metadata
  copy      Json          // Flexible storage for taxonomy copy/content

  // Relationships
  products    Product[]     @relation("ProductToTaxonomy")
  collections Collection[]  @relation("CollectionToTaxonomy")
  media       Media[]

  @@index([slug])
  @@index([type])
  @@index([status])
  @@index([deletedAt])
  @@index([deletedById])
}



model Media {
  id        String    @id @default(cuid())
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  // Soft delete
  deletedAt DateTime?
  deletedById String?
  deletedBy   User?   @relation("DeletedMedia", fields: [deletedById], references: [id], onDelete: SetNull)

  // Basic information
  url       String
  altText   String?
  type      MediaType @default(IMAGE)

  // Technical details
  width     Int?
  height    Int?
  size      Int?      // File size in bytes
  mimeType  String?

  // Ownership
  userId    String?
  user      User?     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Entity relationships (only one should be set)
  articleId    String?
  article      Article?    @relation(fields: [articleId], references: [id], onDelete: Cascade)

  brandId      String?
  brand        Brand?      @relation(fields: [brandId], references: [id], onDelete: SetNull)

  collectionId String?
  collection   Collection? @relation(fields: [collectionId], references: [id], onDelete: SetNull)

  productId    String?
  product      Product?    @relation(fields: [productId], references: [id], onDelete: Cascade)

  taxonomyId   String?
  taxonomy     Taxonomy?   @relation(fields: [taxonomyId], references: [id], onDelete: SetNull)

  reviewId     String?
  review       Review?     @relation(fields: [reviewId], references: [id], onDelete: Cascade)

  categoryId   String?
  category     ProductCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([articleId])
  @@index([brandId])
  @@index([collectionId])
  @@index([productId])
  @@index([taxonomyId])
  @@index([reviewId])
  @@index([categoryId])
  @@index([type])
  @@index([deletedAt])
  @@index([deletedById])
}

//==============================================================================
// JUNCTION MODELS
//==============================================================================

model PdpJoin {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relationships
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  brandId   String
  brand     Brand    @relation(fields: [brandId], references: [id], onDelete: Cascade)

  @@unique([productId, brandId])
  @@index([productId])
  @@index([brandId])
}


