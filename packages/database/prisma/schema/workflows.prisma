// workflows.prisma - Workflow Management Models

//==============================================================================
// WORKFLOW MANAGEMENT MODELS
//==============================================================================

model WorkflowConfig {
  id              String   @id @default(cuid())
  workflowSlug    String   // References the dynamically registered workflow
  organizationId  String?  // If set, applies to entire organization
  userId          String?  // If set, applies to specific user

  // Enable/disable workflow
  isEnabled       Boolean  @default(true)

  // Optional overrides
  displayName     String?
  description     String?
  category        String?
  tags            String[]

  // Notification settings
  notifyOnStart   Boolean  @default(false)
  notifyOnComplete Boolean @default(false)
  notifyOnFailure Boolean  @default(true)
  notifyOnApproval Boolean @default(false)
  notificationEmail String?

  // Execution limits
  maxRetries      Int?
  timeoutSeconds  Int?
  rateLimitPerHour Int?

  // Resource limits
  maxConcurrent   Int?
  priority        Int?     @db.SmallInt @default(5)

  // Custom configuration
  customPayload   Json?
  metadata        Json?

  // Timestamps
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  createdBy       String?

  // Relations
  schedules       WorkflowSchedule[]

  @@unique([workflowSlug, organizationId])
  @@unique([workflowSlug, userId])
  @@index([workflowSlug])
  @@index([organizationId])
  @@index([userId])
  @@index([isEnabled])
  @@map("workflow_config")
}

model WorkflowExecution {
  id                  String   @id @default(cuid())
  workflowRunId       String   @unique
  workflowSlug        String
  userId              String?
  organizationId      String?

  // Execution details
  status              String   // pending, running, completed, failed, cancelled
  startedAt           DateTime @default(now())
  completedAt         DateTime?
  duration            Int?     // milliseconds

  // Payload and results
  inputPayloadHash    String?
  hasOutput           Boolean  @default(false)
  error               String?  @db.Text
  errorType           String?

  // Metrics
  stepCount           Int      @default(0)
  completedSteps      Int      @default(0)
  retryCount          Int      @default(0)

  // Trigger information
  triggeredBy         String   // api, schedule, webhook, manual, chained
  triggerSource       String?
  parentExecutionId   String?

  // Cost tracking
  creditsUsed         Int      @default(0)
  apiCallCount        Int      @default(0)

  // Metadata
  tags                String[]
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([workflowSlug])
  @@index([workflowSlug, status, startedAt])
  @@index([userId])
  @@index([organizationId])
  @@index([organizationId, status, startedAt])
  @@index([status])
  @@index([startedAt])
  @@index([triggeredBy])
  @@map("workflow_execution")
}

model WorkflowSchedule {
  id                  String   @id @default(cuid())
  configId            String

  // Schedule configuration
  name                String
  description         String?
  cronExpression      String
  timezone            String   @default("UTC")
  isActive            Boolean  @default(true)

  // Execution settings
  payload             Json

  // Schedule metadata
  nextRunAt           DateTime?
  lastRunAt           DateTime?
  lastRunStatus       String?
  totalRuns           Int      @default(0)
  successfulRuns      Int      @default(0)
  failedRuns          Int      @default(0)

  // Validity period
  validFrom           DateTime @default(now())
  validUntil          DateTime?

  // Metadata
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  createdBy           String?

  // Relations
  config              WorkflowConfig @relation(fields: [configId], references: [id], onDelete: Cascade)

  @@index([configId])
  @@index([isActive])
  @@index([nextRunAt])
  @@map("workflow_schedule")
}