{
  "name": "@repo/database",
  "private": true,
  "type": "module",
  "main": "./index.ts",
  "types": "./index.ts",
  "scripts": {
    "analyze": "doppler run -- prisma generate --no-hints --schema=./prisma/schema.prisma",
    "analyze:offline": "prisma generate --no-hints --schema=./prisma/schema.prisma",
    "build": "doppler run -- prisma generate --no-hints --schema=./prisma/schema.prisma",
    "build:offline": "prisma generate --no-hints --schema=./prisma/schema.prisma",
    "typecheck": "tsc --noEmit --emitDeclarationOnly false",
    "lint": "eslint . --fix",
    "seed": "doppler run -- tsx prisma/seed.ts",
    "seed:offline": "tsx prisma/seed.ts",
    "create-users": "doppler run -- tsx scripts/create-users.ts",
    "create-users:offline": "tsx scripts/create-users.ts",
    "doppler:secrets": "doppler secrets",
    "doppler:secrets:upload": "doppler secrets upload .env.local",
    "doppler:secrets:download": "doppler secrets download --no-file --format env",
    "doppler:pull": "doppler secrets download --no-file --format env > .env.local",
    "doppler:open": "doppler open"
  },
  "dependencies": {
    "@prisma/client": "catalog:",
    "@prisma/extension-accelerate": "^2.0.1",
    "@t3-oss/env-nextjs": "catalog:",
    "chalk": "^5.4.1",
    "server-only": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@repo/eslint-config": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "@types/eslint": "^9.6.1",
    "@types/node": "catalog:",
    "eslint": "catalog:",
    "prisma": "catalog:",
    "tsx": "^4.19.4",
    "typescript": "catalog:"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
