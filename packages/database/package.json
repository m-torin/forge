{
  "name": "@repo/database",
  "private": true,
  "type": "module",
  "scripts": {
    "clean": "rm -rf ./prisma-generated",
    "analyze": "pnpm prisma:generate -- --no-hints",
    "analyze:local": "pnpm prisma:generate:local -- --no-hints",
    "build": "pnpm analyze",
    "build:local": "pnpm analyze:local",
    "typecheck": "tsc --noEmit --emitDeclarationOnly false",
    "lint": "eslint . --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:firestore": "vitest run __tests__/firestore.test.ts",
    "test:vector": "vitest run __tests__/upstash-vector.test.ts",
    "test:redis": "vitest run __tests__/upstash-redis.test.ts",
    "test:integration": "vitest run __tests__/integration.test.ts",
    "test:performance": "vitest run __tests__/performance.test.ts",
    "prisma:generate": "pnpm clean && doppler run -- prisma generate --schema=./prisma",
    "prisma:generate:local": "pnpm clean && prisma generate --schema=./prisma",
    "prisma:migrate": "doppler run -- prisma migrate dev --schema=./prisma",
    "prisma:migrate:local": "prisma migrate dev --schema=./prisma",
    "prisma:migrate:deploy": "doppler run -- prisma migrate deploy --schema=./prisma",
    "prisma:migrate:deploy:local": "prisma migrate deploy --schema=./prisma",
    "prisma:migrate:reset": "doppler run -- prisma migrate reset --schema=./prisma",
    "prisma:migrate:reset:local": "prisma migrate reset --schema=./prisma",
    "prisma:push": "doppler run -- prisma db push --schema=./prisma",
    "prisma:push:local": "prisma db push --schema=./prisma",
    "prisma:studio": "doppler run -- prisma studio --schema=./prisma",
    "prisma:studio:local": "prisma studio --schema=./prisma",
    "prisma:format": "prisma format --schema=./prisma",
    "prisma:validate": "prisma validate --schema=./prisma",
    "seed": "doppler run -- tsx prisma/src/seed.ts",
    "seed:local": "tsx prisma/src/seed.ts",
    "create-users": "doppler run -- tsx scripts/create-users.ts",
    "create-users:local": "tsx scripts/create-users.ts",
    "doppler:secrets": "doppler secrets",
    "doppler:secrets:upload": "doppler secrets upload .env.local",
    "doppler:secrets:download": "doppler secrets download --no-file --format env",
    "doppler:pull": "doppler secrets download --no-file --format env > .env.local",
    "doppler:open": "doppler open"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^6.9.0",
    "@prisma/client": "catalog:",
    "@prisma/extension-accelerate": "^2.0.1",
    "@repo/observability": "workspace:*",
    "@t3-oss/env-nextjs": "catalog:",
    "@upstash/redis": "^1.35.0",
    "@upstash/vector": "^1.2.1",
    "chalk": "^5.4.1",
    "firebase-admin": "^13.4.0",
    "pg": "^8.16.0",
    "server-only": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@faker-js/faker": "^9.8.0",
    "@repo/config": "workspace:*",
    "@repo/eslint-config": "workspace:*",
    "@repo/testing": "workspace:*",
    "@types/eslint": "^9.6.1",
    "@types/node": "catalog:",
    "@types/pg": "^8.15.4",
    "eslint": "catalog:",
    "prisma": "catalog:",
    "tsx": "^4.20.1",
    "typescript": "catalog:"
  },
  "prisma": {
    "seed": "tsx prisma/src/seed.ts",
    "schema": "./prisma"
  },
  "exports": {
    "./prisma": {
      "types": "./prisma/index.ts",
      "import": "./prisma/index.ts"
    },
    "./prisma/edge": {
      "types": "./prisma/clients/edge.ts",
      "import": "./prisma/clients/edge.ts"
    },
    "./prisma/accelerate": {
      "types": "./prisma/clients/accelerate.ts",
      "import": "./prisma/clients/accelerate.ts"
    },
    "./firestore": {
      "types": "./firestore/index.ts",
      "import": "./firestore/index.ts"
    },
    "./upstash": {
      "types": "./upstash/index.ts",
      "import": "./upstash/index.ts"
    },
    "./redis": {
      "types": "./redis/index.ts",
      "import": "./redis/index.ts"
    },
    "./types": {
      "types": "./types.ts",
      "import": "./types.ts"
    },
    "./keys": {
      "types": "./keys.ts",
      "import": "./keys.ts"
    }
  }
}
