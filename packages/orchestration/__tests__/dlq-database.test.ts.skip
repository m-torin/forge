import { describe, it, expect, beforeEach, afterEach, vi } from 'vitest';
import {
  mockUpstashRedisAdapter,
  mockFirestoreAdapter,
  resetMockRedisStorage,
  resetMockFirestoreStorage,
  RedisDatabaseTestHelper,
  DatabaseTestHelper,
  createTestUser,
} from '@repo/testing';
import {
  sendToDLQ,
  runWithDLQ,
  categorizeError,
  getDLQStats,
  clearDLQTracking,
  createDefaultDLQProcessor,
  processDLQMessage,
  type DLQConfig,
  type DLQMessage,
} from '../src/runtime/features/dlq-handling';
import { WorkflowErrorType } from '../src/utils/error-handling';

// Mock Redis and Firestore for DLQ storage
vi.mock('@upstash/redis', async () => {
  const { mockUpstashRedis } = await import('@repo/testing');
  return mockUpstashRedis;
});

vi.mock('firebase-admin', async () => {
  const { mockFirebaseAdmin } = await import('@repo/testing');
  return mockFirebaseAdmin;
});

describe('Orchestration DLQ with Database Storage', () => {
  let redisHelper: RedisDatabaseTestHelper;
  let firestoreHelper: DatabaseTestHelper;
  let mockContext: any;

  beforeEach(async () => {
    resetMockRedisStorage();
    resetMockFirestoreStorage();
    
    redisHelper = new RedisDatabaseTestHelper(mockUpstashRedisAdapter);
    firestoreHelper = new DatabaseTestHelper(mockFirestoreAdapter, {
      provider: 'firestore',
    });
    
    await redisHelper.setup();
    await firestoreHelper.setup();

    // Mock workflow context
    mockContext = {
      workflowRunId: 'test-workflow-789',
      url: 'https://example.com/webhook',
      headers: { 'content-type': 'application/json' },
      requestPayload: { orderId: 'order-123', userId: 'user-456' },
      run: vi.fn(),
      call: vi.fn(),
    };

    // Set development environment
    process.env.NODE_ENV = 'development';
  });

  afterEach(async () => {
    await redisHelper.cleanup();
    await firestoreHelper.cleanup();
    
    resetMockRedisStorage();
    resetMockFirestoreStorage();
    
    try {
      clearDLQTracking();
    } catch {
      // Ignore cleanup errors
    }
  });

  describe('DLQ Message Storage', () => {
    it('should store DLQ messages in Firestore for persistence', async () => {
      const error = new Error('Payment processing failed');
      const config: DLQConfig = {
        maxRetries: 3,
        includeOriginalPayload: true,
        useNativeDLQ: false,
      };

      // Mock the DLQ send to capture the message
      let capturedDLQMessage: DLQMessage | null = null;
      mockContext.call.mockImplementation(async (stepName: string, options: any) => {
        if (stepName === 'send-dlq-message') {
          capturedDLQMessage = options.body;
          return { success: true };
        }
      });

      config.dlqEndpoint = 'https://dlq.example.com/messages';

      await sendToDLQ(mockContext, 'send-dlq-message', config, error, 'payment-processing');

      // Store the DLQ message in Firestore for long-term storage
      if (capturedDLQMessage) {
        await firestoreHelper.getAdapter().create('dlq_messages', {
          id: `${capturedDLQMessage.originalWorkflowRunId}-${Date.now()}`,
          ...capturedDLQMessage,
          storedAt: Date.now(),
          processingStatus: 'pending',
        });

        // Verify storage
        const stored = await firestoreHelper.getAdapter().findMany('dlq_messages', {
          where: { originalWorkflowRunId: mockContext.workflowRunId },
        });

        expect(stored).toHaveLength(1);
        expect(stored[0].errorMessage).toBe('Payment processing failed');
        expect(stored[0].failedStep).toBe('payment-processing');
        expect(stored[0].originalPayload).toEqual(mockContext.requestPayload);
      }
    });

    it('should store DLQ statistics in Redis for real-time monitoring', async () => {
      const errors = [
        { step: 'api-call', category: 'network', message: 'Connection timeout' },
        { step: 'data-validation', category: 'validation', message: 'Invalid schema' },
        { step: 'api-call', category: 'network', message: 'Service unavailable' },
      ];

      const config: DLQConfig = {
        maxRetries: 2,
        retryableErrors: ['network'],
      };

      // Process multiple errors
      for (const errorInfo of errors) {
        const error = new Error(errorInfo.message);
        await sendToDLQ(mockContext, 'dlq-stats', config, error, errorInfo.step);

        // Update statistics in Redis
        await redisHelper.getAdapter().increment('dlq_stats', 'total_messages');
        await redisHelper.getAdapter().increment('dlq_stats', `category_${errorInfo.category}`);
        await redisHelper.getAdapter().increment('dlq_stats', `step_${errorInfo.step}`);
        
        // Add to recent errors list
        await redisHelper.getAdapter().listPush('recent_dlq_errors', 'list', {
          step: errorInfo.step,
          category: errorInfo.category,
          timestamp: Date.now(),
          workflowRunId: mockContext.workflowRunId,
        });
      }

      // Verify statistics
      const totalMessages = await redisHelper.getAdapter().increment('dlq_stats', 'total_messages', undefined, 0);
      expect(totalMessages).toBe(3);

      const networkErrors = await redisHelper.getAdapter().increment('dlq_stats', 'category_network', undefined, 0);
      expect(networkErrors).toBe(2);

      const validationErrors = await redisHelper.getAdapter().increment('dlq_stats', 'category_validation', undefined, 0);
      expect(validationErrors).toBe(1);

      // Check recent errors
      const recentErrors = await redisHelper.getAdapter().listRange('recent_dlq_errors', 'list', 0, -1);
      expect(recentErrors).toHaveLength(3);
    });

    it('should maintain DLQ retry history in database', async () => {
      const workflowRunId = 'retry-test-workflow';
      const stepName = 'external-service-call';
      const error = new Error('Service temporarily unavailable');

      const config: DLQConfig = {
        maxRetries: 3,
        retryableErrors: ['network', 'server_error'],
      };

      // Simulate multiple failures leading to DLQ
      const retryHistory = [];
      
      for (let attempt = 1; attempt <= 4; attempt++) {
        const retryRecord = {
          id: `${workflowRunId}-${stepName}-${attempt}`,
          workflowRunId,
          stepName,
          attempt,
          errorMessage: error.message,
          errorCategory: categorizeError(error),
          timestamp: Date.now() + (attempt * 1000), // Spread out timestamps
          isRetryable: true,
        };

        retryHistory.push(retryRecord);

        // Store in Firestore for historical tracking
        await firestoreHelper.getAdapter().create('retry_history', retryRecord);

        // Update current retry count in Redis
        await redisHelper.getAdapter().setWithExpiration(
          'current_retries',
          `${workflowRunId}:${stepName}`,
          { count: attempt, lastAttempt: Date.now() },
          3600 // 1 hour TTL
        );
      }

      // Verify retry history
      const history = await firestoreHelper.getAdapter().findMany('retry_history', {
        where: { workflowRunId },
        orderBy: { field: 'attempt', direction: 'asc' },
      });

      expect(history).toHaveLength(4);
      expect(history[0].attempt).toBe(1);
      expect(history[3].attempt).toBe(4);

      // Verify current retry state
      const currentState = await redisHelper.getAdapter().findUnique('current_retries', {
        id: `${workflowRunId}:${stepName}`
      });
      expect(currentState?.count).toBe(4);
    });
  });

  describe('DLQ Processing with Database Backends', () => {
    it('should process DLQ messages with database state management', async () => {
      const dlqMessage: DLQMessage = {
        originalWorkflowRunId: 'failed-workflow-123',
        failedStep: 'payment-capture',
        errorMessage: 'Payment gateway timeout',
        errorCategory: 'network',
        retryCount: 2,
        isRetryable: true,
        firstFailedAt: new Date(Date.now() - 300000).toISOString(), // 5 minutes ago
        lastFailedAt: new Date().toISOString(),
        originalPayload: { orderId: 'order-789', amount: 99.99 },
        context: {
          url: 'https://api.example.com/payment',
          environment: 'production',
          headers: {},
        },
      };

      // Store DLQ message state in database
      await firestoreHelper.getAdapter().create('dlq_processing', {
        id: dlqMessage.originalWorkflowRunId,
        ...dlqMessage,
        processingStatus: 'queued',
        processedAt: null,
        processingResult: null,
      });

      const processor = createDefaultDLQProcessor({
        autoRetryCategories: ['network'],
        maxAutoRetries: 3,
      });

      // Process the message
      await processDLQMessage(dlqMessage, processor);

      // Update processing status
      await firestoreHelper.getAdapter().update('dlq_processing', dlqMessage.originalWorkflowRunId, {
        processingStatus: 'processed',
        processedAt: Date.now(),
        processingResult: { action: 'retry', reason: 'Auto-retry for network error' },
      });

      // Verify processing state
      const processed = await firestoreHelper.getAdapter().findUnique('dlq_processing', {
        id: dlqMessage.originalWorkflowRunId
      });

      expect(processed?.processingStatus).toBe('processed');
      expect(processed?.processingResult.action).toBe('retry');
    });

    it('should maintain DLQ processing queues in Redis', async () => {
      const dlqMessages = [
        {
          id: 'dlq-msg-1',
          category: 'network',
          priority: 'high',
          retryCount: 1,
          workflowRunId: 'wf-1',
        },
        {
          id: 'dlq-msg-2', 
          category: 'validation',
          priority: 'medium',
          retryCount: 0,
          workflowRunId: 'wf-2',
        },
        {
          id: 'dlq-msg-3',
          category: 'network',
          priority: 'low',
          retryCount: 3,
          workflowRunId: 'wf-3',
        },
      ];

      // Add messages to priority queues
      for (const msg of dlqMessages) {
        // Use sorted sets for priority queues (score = priority + retry count)
        const priorityScore = {
          high: 100,
          medium: 50,
          low: 10,
        }[msg.priority] + msg.retryCount;

        await redisHelper.getAdapter().sortedSetAdd('dlq_processing_queue', 'pending',
          { score: priorityScore, member: msg }
        );

        // Add to category-specific queues
        await redisHelper.getAdapter().listPush('dlq_by_category', msg.category, msg);
      }

      // Process highest priority messages first
      const highPriorityMessages = await redisHelper.getAdapter().sortedSetRange(
        'dlq_processing_queue',
        'pending',
        -2, // Get top 2 highest scores
        -1,
        true
      );

      expect(highPriorityMessages).toHaveLength(2);

      // Process network errors as a batch
      const networkMessages = await redisHelper.getAdapter().listRange('dlq_by_category', 'network', 0, -1);
      expect(networkMessages).toHaveLength(2);
      expect(networkMessages.every((msg: any) => msg.category === 'network')).toBe(true);

      // Mark as processing
      for (const msg of networkMessages) {
        await redisHelper.getAdapter().setAdd('currently_processing', 'dlq', (msg as any).id);
      }

      const processing = await redisHelper.getAdapter().setMembers('currently_processing', 'dlq');
      expect(processing).toContain('dlq-msg-1');
      expect(processing).toContain('dlq-msg-3');
    });

    it('should handle DLQ escalation with database tracking', async () => {
      const escalatedMessage: DLQMessage = {
        originalWorkflowRunId: 'critical-failure-456',
        failedStep: 'user-notification',
        errorMessage: 'Critical service down',
        errorCategory: 'unknown',
        retryCount: 5,
        isRetryable: false,
        firstFailedAt: new Date(Date.now() - 3600000).toISOString(), // 1 hour ago
        lastFailedAt: new Date().toISOString(),
        originalPayload: { userId: 'critical-user-123', alertType: 'security' },
        context: {
          url: 'https://alerts.example.com/send',
          environment: 'production',
          headers: {},
        },
      };

      // Store escalation record
      await firestoreHelper.getAdapter().create('dlq_escalations', {
        id: `escalation-${escalatedMessage.originalWorkflowRunId}`,
        ...escalatedMessage,
        escalatedAt: Date.now(),
        escalationReason: 'Max retries exceeded for critical workflow',
        assignedTo: null,
        status: 'pending_review',
        severity: 'high',
      });

      // Add to escalation queue in Redis
      await redisHelper.getAdapter().listPush('escalation_queue', 'pending', {
        escalationId: `escalation-${escalatedMessage.originalWorkflowRunId}`,
        workflowRunId: escalatedMessage.originalWorkflowRunId,
        severity: 'high',
        escalatedAt: Date.now(),
      });

      // Track escalation metrics
      await redisHelper.getAdapter().increment('escalation_stats', 'total_escalations');
      await redisHelper.getAdapter().increment('escalation_stats', 'severity_high');

      // Verify escalation storage
      const escalation = await firestoreHelper.getAdapter().findUnique('dlq_escalations', {
        id: `escalation-${escalatedMessage.originalWorkflowRunId}`
      });

      expect(escalation?.status).toBe('pending_review');
      expect(escalation?.severity).toBe('high');

      // Verify queue
      const queueLength = await redisHelper.getAdapter().listLength('escalation_queue', 'pending');
      expect(queueLength).toBe(1);

      // Verify metrics
      const totalEscalations = await redisHelper.getAdapter().increment('escalation_stats', 'total_escalations', undefined, 0);
      expect(totalEscalations).toBe(1);
    });
  });

  describe('Database Performance Optimization', () => {
    it('should efficiently query DLQ messages by time ranges', async () => {
      const timeRanges = {
        lastHour: Date.now() - 3600000,
        last24Hours: Date.now() - 86400000,
        lastWeek: Date.now() - 604800000,
      };

      // Generate test DLQ messages across different time periods
      const messages = [];
      for (let i = 0; i < 20; i++) {
        const timestamp = timeRanges.lastWeek + (i * 100000); // Spread across week
        messages.push({
          id: `dlq-${i}`,
          workflowRunId: `workflow-${i}`,
          failedStep: 'processing',
          errorCategory: i % 3 === 0 ? 'network' : 'validation',
          timestamp,
          retryCount: Math.floor(i / 5),
        });
      }

      // Store in Firestore
      for (const msg of messages) {
        await firestoreHelper.getAdapter().create('dlq_timeline', msg);
      }

      // Query recent messages efficiently
      const recentMessages = await firestoreHelper.getAdapter().findMany('dlq_timeline', {
        where: { timestamp: { '>': timeRanges.lastHour } },
        orderBy: { field: 'timestamp', direction: 'desc' },
        limit: 10,
      });

      expect(recentMessages.length).toBeGreaterThan(0);
      
      // Use Redis for fast lookups of active errors
      const activeErrorKeys = messages
        .filter(msg => msg.timestamp > timeRanges.lastHour)
        .map(msg => msg.workflowRunId);

      await redisHelper.getAdapter().setAdd('active_errors', 'current', ...activeErrorKeys);
      
      const activeCount = await redisHelper.getAdapter().setMembers('active_errors', 'current');
      expect(activeCount.length).toBeGreaterThan(0);
    });

    it('should handle batch DLQ operations efficiently', async () => {
      const batchSize = 50;
      const dlqRecords = Array.from({ length: batchSize }, (_, i) => ({
        id: `batch-dlq-${i}`,
        workflowRunId: `batch-workflow-${i}`,
        errorCategory: ['network', 'validation', 'timeout'][i % 3],
        retryCount: Math.floor(i / 10),
        processingStatus: 'pending',
        createdAt: Date.now() + i,
      }));

      const startTime = performance.now();

      // Batch insert to Firestore
      for (const record of dlqRecords) {
        await firestoreHelper.getAdapter().create('batch_dlq', record);
      }

      // Batch operations in Redis
      const redisOperations = dlqRecords.map(record => ({
        id: record.id,
        category: record.errorCategory,
        status: record.processingStatus,
      }));

      await redisHelper.getAdapter().setMultiple('dlq_cache', redisOperations);

      const endTime = performance.now();
      const totalTime = endTime - startTime;
      const avgTimePerRecord = totalTime / batchSize;

      console.log(`Batch DLQ operations: ${avgTimePerRecord.toFixed(2)}ms per record`);
      expect(avgTimePerRecord).toBeLessThan(20); // Should be efficient

      // Verify batch operations
      const firestoreCount = await firestoreHelper.getAdapter().count('batch_dlq');
      expect(firestoreCount).toBe(batchSize);

      const redisCount = await redisHelper.getAdapter().count('dlq_cache');
      expect(redisCount).toBe(batchSize);
    });

    it('should support real-time DLQ dashboard queries', async () => {
      // Setup test data for dashboard
      const categories = ['network', 'validation', 'timeout', 'unknown'];
      const statuses = ['pending', 'processing', 'resolved', 'escalated'];

      // Generate metrics data
      for (const category of categories) {
        for (const status of statuses) {
          const count = Math.floor(Math.random() * 50) + 1;
          await redisHelper.getAdapter().hashSet('dlq_dashboard', `${category}_${status}`, count.toString());
        }
      }

      // Store hourly trends
      const currentHour = Math.floor(Date.now() / 3600000);
      for (let i = 0; i < 24; i++) {
        const hour = currentHour - i;
        const errorCount = Math.floor(Math.random() * 20);
        await redisHelper.getAdapter().sortedSetAdd('dlq_hourly_trends', 'errors',
          { score: hour, member: { hour: hour * 3600000, count: errorCount } }
        );
      }

      // Dashboard query: Get current status overview
      const statusOverview = await redisHelper.getAdapter().hashGetAll('dlq_dashboard', 'overview');
      expect(Object.keys(statusOverview).length).toBeGreaterThan(0);

      // Dashboard query: Get recent trends
      const recentTrends = await redisHelper.getAdapter().sortedSetRange('dlq_hourly_trends', 'errors', -12, -1, true);
      expect(recentTrends.length).toBeLessThanOrEqual(12); // Last 12 hours

      // Dashboard query: Get error distribution
      const errorDistribution: Record<string, number> = {};
      for (const category of categories) {
        const categoryTotal = await redisHelper.getAdapter().hashGet('dlq_dashboard', `${category}_total`) || '0';
        errorDistribution[category] = parseInt(categoryTotal);
      }

      expect(Object.keys(errorDistribution)).toEqual(categories);
    });
  });

  describe('Integration with Workflow Lifecycle', () => {
    it('should track complete workflow failure journey', async () => {
      const workflowId = 'journey-test-workflow';
      const steps = ['validate-input', 'process-payment', 'send-confirmation', 'update-inventory'];
      
      // Simulate workflow execution with failures
      const workflowJourney = {
        id: workflowId,
        status: 'running',
        currentStep: 0,
        steps: steps.map(step => ({ name: step, status: 'pending', attempts: 0 })),
        startedAt: Date.now(),
      };

      await firestoreHelper.getAdapter().create('workflow_journeys', workflowJourney);

      // Simulate step failures and retries
      for (let stepIndex = 0; stepIndex < steps.length; stepIndex++) {
        const stepName = steps[stepIndex];
        let success = false;
        let attempts = 0;

        while (!success && attempts < 3) {
          attempts++;
          
          // Simulate random failure (60% success rate)
          success = Math.random() > 0.4;

          if (!success) {
            // Log failure attempt
            await redisHelper.getAdapter().increment('step_failures', `${workflowId}:${stepName}`);
            
            // Store failure details
            await firestoreHelper.getAdapter().create('step_failures', {
              id: `${workflowId}-${stepName}-${attempts}`,
              workflowId,
              stepName,
              attempt: attempts,
              errorMessage: 'Simulated failure',
              failedAt: Date.now(),
            });

            if (attempts >= 3) {
              // Send to DLQ after max retries
              const error = new Error(`Step ${stepName} failed after ${attempts} attempts`);
              const config: DLQConfig = { maxRetries: 3 };

              await sendToDLQ(mockContext, 'dlq-journey', config, error, stepName);
              
              // Update workflow status to failed
              await firestoreHelper.getAdapter().update('workflow_journeys', workflowId, {
                status: 'failed',
                failedStep: stepName,
                failedAt: Date.now(),
              });
              break;
            }
          } else {
            // Update successful step
            await firestoreHelper.getAdapter().update('workflow_journeys', workflowId, {
              [`steps.${stepIndex}.status`]: 'completed',
              [`steps.${stepIndex}.attempts`]: attempts,
              currentStep: stepIndex + 1,
            });
          }
        }

        if (!success) break; // Workflow failed
      }

      // Verify journey tracking
      const journey = await firestoreHelper.getAdapter().findUnique('workflow_journeys', { id: workflowId });
      expect(journey).toBeTruthy();
      
      // Check failure statistics
      const totalFailures = await redisHelper.getAdapter().findMany('step_failures');
      expect(totalFailures.length).toBeGreaterThan(0);
    });

    it('should support workflow recovery from DLQ', async () => {
      const originalWorkflow = {
        id: 'recovery-workflow-123',
        orderId: 'order-recovery-456',
        customerId: 'customer-789',
        status: 'failed',
        failedStep: 'payment-processing',
        failedAt: Date.now() - 3600000, // Failed 1 hour ago
        originalPayload: {
          amount: 149.99,
          currency: 'USD',
          paymentMethod: 'credit_card',
        },
      };

      // Store failed workflow
      await firestoreHelper.getAdapter().create('failed_workflows', originalWorkflow);

      // Create DLQ record for recovery
      const dlqRecord = {
        id: `dlq-${originalWorkflow.id}`,
        originalWorkflowRunId: originalWorkflow.id,
        failedStep: originalWorkflow.failedStep,
        errorCategory: 'network',
        isRetryable: true,
        retryCount: 2,
        originalPayload: originalWorkflow.originalPayload,
        status: 'pending_retry',
      };

      await firestoreHelper.getAdapter().create('dlq_recovery', dlqRecord);

      // Simulate successful recovery
      const recoveryResult = {
        recoveredAt: Date.now(),
        recoveryMethod: 'manual_retry',
        newWorkflowRunId: `${originalWorkflow.id}-recovery`,
        recoveryStatus: 'success',
      };

      // Update workflow status
      await firestoreHelper.getAdapter().update('failed_workflows', originalWorkflow.id, {
        status: 'recovered',
        recoveredAt: recoveryResult.recoveredAt,
        recoveryWorkflowId: recoveryResult.newWorkflowRunId,
      });

      // Update DLQ record
      await firestoreHelper.getAdapter().update('dlq_recovery', dlqRecord.id, {
        status: 'recovered',
        ...recoveryResult,
      });

      // Add to recovered workflows tracking
      await redisHelper.getAdapter().setAdd('recovered_workflows', 'today', originalWorkflow.id);
      await redisHelper.getAdapter().increment('recovery_stats', 'successful_recoveries');

      // Verify recovery tracking
      const recoveredWorkflow = await firestoreHelper.getAdapter().findUnique('failed_workflows', {
        id: originalWorkflow.id
      });
      expect(recoveredWorkflow?.status).toBe('recovered');
      expect(recoveredWorkflow?.recoveryWorkflowId).toBe(recoveryResult.newWorkflowRunId);

      const recoveryStats = await redisHelper.getAdapter().increment('recovery_stats', 'successful_recoveries', undefined, 0);
      expect(recoveryStats).toBe(1);

      const todaysRecoveries = await redisHelper.getAdapter().setMembers('recovered_workflows', 'today');
      expect(todaysRecoveries).toContain(originalWorkflow.id);
    });
  });
});