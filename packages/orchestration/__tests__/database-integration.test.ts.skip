import { describe, it, expect, beforeEach, afterEach, vi } from 'vitest';
import {
  mockUpstashRedisAdapter,
  mockFirestoreAdapter,
  resetMockRedisStorage,
  resetMockFirestoreStorage,
  RedisDatabaseTestHelper,
  DatabaseTestHelper,
  createTestUser,
} from '@repo/testing';

// Mock the database modules
vi.mock('@upstash/redis', async () => {
  const { mockUpstashRedis } = await import('@repo/testing');
  return mockUpstashRedis;
});

vi.mock('firebase-admin', async () => {
  const { mockFirebaseAdmin } = await import('@repo/testing');
  return mockFirebaseAdmin;
});

describe('Orchestration Database Integration', () => {
  let redisHelper: RedisDatabaseTestHelper;
  let firestoreHelper: DatabaseTestHelper;

  beforeEach(async () => {
    resetMockRedisStorage();
    resetMockFirestoreStorage();

    redisHelper = new RedisDatabaseTestHelper(mockUpstashRedisAdapter);
    firestoreHelper = new DatabaseTestHelper(mockFirestoreAdapter, {
      provider: 'firestore',
    });

    await redisHelper.setup();
    await firestoreHelper.setup();
  });

  afterEach(async () => {
    await redisHelper.cleanup();
    await firestoreHelper.cleanup();

    resetMockRedisStorage();
    resetMockFirestoreStorage();
  });

  describe('Basic Database Operations', () => {
    it('should store and retrieve workflow state in Firestore', async () => {
      const workflowState = {
        id: 'workflow-123',
        status: 'running',
        startedAt: Date.now(),
        steps: ['init', 'process', 'complete'],
        currentStep: 'process',
      };

      await firestoreHelper.getAdapter().create('workflow_states', workflowState);

      const retrieved = await firestoreHelper.getAdapter().findUnique('workflow_states', {
        id: 'workflow-123'
      });

      expect(retrieved).toBeTruthy();
      expect(retrieved?.status).toBe('running');
      expect(retrieved?.currentStep).toBe('process');
    });

    it('should cache workflow data in Redis', async () => {
      const cacheData = {
        id: 'cache-key-456',
        workflowId: 'workflow-456',
        progress: 50,
        lastUpdated: Date.now(),
      };

      await redisHelper.getAdapter().create('workflow_cache', cacheData);

      const cached = await redisHelper.getAdapter().findUnique('workflow_cache', {
        id: 'cache-key-456'
      });

      expect(cached).toBeTruthy();
      expect(cached?.progress).toBe(50);
      expect(cached?.workflowId).toBe('workflow-456');
    });

    it('should handle workflow error tracking', async () => {
      const errorRecord = {
        id: 'error-789',
        workflowId: 'failed-workflow-789',
        stepName: 'api-call',
        errorMessage: 'Network timeout',
        timestamp: Date.now(),
        retryCount: 2,
      };

      await firestoreHelper.getAdapter().create('workflow_errors', errorRecord);

      // Also track in Redis for quick access
      await redisHelper.getAdapter().create('error_cache', {
        id: errorRecord.workflowId,
        lastError: errorRecord.errorMessage,
        retryCount: errorRecord.retryCount,
      });

      const storedError = await firestoreHelper.getAdapter().findUnique('workflow_errors', {
        id: 'error-789'
      });
      expect(storedError?.errorMessage).toBe('Network timeout');

      const cachedError = await redisHelper.getAdapter().findUnique('error_cache', {
        id: 'failed-workflow-789'
      });
      expect(cachedError?.retryCount).toBe(2);
    });

    it('should support workflow metrics aggregation', async () => {
      const metrics = [
        { id: 'metric-1', workflowType: 'data-processing', duration: 1500, success: true },
        { id: 'metric-2', workflowType: 'data-processing', duration: 2000, success: true },
        { id: 'metric-3', workflowType: 'user-onboarding', duration: 800, success: false },
      ];

      // Store detailed metrics in Firestore
      for (const metric of metrics) {
        await firestoreHelper.getAdapter().create('workflow_metrics', metric);
      }

      // Track aggregated counts in Redis
      await redisHelper.getAdapter().create('metric_counters', {
        id: 'data-processing',
        totalRuns: 2,
        successCount: 2,
        avgDuration: 1750,
      });

      await redisHelper.getAdapter().create('metric_counters', {
        id: 'user-onboarding', 
        totalRuns: 1,
        successCount: 0,
        avgDuration: 800,
      });

      const detailedMetrics = await firestoreHelper.getAdapter().findMany('workflow_metrics');
      expect(detailedMetrics).toHaveLength(3);

      const dataProcessingStats = await redisHelper.getAdapter().findUnique('metric_counters', {
        id: 'data-processing'
      });
      expect(dataProcessingStats?.successCount).toBe(2);
      expect(dataProcessingStats?.avgDuration).toBe(1750);
    });
  });

  describe('Workflow Deduplication Patterns', () => {
    it('should prevent duplicate workflow execution', async () => {
      const workflowRequest = {
        id: 'dedup-test-123',
        orderId: 'order-456',
        userId: 'user-789',
        requestedAt: Date.now(),
      };

      // Store the original request
      await firestoreHelper.getAdapter().create('workflow_requests', workflowRequest);

      // Mark as processed in Redis for fast duplicate checking
      await redisHelper.getAdapter().create('processed_requests', {
        id: workflowRequest.orderId,
        workflowId: workflowRequest.id,
        processedAt: Date.now(),
      });

      // Simulate duplicate request
      const duplicateCheck = await redisHelper.getAdapter().findUnique('processed_requests', {
        id: 'order-456'
      });

      expect(duplicateCheck).toBeTruthy();
      expect(duplicateCheck?.workflowId).toBe('dedup-test-123');

      // Should not create duplicate workflow
      const existingWorkflow = await firestoreHelper.getAdapter().findUnique('workflow_requests', {
        id: 'dedup-test-123'
      });
      expect(existingWorkflow).toBeTruthy();
    });

    it('should handle workflow state transitions', async () => {
      const workflowId = 'transition-test-456';
      const initialState = {
        id: workflowId,
        status: 'pending',
        currentStep: 0,
        steps: ['validate', 'process', 'complete'],
        updatedAt: Date.now(),
      };

      await firestoreHelper.getAdapter().create('workflow_transitions', initialState);

      // Transition to next step
      const updatedState = {
        ...initialState,
        status: 'running',
        currentStep: 1,
        updatedAt: Date.now() + 1000,
      };

      await firestoreHelper.getAdapter().update('workflow_transitions', workflowId, {
        status: 'running',
        currentStep: 1,
        updatedAt: updatedState.updatedAt,
      });

      // Update Redis cache
      await redisHelper.getAdapter().create('active_workflows', {
        id: workflowId,
        status: 'running',
        progress: 33, // 1/3 steps complete
        lastUpdate: updatedState.updatedAt,
      });

      const finalState = await firestoreHelper.getAdapter().findUnique('workflow_transitions', {
        id: workflowId
      });
      expect(finalState?.status).toBe('running');
      expect(finalState?.currentStep).toBe(1);

      const cachedState = await redisHelper.getAdapter().findUnique('active_workflows', {
        id: workflowId
      });
      expect(cachedState?.progress).toBe(33);
    });
  });

  describe('Error Recovery and DLQ Integration', () => {
    it('should store failed workflows for retry', async () => {
      const failedWorkflow = {
        id: 'failed-workflow-789',
        originalRequest: { orderId: 'order-123', amount: 99.99 },
        failedStep: 'payment-processing',
        errorMessage: 'Payment gateway timeout',
        failedAt: Date.now(),
        retryCount: 2,
        isRetryable: true,
      };

      // Store in Firestore for persistence
      await firestoreHelper.getAdapter().create('failed_workflows', failedWorkflow);

      // Add to retry queue in Redis
      await redisHelper.getAdapter().create('retry_queue', {
        id: failedWorkflow.id,
        retryAfter: Date.now() + 300000, // Retry in 5 minutes
        priority: failedWorkflow.isRetryable ? 'high' : 'low',
      });

      const storedFailure = await firestoreHelper.getAdapter().findUnique('failed_workflows', {
        id: 'failed-workflow-789'
      });
      expect(storedFailure?.errorMessage).toBe('Payment gateway timeout');
      expect(storedFailure?.retryCount).toBe(2);

      const queuedRetry = await redisHelper.getAdapter().findUnique('retry_queue', {
        id: 'failed-workflow-789'
      });
      expect(queuedRetry?.priority).toBe('high');
    });

    it('should track workflow recovery success', async () => {
      const recoveryRecord = {
        id: 'recovery-success-456',
        originalWorkflowId: 'failed-workflow-789',
        recoveryMethod: 'manual_retry',
        recoveredAt: Date.now(),
        newWorkflowId: 'recovered-workflow-101',
        recoverySuccess: true,
      };

      await firestoreHelper.getAdapter().create('workflow_recoveries', recoveryRecord);

      // Update success metrics in Redis
      await redisHelper.getAdapter().create('recovery_stats', {
        id: 'daily_stats',
        totalRecoveries: 1,
        successfulRecoveries: 1,
        successRate: 100,
        lastUpdated: Date.now(),
      });

      const recovery = await firestoreHelper.getAdapter().findUnique('workflow_recoveries', {
        id: 'recovery-success-456'
      });
      expect(recovery?.recoverySuccess).toBe(true);
      expect(recovery?.newWorkflowId).toBe('recovered-workflow-101');

      const stats = await redisHelper.getAdapter().findUnique('recovery_stats', {
        id: 'daily_stats'
      });
      expect(stats?.successRate).toBe(100);
    });
  });

  describe('Performance and Monitoring', () => {
    it('should track workflow execution performance', async () => {
      const performanceData = {
        id: 'perf-data-123',
        workflowType: 'image-processing',
        startTime: Date.now() - 5000,
        endTime: Date.now(),
        duration: 5000,
        memoryUsed: 128,
        cpuUsed: 75,
        success: true,
      };

      await firestoreHelper.getAdapter().create('performance_data', performanceData);

      // Update real-time metrics in Redis
      await redisHelper.getAdapter().create('performance_metrics', {
        id: 'image-processing',
        avgDuration: 5000,
        totalExecutions: 1,
        successCount: 1,
        lastUpdated: Date.now(),
      });

      const stored = await firestoreHelper.getAdapter().findUnique('performance_data', {
        id: 'perf-data-123'
      });
      expect(stored?.duration).toBe(5000);
      expect(stored?.success).toBe(true);

      const metrics = await redisHelper.getAdapter().findUnique('performance_metrics', {
        id: 'image-processing'
      });
      expect(metrics?.avgDuration).toBe(5000);
      expect(metrics?.successCount).toBe(1);
    });

    it('should maintain workflow audit trail', async () => {
      const auditEvents = [
        {
          id: 'audit-1',
          workflowId: 'audit-workflow-123',
          eventType: 'workflow_started',
          timestamp: Date.now() - 2000,
          details: { triggeredBy: 'api_request' },
        },
        {
          id: 'audit-2',
          workflowId: 'audit-workflow-123',
          eventType: 'step_completed',
          timestamp: Date.now() - 1000,
          details: { stepName: 'validation', duration: 500 },
        },
        {
          id: 'audit-3',
          workflowId: 'audit-workflow-123',
          eventType: 'workflow_completed',
          timestamp: Date.now(),
          details: { totalDuration: 2000, success: true },
        },
      ];

      // Store audit trail in Firestore
      for (const event of auditEvents) {
        await firestoreHelper.getAdapter().create('audit_trail', event);
      }

      // Cache recent events in Redis
      await redisHelper.getAdapter().create('recent_events', {
        id: 'audit-workflow-123',
        lastEvent: 'workflow_completed',
        eventCount: 3,
        lastUpdated: Date.now(),
      });

      const auditTrail = await firestoreHelper.getAdapter().findMany('audit_trail', {
        where: { workflowId: 'audit-workflow-123' },
      });
      expect(auditTrail).toHaveLength(3);

      const recentEvent = await redisHelper.getAdapter().findUnique('recent_events', {
        id: 'audit-workflow-123'
      });
      expect(recentEvent?.lastEvent).toBe('workflow_completed');
      expect(recentEvent?.eventCount).toBe(3);
    });
  });
});