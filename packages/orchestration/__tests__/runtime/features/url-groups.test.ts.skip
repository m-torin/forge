import { beforeEach, describe, expect, it, vi } from 'vitest';

import {
  createURLGroupManager,
  extractParams,
  matchURL,
  type URLGroup,
  URLGroupManager,
  type URLPattern,
} from '../../../src/runtime/features/url-groups';

describe('URL Groups', () => {
  describe('matchURL', () => {
    it('should match exact URLs', () => {
      const pattern: URLPattern = {
        exact: true,
        pattern: 'https://api.example.com/users',
      };

      expect(matchURL('https://api.example.com/users', pattern)).toBe(true);
      expect(matchURL('https://api.example.com/users/', pattern)).toBe(false);
      expect(matchURL('https://api.example.com/users/123', pattern)).toBe(false);
    });

    it('should match with wildcards', () => {
      const pattern: URLPattern = {
        pattern: 'https://api.example.com/users/*',
      };

      expect(matchURL('https://api.example.com/users/123', pattern)).toBe(true);
      expect(matchURL('https://api.example.com/users/456', pattern)).toBe(true);
      expect(matchURL('https://api.example.com/users', pattern)).toBe(false);
    });

    it('should match with multiple wildcards', () => {
      const pattern: URLPattern = {
        pattern: 'https://api.example.com/*/posts/*',
      };

      expect(matchURL('https://api.example.com/users/posts/123', pattern)).toBe(true);
      expect(matchURL('https://api.example.com/admin/posts/456', pattern)).toBe(true);
      expect(matchURL('https://api.example.com/posts/123', pattern)).toBe(false);
    });

    it('should match with regex', () => {
      const pattern: URLPattern = {
        pattern: /^https:\/\/api\.example\.com\/users\/\d+$/,
      };

      expect(matchURL('https://api.example.com/users/123', pattern)).toBe(true);
      expect(matchURL('https://api.example.com/users/456', pattern)).toBe(true);
      expect(matchURL('https://api.example.com/users/abc', pattern)).toBe(false);
    });

    it('should match with query parameters', () => {
      const pattern: URLPattern = {
        pattern: 'https://api.example.com/search',
        queryParams: {
          limit: '10',
          q: 'test',
        },
      };

      expect(matchURL('https://api.example.com/search?q=test&limit=10', pattern)).toBe(true);
      expect(matchURL('https://api.example.com/search?limit=10&q=test', pattern)).toBe(true);
      expect(matchURL('https://api.example.com/search?q=test', pattern)).toBe(false);
    });

    it('should match with partial query parameters', () => {
      const pattern: URLPattern = {
        matchAllParams: false,
        pattern: 'https://api.example.com/search',
        queryParams: {
          q: 'test',
        },
      };

      expect(matchURL('https://api.example.com/search?q=test&limit=10', pattern)).toBe(true);
      expect(matchURL('https://api.example.com/search?q=test', pattern)).toBe(true);
      expect(matchURL('https://api.example.com/search?q=other', pattern)).toBe(false);
    });

    it('should match with methods', () => {
      const pattern: URLPattern = {
        methods: ['GET', 'POST'],
        pattern: 'https://api.example.com/users',
      };

      expect(matchURL('https://api.example.com/users', pattern, 'GET')).toBe(true);
      expect(matchURL('https://api.example.com/users', pattern, 'POST')).toBe(true);
      expect(matchURL('https://api.example.com/users', pattern, 'DELETE')).toBe(false);
    });
  });

  describe('extractParams', () => {
    it('should extract path parameters', () => {
      const pattern = 'https://api.example.com/users/:id';
      const url = 'https://api.example.com/users/123';

      const params = extractParams(url, pattern);
      expect(params).toEqual({ id: '123' });
    });

    it('should extract multiple parameters', () => {
      const pattern = 'https://api.example.com/users/:userId/posts/:postId';
      const url = 'https://api.example.com/users/456/posts/789';

      const params = extractParams(url, pattern);
      expect(params).toEqual({ postId: '789', userId: '456' });
    });

    it('should handle optional parameters', () => {
      const pattern = 'https://api.example.com/users/:id/:action?';
      
      const params1 = extractParams('https://api.example.com/users/123/edit', pattern);
      expect(params1).toEqual({ id: '123', action: 'edit' });

      const params2 = extractParams('https://api.example.com/users/123', pattern);
      expect(params2).toEqual({ id: '123' });
    });

    it('should extract query parameters', () => {
      const pattern = 'https://api.example.com/search';
      const url = 'https://api.example.com/search?q=test&page=2&limit=10';

      const params = extractParams(url, pattern);
      expect(params.q).toBe('test');
      expect(params.page).toBe('2');
      expect(params.limit).toBe('10');
    });

    it('should combine path and query parameters', () => {
      const pattern = 'https://api.example.com/users/:id';
      const url = 'https://api.example.com/users/123?include=posts&sort=desc';

      const params = extractParams(url, pattern);
      expect(params).toEqual({
        id: '123',
        include: 'posts',
        sort: 'desc',
      });
    });
  });

  describe('createURLGroupManager', () => {
    it('should create a URL group manager', () => {
      const manager = createURLGroupManager();
      expect(manager).toBeInstanceOf(URLGroupManager);
    });

    it('should create with initial groups', () => {
      const groups: URLGroup[] = [
        {
          name: 'api-v1',
          patterns: [
            { pattern: 'https://api.example.com/v1/*' },
          ],
        },
      ];

      const manager = createURLGroupManager(groups);
      expect(manager.getGroup('api-v1')).toBeDefined();
    });
  });

  describe('URLGroupManager', () => {
    let manager: URLGroupManager;

    beforeEach(() => {
      manager = new URLGroupManager();
    });

    describe('addGroup', () => {
      it('should add a URL group', () => {
        const group: URLGroup = {
          name: 'users-api',
          patterns: [
            { pattern: 'https://api.example.com/users/*' },
            { pattern: 'https://api.example.com/user/*' },
          ],
        };

        manager.addGroup(group);
        expect(manager.getGroup('users-api')).toEqual(group);
      });

      it('should throw for duplicate group name', () => {
        const group: URLGroup = {
          name: 'test-group',
          patterns: [{ pattern: 'https://example.com/*' }],
        };

        manager.addGroup(group);
        expect(() => manager.addGroup(group)).toThrow('Group test-group already exists');
      });

      it('should add group with metadata', () => {
        const group: URLGroup = {
          name: 'api-endpoints',
          metadata: {
            auth: 'required',
            rateLimit: 100,
            version: 'v1',
          },
          patterns: [{ pattern: 'https://api.example.com/*' }],
        };

        manager.addGroup(group);
        const retrieved = manager.getGroup('api-endpoints');
        expect(retrieved?.metadata).toEqual({
          auth: 'required',
          rateLimit: 100,
          version: 'v1',
        });
      });
    });

    describe('removeGroup', () => {
      it('should remove a group', () => {
        const group: URLGroup = {
          name: 'test-group',
          patterns: [{ pattern: 'https://example.com/*' }],
        };

        manager.addGroup(group);
        manager.removeGroup('test-group');
        expect(manager.getGroup('test-group')).toBeUndefined();
      });

      it('should not throw for non-existent group', () => {
        expect(() => manager.removeGroup('non-existent')).not.toThrow();
      });
    });

    describe('matchGroups', () => {
      beforeEach(() => {
        manager.addGroup({
          name: 'users-api',
          patterns: [
            { pattern: 'https://api.example.com/users/*' },
            { pattern: 'https://api.example.com/user/*' },
          ],
        });

        manager.addGroup({
          name: 'posts-api',
          patterns: [
            { pattern: 'https://api.example.com/posts/*' },
            { pattern: 'https://api.example.com/blog/*' },
          ],
        });

        manager.addGroup({
          name: 'admin-api',
          patterns: [
            { methods: ['GET', 'POST'], pattern: 'https://api.example.com/admin/*' },
          ],
        });
      });

      it('should match URL to groups', () => {
        const groups = manager.matchGroups('https://api.example.com/users/123');
        expect(groups).toHaveLength(1);
        expect(groups[0].name).toBe('users-api');
      });

      it('should match multiple groups', () => {
        manager.addGroup({
          name: 'all-api',
          patterns: [{ pattern: 'https://api.example.com/*' }],
        });

        const groups = manager.matchGroups('https://api.example.com/users/123');
        expect(groups).toHaveLength(2);
        expect(groups.map(g => g.name)).toContain('users-api');
        expect(groups.map(g => g.name)).toContain('all-api');
      });

      it('should respect method matching', () => {
        const getGroups = manager.matchGroups('https://api.example.com/admin/users', 'GET');
        expect(getGroups).toHaveLength(1);
        expect(getGroups[0].name).toBe('admin-api');

        const deleteGroups = manager.matchGroups('https://api.example.com/admin/users', 'DELETE');
        expect(deleteGroups).toHaveLength(0);
      });

      it('should return empty array for no matches', () => {
        const groups = manager.matchGroups('https://other.example.com/data');
        expect(groups).toEqual([]);
      });
    });

    describe('findGroup', () => {
      beforeEach(() => {
        manager.addGroup({
          name: 'high-priority',
          metadata: { priority: 1 },
          patterns: [{ pattern: 'https://api.example.com/critical/*' }],
        });

        manager.addGroup({
          name: 'medium-priority',
          metadata: { priority: 2 },
          patterns: [{ pattern: 'https://api.example.com/*' }],
        });

        manager.addGroup({
          name: 'low-priority',
          metadata: { priority: 3 },
          patterns: [{ pattern: 'https://*.example.com/*' }],
        });
      });

      it('should find first matching group', () => {
        const group = manager.findGroup('https://api.example.com/critical/operation');
        expect(group?.name).toBe('high-priority');
      });

      it('should find by priority order', () => {
        const group = manager.findGroup('https://api.example.com/normal/operation');
        expect(group?.name).toBe('medium-priority');
      });

      it('should return undefined for no match', () => {
        const group = manager.findGroup('https://other.com/data');
        expect(group).toBeUndefined();
      });
    });

    describe('updateGroup', () => {
      it('should update an existing group', () => {
        manager.addGroup({
          name: 'test-group',
          patterns: [{ pattern: 'https://old.example.com/*' }],
        });

        manager.updateGroup('test-group', {
          metadata: { updated: true },
          patterns: [{ pattern: 'https://new.example.com/*' }],
        });

        const updated = manager.getGroup('test-group');
        expect(updated?.patterns[0].pattern).toBe('https://new.example.com/*');
        expect(updated?.metadata?.updated).toBe(true);
      });

      it('should throw for non-existent group', () => {
        expect(() => manager.updateGroup('non-existent', {}))
          .toThrow('Group non-existent not found');
      });
    });

    describe('listGroups', () => {
      it('should list all groups', () => {
        manager.addGroup({
          name: 'group1',
          patterns: [{ pattern: 'https://example1.com/*' }],
        });

        manager.addGroup({
          name: 'group2',
          patterns: [{ pattern: 'https://example2.com/*' }],
        });

        const groups = manager.listGroups();
        expect(groups).toHaveLength(2);
        expect(groups.map(g => g.name)).toEqual(['group1', 'group2']);
      });

      it('should return empty array when no groups', () => {
        expect(manager.listGroups()).toEqual([]);
      });
    });

    describe('middleware integration', () => {
      it('should create middleware for Express-like frameworks', () => {
        manager.addGroup({
          name: 'rate-limited',
          metadata: { rateLimit: 10 },
          patterns: [{ pattern: 'https://api.example.com/limited/*' }],
        });

        const middleware = manager.createMiddleware((group, req, res, next) => {
          if (group?.metadata?.rateLimit) {
            res.setHeader('X-Rate-Limit', group.metadata.rateLimit.toString());
          }
          next();
        });

        // Mock request/response
        const req = { url: 'https://api.example.com/limited/resource', method: 'GET' };
        const res = { setHeader: vi.fn() };
        const next = vi.fn();

        middleware(req as any, res as any, next);

        expect(res.setHeader).toHaveBeenCalledWith('X-Rate-Limit', '10');
        expect(next).toHaveBeenCalled();
      });
    });

    describe('pattern validation', () => {
      it('should validate URL patterns', () => {
        const validPatterns = [
          'https://example.com/path',
          'https://example.com/*',
          'https://*.example.com/*',
          'https://example.com/users/:id',
          /^https:\/\/example\.com\/.*/,
        ];

        validPatterns.forEach(pattern => {
          expect(() => manager.addGroup({
            name: 'test',
            patterns: [{ pattern }],
          })).not.toThrow();
          manager.removeGroup('test');
        });
      });

      it('should reject invalid patterns', () => {
        const invalidPatterns = [
          '',
          'not-a-url',
          'ftp://example.com', // Non-HTTP protocol
        ];

        invalidPatterns.forEach(pattern => {
          expect(() => manager.addGroup({
            name: 'test',
            patterns: [{ pattern }],
          })).toThrow();
        });
      });
    });

    describe('performance', () => {
      it('should handle large number of groups efficiently', () => {
        // Add 1000 groups
        for (let i = 0; i < 1000; i++) {
          manager.addGroup({
            name: `group-${i}`,
            patterns: [
              { pattern: `https://api${i}.example.com/*` },
              { pattern: `https://api.example.com/v${i}/*` },
            ],
          });
        }

        const start = Date.now();
        const matches = manager.matchGroups('https://api500.example.com/users');
        const duration = Date.now() - start;

        expect(matches).toHaveLength(1);
        expect(duration).toBeLessThan(10); // Should be fast
      });
    });

    describe('export/import', () => {
      it('should export groups', () => {
        manager.addGroup({
          name: 'group1',
          metadata: { version: 1 },
          patterns: [{ pattern: 'https://example1.com/*' }],
        });

        manager.addGroup({
          name: 'group2',
          patterns: [{ pattern: 'https://example2.com/*' }],
        });

        const exported = manager.export();
        expect(exported).toHaveLength(2);
        expect(exported[0]).toMatchObject({
          name: 'group1',
          metadata: { version: 1 },
          patterns: [{ pattern: 'https://example1.com/*' }],
        });
      });

      it('should import groups', () => {
        const groups: URLGroup[] = [
          {
            name: 'imported1',
            patterns: [{ pattern: 'https://imported1.com/*' }],
          },
          {
            name: 'imported2',
            patterns: [{ pattern: 'https://imported2.com/*' }],
          },
        ];

        manager.import(groups);

        expect(manager.getGroup('imported1')).toBeDefined();
        expect(manager.getGroup('imported2')).toBeDefined();
      });

      it('should clear existing groups on import with replace option', () => {
        manager.addGroup({
          name: 'existing',
          patterns: [{ pattern: 'https://existing.com/*' }],
        });

        const groups: URLGroup[] = [
          {
            name: 'new',
            patterns: [{ pattern: 'https://new.com/*' }],
          },
        ];

        manager.import(groups, { replace: true });

        expect(manager.getGroup('existing')).toBeUndefined();
        expect(manager.getGroup('new')).toBeDefined();
      });
    });
  });
});