import { afterEach, beforeEach, describe, expect, it, vi } from 'vitest';

import {
  createScheduler,
  getNextRunTime,
  parseSchedule,
  type Schedule,
  Scheduler,
  validateCron,
} from '../../../src/runtime/features/schedules';

// Mock timers for testing
vi.useFakeTimers();

describe('Schedules', () => {
  afterEach(() => {
    vi.clearAllTimers();
  });

  describe('validateCron', () => {
    it('should validate correct cron expressions', () => {
      const validExpressions = [
        '* * * * *',           // Every minute
        '*/5 * * * *',         // Every 5 minutes
        '0 0 * * *',           // Daily at midnight
        '0 0 * * 1',           // Every Monday
        '0 0 1 * *',           // First day of month
        '30 2 * * 1-5',        // Weekdays at 2:30 AM
        '0 */4 * * *',         // Every 4 hours
        '15,45 * * * *',       // At 15 and 45 minutes
        '0 0 1 1 *',           // January 1st
      ];

      validExpressions.forEach(expr => {
        expect(validateCron(expr)).toBe(true);
      });
    });

    it('should reject invalid cron expressions', () => {
      const invalidExpressions = [
        '',                    // Empty
        '* * * *',            // Missing field
        '* * * * * *',        // Too many fields
        '60 * * * *',         // Invalid minute
        '* 24 * * *',         // Invalid hour
        '* * 32 * *',         // Invalid day
        '* * * 13 *',         // Invalid month
        '* * * * 8',          // Invalid day of week
        'not a cron',         // Invalid format
      ];

      invalidExpressions.forEach(expr => {
        expect(validateCron(expr)).toBe(false);
      });
    });
  });

  describe('parseSchedule', () => {
    it('should parse cron expression', () => {
      const schedule = parseSchedule('*/5 * * * *');
      expect(schedule.type).toBe('cron');
      expect(schedule.expression).toBe('*/5 * * * *');
    });

    it('should parse interval schedule', () => {
      const schedule = parseSchedule('every 5 minutes');
      expect(schedule.type).toBe('interval');
      expect(schedule.interval).toBe(300000); // 5 minutes in ms
    });

    it('should parse various interval formats', () => {
      const intervals = [
        { expected: 30000, input: 'every 30 seconds' },
        { expected: 60000, input: 'every 1 minute' },
        { expected: 7200000, input: 'every 2 hours' },
        { expected: 86400000, input: 'every 1 day' },
        { expected: 604800000, input: 'every 1 week' },
      ];

      intervals.forEach(({ expected, input }) => {
        const schedule = parseSchedule(input);
        expect(schedule.type).toBe('interval');
        expect(schedule.interval).toBe(expected);
      });
    });

    it('should parse rate schedule', () => {
      const schedule = parseSchedule('rate(5 minutes)');
      expect(schedule.type).toBe('rate');
      expect(schedule.rate).toBe(300000);
    });

    it('should parse at schedule', () => {
      const schedule = parseSchedule('at 2:30 PM');
      expect(schedule.type).toBe('at');
      expect(schedule.time).toBe('14:30');
    });

    it('should throw for invalid schedule', () => {
      expect(() => parseSchedule('invalid schedule')).toThrow('Invalid schedule format');
    });
  });

  describe('getNextRunTime', () => {
    const baseTime = new Date('2024-01-15T10:00:00Z');

    beforeEach(() => {
      vi.setSystemTime(baseTime);
    });

    it('should calculate next run for cron', () => {
      const schedule: Schedule = {
        type: 'cron',
        expression: '0 * * * *', // Every hour on the hour
      };

      const next = getNextRunTime(schedule);
      expect(next).toEqual(new Date('2024-01-15T11:00:00Z'));
    });

    it('should calculate next run for interval', () => {
      const schedule: Schedule = {
        type: 'interval',
        interval: 300000, // 5 minutes
      };

      const next = getNextRunTime(schedule);
      expect(next).toEqual(new Date('2024-01-15T10:05:00Z'));
    });

    it('should calculate next run for specific time', () => {
      const schedule: Schedule = {
        type: 'at',
        time: '15:30',
      };

      const next = getNextRunTime(schedule);
      expect(next).toEqual(new Date('2024-01-15T15:30:00Z'));
    });

    it('should handle time already passed for today', () => {
      const schedule: Schedule = {
        type: 'at',
        time: '08:00',
      };

      const next = getNextRunTime(schedule);
      expect(next).toEqual(new Date('2024-01-16T08:00:00Z'));
    });
  });

  describe('createScheduler', () => {
    it('should create a scheduler', () => {
      const scheduler = createScheduler();
      expect(scheduler).toBeInstanceOf(Scheduler);
    });

    it('should create scheduler with config', () => {
      const scheduler = createScheduler({
        maxConcurrent: 5,
        timezone: 'America/New_York',
      });
      expect(scheduler).toBeInstanceOf(Scheduler);
    });
  });

  describe('Scheduler', () => {
    let scheduler: Scheduler;

    beforeEach(() => {
      scheduler = new Scheduler();
      vi.setSystemTime(new Date('2024-01-15T10:00:00Z'));
    });

    describe('schedule', () => {
      it('should schedule a job with cron', () => {
        const handler = vi.fn();
        const jobId = scheduler.schedule('test-job', '*/5 * * * *', handler);

        expect(jobId).toBe('test-job');
        expect(scheduler.getJob('test-job')).toBeDefined();
      });

      it('should schedule a job with interval', () => {
        const handler = vi.fn();
        const jobId = scheduler.schedule('test-job', 'every 5 minutes', handler);

        expect(jobId).toBe('test-job');
        expect(scheduler.getJob('test-job')).toBeDefined();
      });

      it('should auto-generate job ID if not provided', () => {
        const handler = vi.fn();
        const jobId = scheduler.schedule(null, 'every 5 minutes', handler);

        expect(jobId).toBeDefined();
        expect(typeof jobId).toBe('string');
      });

      it('should throw for duplicate job ID', () => {
        const handler = vi.fn();
        scheduler.schedule('test-job', 'every 5 minutes', handler);

        expect(() => scheduler.schedule('test-job', 'every 10 minutes', handler))
          .toThrow('Job with ID test-job already exists');
      });

      it('should schedule with options', () => {
        const handler = vi.fn();
        const jobId = scheduler.schedule('test-job', 'every 5 minutes', handler, {
          errorHandler: vi.fn(),
          immediate: true,
          maxRuns: 5,
        });

        const job = scheduler.getJob('test-job');
        expect(job?.options.immediate).toBe(true);
        expect(job?.options.maxRuns).toBe(5);
        expect(job?.options.errorHandler).toBeDefined();
      });
    });

    describe('start/stop', () => {
      it('should start scheduler', () => {
        scheduler.start();
        expect(scheduler.isRunning()).toBe(true);
      });

      it('should stop scheduler', () => {
        scheduler.start();
        scheduler.stop();
        expect(scheduler.isRunning()).toBe(false);
      });

      it('should not run jobs when stopped', () => {
        const handler = vi.fn();
        scheduler.schedule('test-job', 'every 1 second', handler);
        
        // Don't start scheduler
        vi.advanceTimersByTime(5000);
        expect(handler).not.toHaveBeenCalled();
      });

      it('should run jobs when started', () => {
        const handler = vi.fn();
        scheduler.schedule('test-job', 'every 1 second', handler);
        
        scheduler.start();
        vi.advanceTimersByTime(3500);
        
        expect(handler).toHaveBeenCalledTimes(3);
      });
    });

    describe('job execution', () => {
      it('should execute job on schedule', () => {
        const handler = vi.fn();
        scheduler.schedule('test-job', 'every 5 seconds', handler);
        
        scheduler.start();
        
        // Advance time
        vi.advanceTimersByTime(5000);
        expect(handler).toHaveBeenCalledTimes(1);
        
        vi.advanceTimersByTime(5000);
        expect(handler).toHaveBeenCalledTimes(2);
      });

      it('should execute immediate job', () => {
        const handler = vi.fn();
        scheduler.schedule('test-job', 'every 5 seconds', handler, {
          immediate: true,
        });
        
        scheduler.start();
        
        // Should run immediately
        expect(handler).toHaveBeenCalledTimes(1);
        
        // And then on schedule
        vi.advanceTimersByTime(5000);
        expect(handler).toHaveBeenCalledTimes(2);
      });

      it('should respect maxRuns', () => {
        const handler = vi.fn();
        scheduler.schedule('test-job', 'every 1 second', handler, {
          maxRuns: 3,
        });
        
        scheduler.start();
        
        vi.advanceTimersByTime(5000);
        expect(handler).toHaveBeenCalledTimes(3);
        
        // Job should be removed after max runs
        expect(scheduler.getJob('test-job')).toBeUndefined();
      });

      it('should handle job errors', () => {
        const handler = vi.fn().mockRejectedValue(new Error('Job failed'));
        const errorHandler = vi.fn();
        
        scheduler.schedule('test-job', 'every 1 second', handler, {
          errorHandler,
        });
        
        scheduler.start();
        vi.advanceTimersByTime(1000);
        
        expect(handler).toHaveBeenCalled();
        expect(errorHandler).toHaveBeenCalledWith(
          expect.any(Error),
          'test-job'
        );
      });

      it('should continue after errors', () => {
        const handler = vi.fn()
          .mockRejectedValueOnce(new Error('First fail'))
          .mockResolvedValue('success');
        
        scheduler.schedule('test-job', 'every 1 second', handler);
        
        scheduler.start();
        
        vi.advanceTimersByTime(1000);
        expect(handler).toHaveBeenCalledTimes(1);
        
        vi.advanceTimersByTime(1000);
        expect(handler).toHaveBeenCalledTimes(2);
      });
    });

    describe('cancelJob', () => {
      it('should cancel a scheduled job', () => {
        const handler = vi.fn();
        scheduler.schedule('test-job', 'every 1 second', handler);
        
        scheduler.start();
        vi.advanceTimersByTime(2000);
        expect(handler).toHaveBeenCalledTimes(2);
        
        scheduler.cancelJob('test-job');
        vi.advanceTimersByTime(2000);
        expect(handler).toHaveBeenCalledTimes(2); // No more calls
      });

      it('should not throw for non-existent job', () => {
        expect(() => scheduler.cancelJob('non-existent')).not.toThrow();
      });
    });

    describe('pauseJob/resumeJob', () => {
      it('should pause and resume a job', () => {
        const handler = vi.fn();
        scheduler.schedule('test-job', 'every 1 second', handler);
        
        scheduler.start();
        vi.advanceTimersByTime(2000);
        expect(handler).toHaveBeenCalledTimes(2);
        
        scheduler.pauseJob('test-job');
        vi.advanceTimersByTime(2000);
        expect(handler).toHaveBeenCalledTimes(2); // Paused
        
        scheduler.resumeJob('test-job');
        vi.advanceTimersByTime(1000);
        expect(handler).toHaveBeenCalledTimes(3); // Resumed
      });
    });

    describe('runJob', () => {
      it('should run a job manually', async () => {
        const handler = vi.fn().mockResolvedValue('result');
        scheduler.schedule('test-job', 'every 1 hour', handler);
        
        const result = await scheduler.runJob('test-job');
        
        expect(handler).toHaveBeenCalled();
        expect(result).toBe('result');
      });

      it('should throw for non-existent job', async () => {
        await expect(scheduler.runJob('non-existent'))
          .rejects.toThrow('Job non-existent not found');
      });
    });

    describe('listJobs', () => {
      it('should list all jobs', () => {
        scheduler.schedule('job1', 'every 5 minutes', vi.fn());
        scheduler.schedule('job2', 'every 10 minutes', vi.fn());
        scheduler.schedule('job3', 'every 15 minutes', vi.fn());
        
        const jobs = scheduler.listJobs();
        expect(jobs).toHaveLength(3);
        expect(jobs.map(j => j.id)).toEqual(['job1', 'job2', 'job3']);
      });

      it('should include job details', () => {
        scheduler.schedule('test-job', 'every 5 minutes', vi.fn());
        
        const jobs = scheduler.listJobs();
        expect(jobs[0]).toMatchObject({
          id: 'test-job',
          nextRun: expect.any(Date),
          schedule: expect.any(Object),
          status: 'scheduled',
        });
      });
    });

    describe('getJobStatus', () => {
      it('should get job status', () => {
        const handler = vi.fn();
        scheduler.schedule('test-job', 'every 5 minutes', handler);
        
        scheduler.start();
        const status = scheduler.getJobStatus('test-job');
        
        expect(status).toMatchObject({
          id: 'test-job',
          lastRun: undefined,
          nextRun: expect.any(Date),
          runs: 0,
          status: 'scheduled',
        });
      });

      it('should update status after runs', () => {
        const handler = vi.fn();
        scheduler.schedule('test-job', 'every 1 second', handler);
        
        scheduler.start();
        vi.advanceTimersByTime(2000);
        
        const status = scheduler.getJobStatus('test-job');
        expect(status?.runs).toBe(2);
        expect(status?.lastRun).toBeDefined();
      });
    });

    describe('concurrent execution', () => {
      it('should limit concurrent executions', async () => {
        let runningJobs = 0;
        let maxConcurrent = 0;
        
        const handler = async () => {
          runningJobs++;
          maxConcurrent = Math.max(maxConcurrent, runningJobs);
          await new Promise(resolve => setTimeout(resolve, 100));
          runningJobs--;
        };
        
        const concurrentScheduler = new Scheduler({ maxConcurrent: 2 });
        
        // Schedule multiple jobs
        concurrentScheduler.schedule('job1', 'every 50ms', handler);
        concurrentScheduler.schedule('job2', 'every 50ms', handler);
        concurrentScheduler.schedule('job3', 'every 50ms', handler);
        
        concurrentScheduler.start();
        
        // Let jobs run
        vi.advanceTimersByTime(200);
        await vi.runAllTimersAsync();
        
        expect(maxConcurrent).toBeLessThanOrEqual(2);
      });
    });

    describe('timezone support', () => {
      it('should handle timezone for at schedules', () => {
        const handler = vi.fn();
        const tzScheduler = new Scheduler({ timezone: 'America/New_York' });
        
        tzScheduler.schedule('test-job', 'at 10:00 AM', handler);
        
        const job = tzScheduler.getJob('test-job');
        expect(job).toBeDefined();
        // Timezone conversion would be handled by the actual implementation
      });
    });

    describe('persistence', () => {
      it('should export jobs', () => {
        scheduler.schedule('job1', 'every 5 minutes', vi.fn());
        scheduler.schedule('job2', '0 * * * *', vi.fn());
        
        const exported = scheduler.exportJobs();
        expect(exported).toHaveLength(2);
        expect(exported[0]).toMatchObject({
          id: 'job1',
          schedule: expect.any(Object),
        });
      });

      it('should import jobs', () => {
        const jobs = [
          {
            id: 'imported-job1',
            options: {},
            schedule: { type: 'interval' as const, interval: 300000 },
          },
          {
            id: 'imported-job2',
            options: {},
            schedule: { type: 'cron' as const, expression: '0 * * * *' },
          },
        ];
        
        const handlers = {
          'imported-job1': vi.fn(),
          'imported-job2': vi.fn(),
        };
        
        scheduler.importJobs(jobs, handlers);
        
        expect(scheduler.getJob('imported-job1')).toBeDefined();
        expect(scheduler.getJob('imported-job2')).toBeDefined();
      });
    });
  });
});