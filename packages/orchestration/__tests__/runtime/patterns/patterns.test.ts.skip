import { beforeEach, describe, expect, it, vi } from 'vitest';

import {
  bulkhead,
  circuitBreaker,
  cqrs,
  createPattern,
  distributedLock,
  eventSourcing,
  leaderElection,
  messageQueue,
  type Pattern,
  PatternRegistry,
  pubsub,
  rateLimiter,
  saga,
} from '../../../src/runtime/patterns/patterns';

describe('Workflow Patterns', () => {
  describe('createPattern', () => {
    it('should create a custom pattern', () => {
      const customPattern = createPattern({
        name: 'custom-pattern',
        execute: async (context) => {
          return { ...context, processed: true };
        },
      });

      expect(customPattern.name).toBe('custom-pattern');
      expect(typeof customPattern.execute).toBe('function');
    });

    it('should execute custom pattern', async () => {
      const customPattern = createPattern({
        name: 'transformer',
        execute: async (data: any) => {
          return { ...data, transformed: true };
        },
      });

      const result = await customPattern.execute({ value: 42 });
      expect(result).toEqual({ transformed: true, value: 42 });
    });
  });

  describe('PatternRegistry', () => {
    let registry: PatternRegistry;

    beforeEach(() => {
      registry = new PatternRegistry();
    });

    it('should register and retrieve patterns', () => {
      const pattern: Pattern = {
        name: 'test-pattern',
        execute: async () => 'result',
      };

      registry.register(pattern);
      const retrieved = registry.get('test-pattern');

      expect(retrieved).toEqual(pattern);
    });

    it('should list all patterns', () => {
      registry.register({ name: 'pattern1', execute: async () => {} });
      registry.register({ name: 'pattern2', execute: async () => {} });
      registry.register({ name: 'pattern3', execute: async () => {} });

      const patterns = registry.list();
      expect(patterns).toHaveLength(3);
      expect(patterns.map(p => p.name)).toEqual(['pattern1', 'pattern2', 'pattern3']);
    });

    it('should throw for duplicate pattern names', () => {
      const pattern: Pattern = {
        name: 'duplicate',
        execute: async () => {},
      };

      registry.register(pattern);
      expect(() => registry.register(pattern)).toThrow('Pattern duplicate already registered');
    });

    it('should unregister patterns', () => {
      const pattern: Pattern = {
        name: 'removable',
        execute: async () => {},
      };

      registry.register(pattern);
      registry.unregister('removable');

      expect(registry.get('removable')).toBeUndefined();
    });
  });

  describe('saga pattern', () => {
    it('should execute saga steps in order', async () => {
      const executionOrder: string[] = [];

      const sagaSteps = [
        {
          name: 'step1',
          compensate: async () => {
            executionOrder.push('compensate1');
          },
          execute: async () => {
            executionOrder.push('step1');
            return { step1: 'completed' };
          },
        },
        {
          name: 'step2',
          compensate: async () => {
            executionOrder.push('compensate2');
          },
          execute: async () => {
            executionOrder.push('step2');
            return { step2: 'completed' };
          },
        },
        {
          name: 'step3',
          compensate: async () => {
            executionOrder.push('compensate3');
          },
          execute: async () => {
            executionOrder.push('step3');
            return { step3: 'completed' };
          },
        },
      ];

      const result = await saga(sagaSteps);

      expect(executionOrder).toEqual(['step1', 'step2', 'step3']);
      expect(result).toEqual({
        step1: 'completed',
        step2: 'completed',
        step3: 'completed',
      });
    });

    it('should compensate on failure', async () => {
      const executionOrder: string[] = [];

      const sagaSteps = [
        {
          name: 'step1',
          compensate: async () => {
            executionOrder.push('compensate1');
          },
          execute: async () => {
            executionOrder.push('step1');
            return { step1: 'completed' };
          },
        },
        {
          name: 'step2',
          compensate: async () => {
            executionOrder.push('compensate2');
          },
          execute: async () => {
            executionOrder.push('step2');
            throw new Error('Step 2 failed');
          },
        },
        {
          name: 'step3',
          compensate: async () => {
            executionOrder.push('compensate3');
          },
          execute: async () => {
            executionOrder.push('step3');
            return { step3: 'completed' };
          },
        },
      ];

      await expect(saga(sagaSteps)).rejects.toThrow('Step 2 failed');

      // Should compensate step 1 (step 2 failed before completion)
      expect(executionOrder).toEqual(['step1', 'step2', 'compensate1']);
    });

    it('should handle compensation errors', async () => {
      const sagaSteps = [
        {
          name: 'step1',
          compensate: async () => {
            throw new Error('Compensation failed');
          },
          execute: async () => ({ step1: 'completed' }),
        },
        {
          name: 'step2',
          compensate: async () => {},
          execute: async () => {
            throw new Error('Step 2 failed');
          },
        },
      ];

      await expect(saga(sagaSteps)).rejects.toThrow('Step 2 failed');
      // Compensation error should be logged but not throw
    });
  });

  describe('circuitBreaker pattern', () => {
    it('should allow calls when closed', async () => {
      const service = vi.fn().mockResolvedValue('success');
      const breaker = circuitBreaker(service, {
        failureThreshold: 3,
        resetTimeout: 1000,
      });

      const result = await breaker();
      expect(result).toBe('success');
      expect(service).toHaveBeenCalled();
    });

    it('should open after failure threshold', async () => {
      const service = vi.fn().mockRejectedValue(new Error('Service error'));
      const breaker = circuitBreaker(service, {
        failureThreshold: 3,
        resetTimeout: 1000,
      });

      // Fail 3 times
      for (let i = 0; i < 3; i++) {
        await expect(breaker()).rejects.toThrow('Service error');
      }

      // Circuit should be open
      await expect(breaker()).rejects.toThrow('Circuit breaker is open');
      expect(service).toHaveBeenCalledTimes(3);
    });

    it('should half-open after reset timeout', async () => {
      vi.useFakeTimers();

      const service = vi.fn()
        .mockRejectedValueOnce(new Error('Error 1'))
        .mockRejectedValueOnce(new Error('Error 2'))
        .mockRejectedValueOnce(new Error('Error 3'))
        .mockResolvedValue('success');

      const breaker = circuitBreaker(service, {
        failureThreshold: 3,
        resetTimeout: 1000,
      });

      // Open the circuit
      for (let i = 0; i < 3; i++) {
        await expect(breaker()).rejects.toThrow();
      }

      // Circuit is open
      await expect(breaker()).rejects.toThrow('Circuit breaker is open');

      // Wait for reset timeout
      vi.advanceTimersByTime(1100);

      // Should try again (half-open)
      const result = await breaker();
      expect(result).toBe('success');

      vi.useRealTimers();
    });

    it('should close on successful half-open attempt', async () => {
      vi.useFakeTimers();

      const service = vi.fn()
        .mockRejectedValueOnce(new Error('Error'))
        .mockRejectedValueOnce(new Error('Error'))
        .mockRejectedValueOnce(new Error('Error'))
        .mockResolvedValue('success');

      const breaker = circuitBreaker(service, {
        failureThreshold: 3,
        resetTimeout: 100,
      });

      // Open circuit
      for (let i = 0; i < 3; i++) {
        await expect(breaker()).rejects.toThrow();
      }

      vi.advanceTimersByTime(150);

      // Successful half-open attempt
      await breaker();

      // Should be closed now
      expect(await breaker()).toBe('success');
      expect(await breaker()).toBe('success');

      vi.useRealTimers();
    });
  });

  describe('bulkhead pattern', () => {
    it('should limit concurrent executions', async () => {
      let activeCount = 0;
      let maxActive = 0;

      const service = async () => {
        activeCount++;
        maxActive = Math.max(maxActive, activeCount);
        await new Promise(resolve => setTimeout(resolve, 50));
        activeCount--;
        return 'done';
      };

      const limited = bulkhead(service, { maxConcurrent: 3 });

      // Start 5 concurrent calls
      const promises = Array(5).fill(0).map(() => limited());

      await Promise.all(promises);

      expect(maxActive).toBeLessThanOrEqual(3);
    });

    it('should queue excess calls', async () => {
      const service = vi.fn().mockImplementation(async () => {
        await new Promise(resolve => setTimeout(resolve, 50));
        return 'done';
      });

      const limited = bulkhead(service, {
        maxConcurrent: 2,
        maxQueue: 3,
      });

      // Start 5 concurrent calls (2 active, 3 queued)
      const promises = Array(5).fill(0).map(() => limited());
      const results = await Promise.all(promises);

      expect(results).toEqual(['done', 'done', 'done', 'done', 'done']);
      expect(service).toHaveBeenCalledTimes(5);
    });

    it('should reject when queue is full', async () => {
      const service = async () => {
        await new Promise(resolve => setTimeout(resolve, 100));
        return 'done';
      };

      const limited = bulkhead(service, {
        maxConcurrent: 1,
        maxQueue: 1,
      });

      // Start 3 calls (1 active, 1 queued, 1 rejected)
      const promise1 = limited();
      const promise2 = limited();
      const promise3 = limited();

      await expect(promise3).rejects.toThrow('Bulkhead queue is full');
      await expect(promise1).resolves.toBe('done');
      await expect(promise2).resolves.toBe('done');
    });
  });

  describe('rateLimiter pattern', () => {
    it('should limit rate of calls', async () => {
      const service = vi.fn().mockResolvedValue('success');
      const limited = rateLimiter(service, {
        maxRequests: 3,
        window: 1000,
      });

      // First 3 calls should succeed
      for (let i = 0; i < 3; i++) {
        expect(await limited()).toBe('success');
      }

      // 4th call should be rate limited
      await expect(limited()).rejects.toThrow('Rate limit exceeded');
      expect(service).toHaveBeenCalledTimes(3);
    });

    it('should reset after window', async () => {
      vi.useFakeTimers();

      const service = vi.fn().mockResolvedValue('success');
      const limited = rateLimiter(service, {
        maxRequests: 2,
        window: 1000,
      });

      // Use up the limit
      await limited();
      await limited();

      // Should be rate limited
      await expect(limited()).rejects.toThrow('Rate limit exceeded');

      // Advance time past window
      vi.advanceTimersByTime(1100);

      // Should work again
      expect(await limited()).toBe('success');

      vi.useRealTimers();
    });

    it('should use sliding window', async () => {
      vi.useFakeTimers();

      const service = vi.fn().mockResolvedValue('success');
      const limited = rateLimiter(service, {
        slidingWindow: true,
        maxRequests: 3,
        window: 1000,
      });

      // Make 2 calls
      await limited();
      await limited();

      // Advance 500ms
      vi.advanceTimersByTime(500);

      // Make 1 more call
      await limited();

      // Should be at limit
      await expect(limited()).rejects.toThrow('Rate limit exceeded');

      // Advance 600ms (first call should expire)
      vi.advanceTimersByTime(600);

      // Should allow 1 more
      expect(await limited()).toBe('success');

      vi.useRealTimers();
    });
  });

  describe('eventSourcing pattern', () => {
    it('should record and replay events', async () => {
      const eventStore = eventSourcing<any>();

      // Record events
      await eventStore.append({ type: 'UserCreated', data: { id: 1, name: 'John' } });
      await eventStore.append({ type: 'UserUpdated', data: { id: 1, email: 'john@example.com' } });
      await eventStore.append({ type: 'UserDeleted', data: { id: 1 } });

      // Get all events
      const events = await eventStore.getEvents();
      expect(events).toHaveLength(3);
      expect(events[0].type).toBe('UserCreated');
      expect(events[2].type).toBe('UserDeleted');
    });

    it('should get events by aggregate', async () => {
      const eventStore = eventSourcing<any>();

      await eventStore.append({ type: 'Created', aggregateId: 'user-1', data: {} });
      await eventStore.append({ type: 'Updated', aggregateId: 'user-1', data: {} });
      await eventStore.append({ type: 'Created', aggregateId: 'user-2', data: {} });

      const user1Events = await eventStore.getEventsByAggregate('user-1');
      expect(user1Events).toHaveLength(2);

      const user2Events = await eventStore.getEventsByAggregate('user-2');
      expect(user2Events).toHaveLength(1);
    });

    it('should build snapshot from events', async () => {
      const eventStore = eventSourcing<any>();

      const reducer = (state: any, event: any) => {
        switch (event.type) {
          case 'UserCreated':
            return { ...event.data };
          case 'UserUpdated':
            return { ...state, ...event.data };
          case 'UserDeleted':
            return null;
          default:
            return state;
        }
      };

      await eventStore.append({ type: 'UserCreated', data: { id: 1, name: 'John' } });
      await eventStore.append({ type: 'UserUpdated', data: { email: 'john@example.com' } });

      const snapshot = await eventStore.getSnapshot(reducer);
      expect(snapshot).toEqual({
        id: 1,
        name: 'John',
        email: 'john@example.com',
      });
    });
  });

  describe('cqrs pattern', () => {
    it('should separate commands and queries', async () => {
      const store = { users: new Map() };

      const cqrsSystem = cqrs({
        commands: {
          createUser: async (data: { id: string; name: string }) => {
            store.users.set(data.id, data);
            return { success: true };
          },
          updateUser: async (data: { id: string; name: string }) => {
            const user = store.users.get(data.id);
            if (user) {
              store.users.set(data.id, { ...user, ...data });
            }
            return { success: true };
          },
        },
        queries: {
          getUser: async (id: string) => store.users.get(id),
          listUsers: async () => Array.from(store.users.values()),
        },
      });

      // Execute commands
      await cqrsSystem.command('createUser', { id: '1', name: 'John' });
      await cqrsSystem.command('createUser', { id: '2', name: 'Jane' });

      // Execute queries
      const user = await cqrsSystem.query('getUser', '1');
      expect(user).toEqual({ id: '1', name: 'John' });

      const users = await cqrsSystem.query('listUsers');
      expect(users).toHaveLength(2);
    });

    it('should validate command existence', async () => {
      const cqrsSystem = cqrs({
        commands: {},
        queries: {},
      });

      await expect(cqrsSystem.command('nonExistent', {}))
        .rejects.toThrow('Command nonExistent not found');
    });

    it('should handle command middleware', async () => {
      const executed: string[] = [];

      const cqrsSystem = cqrs({
        middleware: {
          command: async (name, data, next) => {
            executed.push('before');
            await next();
            executed.push('after');
          },
        },
        commands: {
          test: async () => {
            executed.push('command');
          },
        },
        queries: {},
      });

      await cqrsSystem.command('test', {});
      expect(executed).toEqual(['before', 'command', 'after']);
    });
  });

  describe('pubsub pattern', () => {
    it('should publish and subscribe to events', async () => {
      const pubsubSystem = pubsub();
      const received: any[] = [];

      // Subscribe
      pubsubSystem.subscribe('user.created', async (data) => {
        received.push({ data, event: 'user.created' });
      });

      pubsubSystem.subscribe('user.*', async (data) => {
        received.push({ data, event: 'user.*' });
      });

      // Publish
      await pubsubSystem.publish('user.created', { id: 1, name: 'John' });

      expect(received).toHaveLength(2);
      expect(received[0].event).toBe('user.created');
      expect(received[1].event).toBe('user.*');
    });

    it('should unsubscribe', async () => {
      const pubsubSystem = pubsub();
      const handler = vi.fn();

      const unsubscribe = pubsubSystem.subscribe('test', handler);
      await pubsubSystem.publish('test', 'data1');
      
      unsubscribe();
      await pubsubSystem.publish('test', 'data2');

      expect(handler).toHaveBeenCalledTimes(1);
      expect(handler).toHaveBeenCalledWith('data1');
    });

    it('should handle multiple subscribers', async () => {
      const pubsubSystem = pubsub();
      const handlers = [vi.fn(), vi.fn(), vi.fn()];

      handlers.forEach(handler => pubsubSystem.subscribe('event', handler));
      await pubsubSystem.publish('event', 'data');

      handlers.forEach(handler => {
        expect(handler).toHaveBeenCalledWith('data');
      });
    });
  });

  describe('messageQueue pattern', () => {
    it('should enqueue and process messages', async () => {
      const processed: any[] = [];
      const queue = messageQueue({
        processor: async (message) => {
          processed.push(message);
        },
      });

      await queue.send({ id: 1, data: 'message1' });
      await queue.send({ id: 2, data: 'message2' });
      await queue.send({ id: 3, data: 'message3' });

      // Give time for processing
      await new Promise(resolve => setTimeout(resolve, 100));

      expect(processed).toHaveLength(3);
      expect(processed[0]).toEqual({ id: 1, data: 'message1' });
    });

    it('should retry failed messages', async () => {
      let attempts = 0;
      const queue = messageQueue({
        maxRetries: 3,
        processor: async (message) => {
          attempts++;
          if (attempts < 3) {
            throw new Error('Processing failed');
          }
          return message;
        },
      });

      await queue.send({ data: 'test' });
      await new Promise(resolve => setTimeout(resolve, 200));

      expect(attempts).toBe(3);
    });

    it('should handle DLQ for failed messages', async () => {
      const dlq: any[] = [];
      const queue = messageQueue({
        dlqHandler: async (message, error) => {
          dlq.push({ error: error.message, message });
        },
        maxRetries: 2,
        processor: async () => {
          throw new Error('Always fails');
        },
      });

      await queue.send({ data: 'test' });
      await new Promise(resolve => setTimeout(resolve, 200));

      expect(dlq).toHaveLength(1);
      expect(dlq[0].error).toBe('Always fails');
    });
  });

  describe('distributedLock pattern', () => {
    it('should acquire and release lock', async () => {
      const lock = distributedLock();
      const results: string[] = [];

      const task1 = async () => {
        await lock.acquire('resource1', async () => {
          results.push('task1-start');
          await new Promise(resolve => setTimeout(resolve, 50));
          results.push('task1-end');
        });
      };

      const task2 = async () => {
        await new Promise(resolve => setTimeout(resolve, 10));
        await lock.acquire('resource1', async () => {
          results.push('task2-start');
          await new Promise(resolve => setTimeout(resolve, 50));
          results.push('task2-end');
        });
      };

      await Promise.all([task1(), task2()]);

      expect(results).toEqual([
        'task1-start',
        'task1-end',
        'task2-start',
        'task2-end',
      ]);
    });

    it('should timeout if lock not acquired', async () => {
      const lock = distributedLock();

      // Acquire lock
      const release = await lock.acquire('resource1', async () => {
        await new Promise(resolve => setTimeout(resolve, 200));
      });

      // Try to acquire with timeout
      const promise = lock.acquire('resource1', async () => {}, { timeout: 100 });

      await expect(promise).rejects.toThrow('Lock acquisition timeout');
    });

    it('should handle multiple resources', async () => {
      const lock = distributedLock();
      const results: string[] = [];

      await Promise.all([
        lock.acquire('resource1', async () => {
          results.push('resource1');
        }),
        lock.acquire('resource2', async () => {
          results.push('resource2');
        }),
      ]);

      expect(results).toContain('resource1');
      expect(results).toContain('resource2');
    });
  });

  describe('leaderElection pattern', () => {
    it('should elect a leader', async () => {
      const nodes: any[] = [];

      const createNode = (id: string) => {
        const node = leaderElection({
          nodeId: id,
          onBecomeFollower: () => {
            nodes.push({ id, role: 'follower' });
          },
          onBecomeLeader: () => {
            nodes.push({ id, role: 'leader' });
          },
        });
        return node;
      };

      const node1 = createNode('node1');
      const node2 = createNode('node2');
      const node3 = createNode('node3');

      await Promise.all([
        node1.start(),
        node2.start(),
        node3.start(),
      ]);

      // Give time for election
      await new Promise(resolve => setTimeout(resolve, 100));

      const leaders = nodes.filter(n => n.role === 'leader');
      const followers = nodes.filter(n => n.role === 'follower');

      expect(leaders).toHaveLength(1);
      expect(followers).toHaveLength(2);
    });

    it('should handle leader failure', async () => {
      const events: any[] = [];

      const node1 = leaderElection({
        nodeId: 'node1',
        onBecomeLeader: () => events.push({ event: 'became-leader', node: 'node1' }),
        onLoseLeadership: () => events.push({ event: 'lost-leadership', node: 'node1' }),
      });

      const node2 = leaderElection({
        nodeId: 'node2',
        onBecomeLeader: () => events.push({ event: 'became-leader', node: 'node2' }),
      });

      await node1.start();
      await node2.start();

      // Node1 becomes leader
      await new Promise(resolve => setTimeout(resolve, 50));

      // Simulate node1 failure
      await node1.stop();

      // Node2 should become leader
      await new Promise(resolve => setTimeout(resolve, 100));

      expect(events).toContainEqual({ event: 'became-leader', node: 'node1' });
      expect(events).toContainEqual({ event: 'lost-leadership', node: 'node1' });
      expect(events).toContainEqual({ event: 'became-leader', node: 'node2' });
    });
  });
});