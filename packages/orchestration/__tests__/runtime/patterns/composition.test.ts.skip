import { describe, expect, it, vi } from 'vitest';

import {
  branch,
  cache,
  catchError,
  chain,
  compose,
  filter,
  fork,
  map,
  memoize,
  merge,
  pipe,
  reduce,
  retry as retryComposition,
  tap,
  timeout as timeoutComposition,
} from '../../../src/runtime/patterns/composition';

describe('Composition Patterns', () => {
  describe('compose', () => {
    it('should compose functions right to left', async () => {
      const add5 = (x: number) => x + 5;
      const multiply2 = (x: number) => x * 2;
      const subtract3 = (x: number) => x - 3;

      const composed = compose(subtract3, multiply2, add5);
      const result = await composed(10);

      expect(result).toBe(27); // (10 + 5) * 2 - 3 = 27
    });

    it('should compose async functions', async () => {
      const asyncAdd = async (x: number) => x + 5;
      const asyncMultiply = async (x: number) => x * 2;
      const asyncSubtract = async (x: number) => x - 3;

      const composed = compose(asyncSubtract, asyncMultiply, asyncAdd);
      const result = await composed(10);

      expect(result).toBe(27);
    });

    it('should handle single function', async () => {
      const double = (x: number) => x * 2;
      const composed = compose(double);
      const result = await composed(5);

      expect(result).toBe(10);
    });

    it('should handle empty composition', async () => {
      const composed = compose();
      const result = await composed(42);

      expect(result).toBe(42);
    });
  });

  describe('pipe', () => {
    it('should pipe functions left to right', async () => {
      const add5 = (x: number) => x + 5;
      const multiply2 = (x: number) => x * 2;
      const subtract3 = (x: number) => x - 3;

      const piped = pipe(add5, multiply2, subtract3);
      const result = await piped(10);

      expect(result).toBe(27); // (10 + 5) * 2 - 3 = 27
    });

    it('should pipe async functions', async () => {
      const asyncAdd = async (x: number) => x + 5;
      const asyncMultiply = async (x: number) => x * 2;
      const asyncSubtract = async (x: number) => x - 3;

      const piped = pipe(asyncAdd, asyncMultiply, asyncSubtract);
      const result = await piped(10);

      expect(result).toBe(27);
    });

    it('should handle errors in pipeline', async () => {
      const add5 = (x: number) => x + 5;
      const throwError = () => {
        throw new Error('Pipeline error');
      };
      const multiply2 = (x: number) => x * 2;

      const piped = pipe(add5, throwError, multiply2);

      await expect(piped(10)).rejects.toThrow('Pipeline error');
    });
  });

  describe('chain', () => {
    it('should chain functions with context', async () => {
      const getUserId = (ctx: { user: { id: number } }) => ctx.user.id;
      const fetchUserData = async (id: number) => ({ id, name: 'John' });
      const formatUser = (data: { id: number; name: string }) => `User: ${data.name} (${data.id})`;

      const chained = chain(getUserId, fetchUserData, formatUser);
      const result = await chained({ user: { id: 123 } });

      expect(result).toBe('User: John (123)');
    });

    it('should pass context through chain', async () => {
      const operations: any[] = [];

      const step1 = (ctx: any) => {
        operations.push({ ctx, step: 1 });
        return { ...ctx, step1: true };
      };

      const step2 = (ctx: any) => {
        operations.push({ ctx, step: 2 });
        return { ...ctx, step2: true };
      };

      const step3 = (ctx: any) => {
        operations.push({ ctx, step: 3 });
        return { ...ctx, step3: true };
      };

      const chained = chain(step1, step2, step3);
      const result = await chained({ initial: true });

      expect(result).toEqual({
        initial: true,
        step1: true,
        step2: true,
        step3: true,
      });

      expect(operations).toHaveLength(3);
    });
  });

  describe('fork', () => {
    it('should fork execution to multiple functions', async () => {
      const double = (x: number) => x * 2;
      const triple = (x: number) => x * 3;
      const square = (x: number) => x * x;

      const forked = fork(double, triple, square);
      const results = await forked(5);

      expect(results).toEqual([10, 15, 25]);
    });

    it('should handle async functions in fork', async () => {
      const asyncDouble = async (x: number) => {
        await new Promise(resolve => setTimeout(resolve, 10));
        return x * 2;
      };
      const asyncTriple = async (x: number) => {
        await new Promise(resolve => setTimeout(resolve, 20));
        return x * 3;
      };

      const forked = fork(asyncDouble, asyncTriple);
      const results = await forked(5);

      expect(results).toEqual([10, 15]);
    });

    it('should handle errors in fork', async () => {
      const success = (x: number) => x * 2;
      const failure = () => {
        throw new Error('Fork error');
      };

      const forked = fork(success, failure);

      await expect(forked(5)).rejects.toThrow('Fork error');
    });
  });

  describe('merge', () => {
    it('should merge results from multiple functions', async () => {
      const getName = () => ({ name: 'John' });
      const getAge = () => ({ age: 30 });
      const getCity = () => ({ city: 'New York' });

      const merged = merge(getName, getAge, getCity);
      const result = await merged();

      expect(result).toEqual({
        name: 'John',
        age: 30,
        city: 'New York',
      });
    });

    it('should handle overlapping keys', async () => {
      const func1 = () => ({ a: 1, b: 2 });
      const func2 = () => ({ b: 3, c: 4 });

      const merged = merge(func1, func2);
      const result = await merged();

      expect(result).toEqual({ a: 1, b: 3, c: 4 });
    });

    it('should merge arrays', async () => {
      const func1 = () => [1, 2, 3];
      const func2 = () => [4, 5, 6];

      const merged = merge(func1, func2);
      const result = await merged();

      expect(result).toEqual([1, 2, 3, 4, 5, 6]);
    });
  });

  describe('branch', () => {
    it('should branch based on condition', async () => {
      const isEven = (n: number) => n % 2 === 0;
      const handleEven = (n: number) => `${n} is even`;
      const handleOdd = (n: number) => `${n} is odd`;

      const branched = branch(isEven, handleEven, handleOdd);

      expect(await branched(4)).toBe('4 is even');
      expect(await branched(5)).toBe('5 is odd');
    });

    it('should handle async conditions', async () => {
      const asyncCondition = async (n: number) => n > 10;
      const handleLarge = (n: number) => `${n} is large`;
      const handleSmall = (n: number) => `${n} is small`;

      const branched = branch(asyncCondition, handleLarge, handleSmall);

      expect(await branched(15)).toBe('15 is large');
      expect(await branched(5)).toBe('5 is small');
    });

    it('should handle missing else branch', async () => {
      const isPositive = (n: number) => n > 0;
      const handlePositive = (n: number) => `${n} is positive`;

      const branched = branch(isPositive, handlePositive);

      expect(await branched(5)).toBe('5 is positive');
      expect(await branched(-5)).toBeUndefined();
    });
  });

  describe('map', () => {
    it('should map over array', async () => {
      const double = (x: number) => x * 2;
      const mapped = map(double);

      const result = await mapped([1, 2, 3, 4, 5]);
      expect(result).toEqual([2, 4, 6, 8, 10]);
    });

    it('should map with async function', async () => {
      const asyncDouble = async (x: number) => x * 2;
      const mapped = map(asyncDouble);

      const result = await mapped([1, 2, 3]);
      expect(result).toEqual([2, 4, 6]);
    });

    it('should preserve index in mapping', async () => {
      const withIndex = (value: number, index: number) => `${index}:${value}`;
      const mapped = map(withIndex);

      const result = await mapped([10, 20, 30]);
      expect(result).toEqual(['0:10', '1:20', '2:30']);
    });
  });

  describe('filter', () => {
    it('should filter array', async () => {
      const isEven = (x: number) => x % 2 === 0;
      const filtered = filter(isEven);

      const result = await filtered([1, 2, 3, 4, 5, 6]);
      expect(result).toEqual([2, 4, 6]);
    });

    it('should filter with async predicate', async () => {
      const asyncIsEven = async (x: number) => x % 2 === 0;
      const filtered = filter(asyncIsEven);

      const result = await filtered([1, 2, 3, 4, 5, 6]);
      expect(result).toEqual([2, 4, 6]);
    });

    it('should handle empty results', async () => {
      const alwaysFalse = () => false;
      const filtered = filter(alwaysFalse);

      const result = await filtered([1, 2, 3]);
      expect(result).toEqual([]);
    });
  });

  describe('reduce', () => {
    it('should reduce array', async () => {
      const sum = (acc: number, val: number) => acc + val;
      const reduced = reduce(sum, 0);

      const result = await reduced([1, 2, 3, 4, 5]);
      expect(result).toBe(15);
    });

    it('should reduce with async reducer', async () => {
      const asyncSum = async (acc: number, val: number) => acc + val;
      const reduced = reduce(asyncSum, 0);

      const result = await reduced([1, 2, 3, 4, 5]);
      expect(result).toBe(15);
    });

    it('should build object with reduce', async () => {
      const toObject = (acc: Record<string, number>, val: number) => ({
        ...acc,
        [`key${val}`]: val * 10,
      });
      const reduced = reduce(toObject, {});

      const result = await reduced([1, 2, 3]);
      expect(result).toEqual({
        key1: 10,
        key2: 20,
        key3: 30,
      });
    });
  });

  describe('tap', () => {
    it('should execute side effect without changing value', async () => {
      const sideEffects: number[] = [];
      const logValue = (x: number) => {
        sideEffects.push(x);
      };

      const tapped = tap(logValue);
      const result = await tapped(42);

      expect(result).toBe(42);
      expect(sideEffects).toEqual([42]);
    });

    it('should work in pipeline', async () => {
      const logs: string[] = [];
      const double = (x: number) => x * 2;
      const log = (x: number) => logs.push(`Value: ${x}`);

      const pipeline = pipe(
        double,
        tap(log),
        double,
        tap(log),
      );

      const result = await pipeline(5);

      expect(result).toBe(20);
      expect(logs).toEqual(['Value: 10', 'Value: 20']);
    });
  });

  describe('catchError', () => {
    it('should catch and handle errors', async () => {
      const throwError = () => {
        throw new Error('Test error');
      };
      const errorHandler = (error: Error) => `Caught: ${error.message}`;

      const wrapped = catchError(throwError, errorHandler);
      const result = await wrapped();

      expect(result).toBe('Caught: Test error');
    });

    it('should pass through successful results', async () => {
      const success = (x: number) => x * 2;
      const errorHandler = () => 'error';

      const wrapped = catchError(success, errorHandler);
      const result = await wrapped(5);

      expect(result).toBe(10);
    });

    it('should handle async errors', async () => {
      const asyncError = async () => {
        throw new Error('Async error');
      };
      const errorHandler = (error: Error) => `Handled: ${error.message}`;

      const wrapped = catchError(asyncError, errorHandler);
      const result = await wrapped();

      expect(result).toBe('Handled: Async error');
    });
  });

  describe('retry', () => {
    it('should retry on failure', async () => {
      let attempts = 0;
      const unreliable = () => {
        attempts++;
        if (attempts < 3) {
          throw new Error('Not yet');
        }
        return 'Success';
      };

      const retried = retryComposition(unreliable, { maxAttempts: 3 });
      const result = await retried();

      expect(result).toBe('Success');
      expect(attempts).toBe(3);
    });

    it('should fail after max attempts', async () => {
      const alwaysFails = () => {
        throw new Error('Always fails');
      };

      const retried = retryComposition(alwaysFails, { maxAttempts: 3 });

      await expect(retried()).rejects.toThrow('Always fails');
    });

    it('should apply delay between retries', async () => {
      let attempts = 0;
      const timestamps: number[] = [];

      const func = () => {
        attempts++;
        timestamps.push(Date.now());
        if (attempts < 3) {
          throw new Error('Retry');
        }
        return 'Success';
      };

      const retried = retryComposition(func, {
        delay: 50,
        maxAttempts: 3,
      });

      await retried();

      expect(timestamps).toHaveLength(3);
      const delay1 = timestamps[1] - timestamps[0];
      const delay2 = timestamps[2] - timestamps[1];
      expect(delay1).toBeGreaterThanOrEqual(45);
      expect(delay2).toBeGreaterThanOrEqual(45);
    });
  });

  describe('timeout', () => {
    it('should complete within timeout', async () => {
      const fast = async () => {
        await new Promise(resolve => setTimeout(resolve, 50));
        return 'Fast';
      };

      const wrapped = timeoutComposition(fast, 100);
      const result = await wrapped();

      expect(result).toBe('Fast');
    });

    it('should timeout slow functions', async () => {
      const slow = async () => {
        await new Promise(resolve => setTimeout(resolve, 200));
        return 'Slow';
      };

      const wrapped = timeoutComposition(slow, 100);

      await expect(wrapped()).rejects.toThrow('Operation timed out');
    });
  });

  describe('cache', () => {
    it('should cache function results', async () => {
      let callCount = 0;
      const expensive = (x: number) => {
        callCount++;
        return x * 2;
      };

      const cached = cache(expensive);

      expect(await cached(5)).toBe(10);
      expect(await cached(5)).toBe(10);
      expect(await cached(5)).toBe(10);

      expect(callCount).toBe(1);
    });

    it('should cache with custom key', async () => {
      let callCount = 0;
      const func = (obj: { id: number; name: string }) => {
        callCount++;
        return `${obj.name}-${obj.id}`;
      };

      const cached = cache(func, {
        keyFn: (obj) => obj.id.toString(),
      });

      const obj1 = { id: 1, name: 'John' };
      const obj2 = { id: 1, name: 'Jane' }; // Same ID

      expect(await cached(obj1)).toBe('John-1');
      expect(await cached(obj2)).toBe('John-1'); // Cached result

      expect(callCount).toBe(1);
    });

    it('should expire cache after TTL', async () => {
      vi.useFakeTimers();

      let callCount = 0;
      const func = (x: number) => {
        callCount++;
        return x * 2;
      };

      const cached = cache(func, { ttl: 1000 });

      expect(await cached(5)).toBe(10);
      expect(callCount).toBe(1);

      vi.advanceTimersByTime(500);
      expect(await cached(5)).toBe(10);
      expect(callCount).toBe(1);

      vi.advanceTimersByTime(600);
      expect(await cached(5)).toBe(10);
      expect(callCount).toBe(2);

      vi.useRealTimers();
    });
  });

  describe('memoize', () => {
    it('should memoize function results', async () => {
      let callCount = 0;
      const fibonacci = memoize((n: number): number => {
        callCount++;
        if (n <= 1) return n;
        return fibonacci(n - 1) + fibonacci(n - 2);
      });

      const result = await fibonacci(10);
      expect(result).toBe(55);

      // Should use memoized results
      const result2 = await fibonacci(10);
      expect(result2).toBe(55);

      // Call count should be much less than without memoization
      expect(callCount).toBeLessThan(20);
    });

    it('should memoize with multiple arguments', async () => {
      let callCount = 0;
      const add = memoize((a: number, b: number) => {
        callCount++;
        return a + b;
      });

      expect(await add(2, 3)).toBe(5);
      expect(await add(2, 3)).toBe(5);
      expect(await add(3, 2)).toBe(5);

      expect(callCount).toBe(2); // Different argument order = different call
    });
  });

  describe('complex compositions', () => {
    it('should compose multiple patterns', async () => {
      const addTax = (price: number) => price * 1.1;
      const addShipping = (price: number) => price + 10;
      const format = (price: number) => `$${price.toFixed(2)}`;

      const processPrice = pipe(
        tap((price: number) => console.log(`Original: ${price}`)),
        addTax,
        tap((price: number) => console.log(`After tax: ${price}`)),
        addShipping,
        tap((price: number) => console.log(`After shipping: ${price}`)),
        format,
      );

      const result = await processPrice(100);
      expect(result).toBe('$120.00');
    });

    it('should handle complex error scenarios', async () => {
      const unreliableService = () => {
        if (Math.random() > 0.5) {
          throw new Error('Service unavailable');
        }
        return 'Success';
      };

      const robustService = pipe(
        retryComposition(unreliableService, { maxAttempts: 5 }),
        catchError(
          (x) => x,
          () => 'Fallback response'
        ),
      );

      const result = await robustService();
      expect(['Success', 'Fallback response']).toContain(result);
    });
  });
});