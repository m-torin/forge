'use client';

import { useEffect, useState } from 'react';

/**
 * Feature flag functions - now part of analytics package
 * Uses PostHog for flag evaluation and automatically tracks usage
 */

// Type declaration for PostHog on window
declare global {
  interface Window {
    posthog?: {
      isFeatureEnabled(key: string): boolean | undefined;
      [key: string]: any;
    };
  }
}

// Parse local flags once at startup
let localFlags: Record<string, boolean> | null = null;
const localFlagsEnv = process.env.LOCAL_FLAGS || process.env.NEXT_PUBLIC_LOCAL_FLAGS;
if (localFlagsEnv) {
  try {
    localFlags = JSON.parse(localFlagsEnv);
    console.log('[Analytics] Using local feature flags:', Object.keys(localFlags || {}).length, 'flags');
  } catch (error) {
    console.error('[Analytics] Failed to parse LOCAL_FLAGS:', error);
  }
}

/**
 * Check if a feature flag is enabled
 * @param key - The flag key (e.g., 'analytics.debug', 'auth.magic-link')
 * @param userId - Optional user ID for server-side checks
 * @returns Promise<boolean> - Whether the flag is enabled
 */
export async function flag(key: string, userId?: string): Promise<boolean> {
  // 1. Check local override (for development)
  if (localFlags && key in localFlags) {
    return localFlags[key];
  }

  // 2. Client-side: Use PostHog from window
  if (typeof window !== 'undefined' && window.posthog) {
    return window.posthog.isFeatureEnabled(key) ?? false;
  }

  // 3. Server-side: Use PostHog server client
  if (typeof window === 'undefined' && userId) {
    try {
      const { analytics } = await import('./posthog/server');
      return await analytics.isFeatureEnabled(key, userId) ?? false;
    } catch (error) {
      console.error('[Analytics] Failed to check server flag:', error);
      return false;
    }
  }

  // 4. Default to false
  return false;
}

/**
 * React hook for feature flags
 * @param key - The flag key
 * @returns boolean - Whether the flag is enabled
 */
export function useFlag(key: string): boolean {
  const [enabled, setEnabled] = useState(false);
  const [checked, setChecked] = useState(false);

  useEffect(() => {
    flag(key).then(value => {
      setEnabled(value);
      setChecked(true);
    });
  }, [key]);

  // Return false until we've checked (safer default)
  return checked ? enabled : false;
}

/**
 * Get multiple flags at once (more efficient)
 * @param keys - Array of flag keys
 * @param userId - Optional user ID for server-side checks
 * @returns Promise<Record<string, boolean>> - Object with flag states
 */
export async function flags(keys: string[], userId?: string): Promise<Record<string, boolean>> {
  const results = await Promise.all(
    keys.map(key => flag(key, userId).then(value => ({ key, value })))
  );
  
  return results.reduce((acc, { key, value }) => {
    acc[key] = value;
    return acc;
  }, {} as Record<string, boolean>);
}

/**
 * Common flag keys for easy discovery
 * Usage: flag(FLAGS.analytics.debug)
 */
export const FLAGS = {
  analytics: {
    enabled: 'analytics.enabled',
    debug: 'analytics.debug',
    segment: 'analytics.segment.enabled',
    posthog: 'analytics.posthog.enabled',
    google: 'analytics.google.enabled',
  },
  auth: {
    magicLink: 'auth.magic-link.enabled',
    oauth: {
      google: 'auth.oauth.google',
      github: 'auth.oauth.github',
      discord: 'auth.oauth.discord',
    },
    twoFactor: 'auth.two-factor.required',
    organizations: 'auth.organizations.enabled',
    apiKeys: 'auth.api-keys.enabled',
  },
  payments: {
    stripe: 'payments.stripe.enabled',
    subscriptions: 'payments.subscriptions.enabled',
    trials: 'payments.trials.enabled',
    refunds: 'payments.refunds.enabled',
  },
  ui: {
    darkMode: 'ui.dark-mode.enabled',
    animations: 'ui.animations.enabled',
    betaComponents: 'ui.beta-components',
    newNavigation: 'ui.new-navigation',
  },
  ai: {
    enabled: 'ai.enabled',
    chat: 'ai.chat.enabled',
    openai: 'ai.openai.enabled',
    anthropic: 'ai.anthropic.enabled',
  },
} as const;

// Export the types that providers expect
export type { AnalyticsFlags, AuthFlags, PaymentFlags, AIFlags, UIFlags } from './types/flags';

// Individual flag functions for backwards compatibility
export const analyticsEnabled = (userId?: string) => flag(FLAGS.analytics.enabled, userId);
export const segmentAnalyticsEnabled = (userId?: string) => flag(FLAGS.analytics.segment, userId);
export const posthogAnalyticsEnabled = (userId?: string) => flag(FLAGS.analytics.posthog, userId);
export const googleAnalyticsEnabled = (userId?: string) => flag(FLAGS.analytics.google, userId);
export const analyticsDebugMode = (userId?: string) => flag(FLAGS.analytics.debug, userId);
export const analyticsProductionOnly = (userId?: string) => flag('analytics.production-only', userId);
export const analyticsDevelopmentMode = (userId?: string) => flag('analytics.development-mode', userId);