    "@storybook/nextjs": "^8.6.9",
    "@storybook/react": "^8.6.9",
    "@storybook/test": "^8.6.9",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "chromatic": "^11.27.0",
    "concurrently": "^9.1.2",
    "pixeleye": "^0.8.8",
    "postcss": "catalog:",
    "storybook": "^8.6.9",
